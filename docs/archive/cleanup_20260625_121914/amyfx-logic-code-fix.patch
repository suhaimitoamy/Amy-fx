+      // Runtime bridge fix for APK mode: the React bundle does not expose raw bslTarget/sslTarget,
+      // so the native scanner gets refreshed from the visible Mapping narrative text.
+      (function() {
+        const state = { lastBsl: "", lastSsl: "", lastKey: "", lastScannerSync: 0 };
+
+        function readTargetsFromText() {
+          const text = document.body ? document.body.innerText || "" : "";
+          const bsl = text.match(/Buy-Side Liquidity \(BSL\)[^0-9]*(\d+(?:\.\d+)?)/i);
+          const ssl = text.match(/Sell-Side Liquidity \(SSL\)[^0-9]*(\d+(?:\.\d+)?)/i);
+          return {
+            bsl: bsl ? bsl[1] : "",
+            ssl: ssl ? ssl[1] : ""
+          };
+        }
+
+        function syncNativeScannerTargets() {
+          try {
+            if (!window.Android || typeof window.Android.startBackgroundScanner !== "function") return;
+            if (localStorage.getItem("bg_scanner") !== "true") return;
+            const key = (localStorage.getItem("twelve_api_key") || "").trim();
+            if (!key) return;
+            const targets = readTargetsFromText();
+            if (!targets.bsl && !targets.ssl) return;
+            const changed = targets.bsl !== state.lastBsl || targets.ssl !== state.lastSsl || key !== state.lastKey;
+            const stale = Date.now() - state.lastScannerSync > 60000;
+            if (!changed && !stale) return;
+            state.lastBsl = targets.bsl;
+            state.lastSsl = targets.ssl;
+            state.lastKey = key;
+            state.lastScannerSync = Date.now();
+            window.Android.startBackgroundScanner(key, targets.bsl || "", targets.ssl || "");
+          } catch (e) {}
+        }
+
+        function normalizeAlertKey(title, message) {
+          return String(title || "") + "|" + String(message || "")
+            .replace(/\d+(?:\.\d+)?/g, "#")
+            .replace(/\([^)]*\d[^)]*\)/g, "(#)")
+            .replace(/\s+/g, " ")
+            .trim();
+        }
+
+        function wrapAndroidNotifications() {
+          if (!window.Android || window.Android.__amyFxWrapped) return;
+          const last = new Map();
+          ["showNotificationWithUrl", "showNotification"].forEach(function(name) {
+            if (typeof window.Android[name] !== "function") return;
+            const original = window.Android[name].bind(window.Android);
+            window.Android[name] = function(title, message) {
+              const key = normalizeAlertKey(title, message);
+              const now = Date.now();
+              const previous = last.get(key) || 0;
+              if (now - previous < 300000) return;
+              last.set(key, now);
+              return original.apply(null, arguments);
+            };
+          });
+          window.Android.__amyFxWrapped = true;
+        }
+
+        wrapAndroidNotifications();
+        setInterval(function() {
+          wrapAndroidNotifications();
+          syncNativeScannerTargets();
+        }, 5000);
+        document.addEventListener("visibilitychange", function() {
+          if (document.visibilityState === "visible") syncNativeScannerTargets();
+        });
+      })();
     </script>
   </body>
 </html>
