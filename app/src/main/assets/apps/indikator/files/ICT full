//@version=5
indicator("ICT Concepts [amygmgo] FULL", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500, max_bars_back=3000)

//-----------------------------------------------------------------------------
// STRINGS
//-----------------------------------------------------------------------------
o          = 'Options'
sp1        = '       '
sp2        = '              '
hl         = 'High / Low    ' + sp1
ny_        = 'New York' + sp1
lo_        = 'London Open'
lc_        = 'London Close'
as_        = 'Asian'

//-----------------------------------------------------------------------------
// SETTINGS — MAIN INDICATOR STYLE
//-----------------------------------------------------------------------------
i_mode     = input.string('Present', title='Mode', options=['Present', 'Historical'])

showMS     = input.bool(true, title='', group='Market Structures', inline='MS')
len        = input.int(5, title='     Length   ' + sp2, group='Market Structures', inline='MS', minval=3, maxval=10)

iMSS       = input.bool(true, title='       MSS' + sp1, group='Market Structures', inline='M1')
cMSSbl     = input.color(color.new(#00e6a1, 0), title='bullish', group='Market Structures', inline='M1')
cMSSbr     = input.color(color.new(#e60400, 0), title='bearish', group='Market Structures', inline='M1')

iBOS       = input.bool(true, title='       BOS' + sp1, group='Market Structures', inline='BS')
cBOSbl     = input.color(color.new(#00e6a1, 0), title='bullish', group='Market Structures', inline='BS')
cBOSbr     = input.color(color.new(#e60400, 0), title='bearish', group='Market Structures', inline='BS')

sDispl     = input.bool(false, title='Show Displacement', group='Displacement')

sVimbl     = input.bool(true, title='', group='Volume Imbalance', inline='VI')
visVim     = input.int(2, title="   # Visible VI's  " + sp1, group='Volume Imbalance', inline='VI', minval=2, maxval=100)
cVimbl     = input.color(color.new(#06b2d0, 0), title='', group='Volume Imbalance', inline='VI')

showOB     = input.bool(true, title='Show Order Blocks', group='Order Blocks')
length     = input.int(10, title='Swing Lookback', group='Order Blocks', minval=3)
showBull   = input.int(1, title='Show Last Bullish OB', group='Order Blocks', minval=0)
showBear   = input.int(1, title='Show Last Bearish OB', group='Order Blocks', minval=0)
useBody    = input.bool(true, title='Use Candle Body', group='Order Blocks')

bullCss    = input.color(color.new(#3e89fa, 0), title='Bullish OB  ', group='Order Blocks', inline='bullcss')
bullBrkCss = input.color(color.new(#4785f9, 85), title='Bullish Break  ', group='Order Blocks', inline='bullcss')
bearCss    = input.color(color.new(#FF3131, 0), title='Bearish OB', group='Order Blocks', inline='bearcss')
bearBrkCss = input.color(color.new(#f9ff57, 85), title='Bearish Break', group='Order Blocks', inline='bearcss')
showLabels = input.bool(false, title='Show Historical Polarity Changes', group='Order Blocks')

showLq     = input.bool(true, title='Show Liquidity', group='Liquidity')
a          = 10 / input.float(4, title='margin', group='Liquidity', step=0.1, minval=2, maxval=7)
visLiq     = input.int(2, title='# Visible Liq. boxes', group='Liquidity', minval=1, maxval=50)
cLIQ_B     = input.color(color.new(#fa451c, 0), title='Buyside Liquidity  ', group='Liquidity')
cLIQ_S     = input.color(color.new(#1ce4fa, 0), title='Sellside Liquidity', group='Liquidity')

shwFVG     = input.bool(true, title='Show FVGs', group='Fair Value Gaps')
i_BPR      = input.bool(false, title='Balance Price Range', group='Fair Value Gaps')
i_FVG      = input.string('FVG', title=o, group='Fair Value Gaps', options=['FVG', 'IFVG'])
visBxs     = input.int(2, title="# Visible FVG's", group='Fair Value Gaps', minval=1, maxval=20)

cFVGbl     = input.color(color.new(#00e676, 0), title='Bullish FVG  ', group='Fair Value Gaps', inline='FVGbl')
cFVGblBR   = input.color(color.new(#808000, 0), title='Break', group='Fair Value Gaps', inline='FVGbl')
cFVGbr     = input.color(color.new(#ff5252, 0), title='Bearish FVG ', group='Fair Value Gaps', inline='FVGbr')
cFVGbrBR   = input.color(color.new(#FF0000, 0), title='Break', group='Fair Value Gaps', inline='FVGbr')

iNWOG      = input.bool(true, title='', inline='NWOG', group='NWOG/NDOG')
cNWOG1     = input.color(color.new(#ff5252, 28), title='NWOG    ', inline='NWOG', group='NWOG/NDOG')
cNWOG2     = input.color(color.new(#b2b5be, 50), title='', inline='NWOG', group='NWOG/NDOG')
maxNWOG    = input.int(3, title='Show max', inline='NWOG', group='NWOG/NDOG', minval=0, maxval=50)

iNDOG      = input.bool(false, title='', inline='NDOG', group='NWOG/NDOG')
cNDOG1     = input.color(color.new(#ff9800, 20), title='NDOG    ', inline='NDOG', group='NWOG/NDOG')
cNDOG2     = input.color(color.new(#4dd0e1, 65), title='', inline='NDOG', group='NWOG/NDOG')
maxNDOG    = input.int(1, title='Show max', inline='NDOG', group='NWOG/NDOG', minval=0, maxval=50)

iFib       = input.string('NONE', title='Fibonacci between last: ', group='Fibonacci', options=['FVG', 'BPR', 'OB', 'Liq', 'VI', 'NWOG', 'NONE'])
iExt       = input.bool(false, title='Extend lines', group='Fibonacci')

//-----------------------------------------------------------------------------
// KILLZONES
//-----------------------------------------------------------------------------
showKZ     = input.bool(false, title='Show Killzones', group='Killzones')
showNyInp  = input.bool(true, title=ny_, inline='ny', group='Killzones')
nyCss      = input.color(color.new(#ff5d00, 93), title='', inline='ny', group='Killzones')
showLdnoInp = input.bool(true, title=lo_, inline='lo', group='Killzones')
ldnoCss    = input.color(color.new(#00bcd4, 93), title='', inline='lo', group='Killzones')
showLdncInp = input.bool(true, title=lc_, inline='lc', group='Killzones')
ldncCss    = input.color(color.new(#2157f3, 93), title='', inline='lc', group='Killzones')
showAsiaInp = input.bool(true, title=as_ + sp2, inline='as', group='Killzones')
asiaCss    = input.color(color.new(#e91e63, 93), title='', inline='as', group='Killzones')

//-----------------------------------------------------------------------------
// GENERAL
//-----------------------------------------------------------------------------
n        = bar_index
hi       = high
lo       = low
tf_msec  = timeframe.in_seconds(timeframe.period) * 1000
atr      = ta.atr(10)
atr14    = ta.atr(14)
per      = i_mode == 'Present' ? last_bar_index - bar_index <= 500 : true
mx       = math.max(close, open)
mn       = math.min(close, open)
body     = math.abs(close - open)
meanBody = ta.sma(body, len)
maxC     = useBody ? mx : high
minC     = useBody ? mn : low

//-----------------------------------------------------------------------------
// TYPES
//-----------------------------------------------------------------------------
type AMYZone
    box bx
    label lb
    line ln
    float top
    float btm
    int dir
    bool active

type AMYLineLabel
    line l1
    line l2
    label lb

type AMYOB
    box bx
    label lb
    line ln
    float top
    float btm
    int dir
    bool active
    bool breaker

type AMYIDM
    line ln
    label lb
    float price
    int dir
    bool triggered
    bool expired
    int idx

//-----------------------------------------------------------------------------
// HELPERS
//-----------------------------------------------------------------------------
amy_price(_x) =>
    na(_x) ? "-" : str.tostring(_x, format.mintick)

amy_min(_a, _b) =>
    na(_a) ? _b : na(_b) ? _a : math.min(_a, _b)

amy_max(_a, _b) =>
    na(_a) ? _b : na(_b) ? _a : math.max(_a, _b)

amy_delete_zone(AMYZone _z) =>
    if not na(_z.bx)
        box.delete(_z.bx)
    if not na(_z.lb)
        label.delete(_z.lb)
    if not na(_z.ln)
        line.delete(_z.ln)

amy_delete_ob(AMYOB _z) =>
    if not na(_z.bx)
        box.delete(_z.bx)
    if not na(_z.lb)
        label.delete(_z.lb)
    if not na(_z.ln)
        line.delete(_z.ln)

amy_delete_idm(AMYIDM _z) =>
    if not na(_z.ln)
        line.delete(_z.ln)
    if not na(_z.lb)
        label.delete(_z.lb)

amy_cap_lines(line[] _arr, int _max) =>
    while array.size(_arr) > _max
        line.delete(array.shift(_arr))

amy_cap_labels(label[] _arr, int _max) =>
    while array.size(_arr) > _max
        label.delete(array.shift(_arr))

//-----------------------------------------------------------------------------
// MARKET STRUCTURE — MAIN
//-----------------------------------------------------------------------------
var float msLastHigh = na
var float msLastLow = na
var int msLastHighBar = na
var int msLastLowBar = na
var int msDir = 0
var float msLastBullBreak = na
var float msLastBearBreak = na
var line[] msLines = array.new_line()
var label[] msLabels = array.new_label()

msPH = ta.pivothigh(hi, len, 1)
msPL = ta.pivotlow(lo, len, 1)

if not na(msPH)
    msLastHigh := msPH
    msLastHighBar := bar_index - 1

if not na(msPL)
    msLastLow := msPL
    msLastLowBar := bar_index - 1

bullBreakMS = showMS and per and not na(msLastHigh) and close > msLastHigh and (na(msLastBullBreak) or msLastHigh != msLastBullBreak)
bearBreakMS = showMS and per and not na(msLastLow) and close < msLastLow and (na(msLastBearBreak) or msLastLow != msLastBearBreak)

if bullBreakMS
    isMss = msDir < 1
    msDir := 1
    msLastBullBreak := msLastHigh
    if (isMss and iMSS) or (not isMss and iBOS)
        _col = isMss ? cMSSbl : cBOSbl
        _txt = isMss ? "MSS" : "BOS"
        _ln = line.new(msLastHighBar, msLastHigh, bar_index, msLastHigh, xloc=xloc.bar_index, extend=extend.none, color=_col, width=1)
        _lb = label.new(math.round(math.avg(msLastHighBar, bar_index)), msLastHigh, _txt, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(_col, 100), textcolor=_col, size=size.tiny)
        array.push(msLines, _ln)
        array.push(msLabels, _lb)

if bearBreakMS
    isMss = msDir > -1
    msDir := -1
    msLastBearBreak := msLastLow
    if (isMss and iMSS) or (not isMss and iBOS)
        _col = isMss ? cMSSbr : cBOSbr
        _txt = isMss ? "MSS" : "BOS"
        _ln = line.new(msLastLowBar, msLastLow, bar_index, msLastLow, xloc=xloc.bar_index, extend=extend.none, color=_col, width=1)
        _lb = label.new(math.round(math.avg(msLastLowBar, bar_index)), msLastLow, _txt, xloc=xloc.bar_index, style=label.style_label_up, color=color.new(_col, 100), textcolor=_col, size=size.tiny)
        array.push(msLines, _ln)
        array.push(msLabels, _lb)

amy_cap_lines(msLines, 200)
amy_cap_labels(msLabels, 200)

//-----------------------------------------------------------------------------
// DISPLACEMENT
//-----------------------------------------------------------------------------
L_body   = high - mx < body * 0.36 and mn - low < body * 0.36
L_bodyUP = body > meanBody and L_body and close > open
L_bodyDN = body > meanBody and L_body and close < open

plotshape(sDispl and per and L_bodyUP ? low : na, title='Displacement UP', style=shape.labelup, color=color.lime, location=location.belowbar, size=size.tiny)
plotshape(sDispl and per and L_bodyDN ? high : na, title='Displacement DN', style=shape.labeldown, color=color.red, location=location.abovebar, size=size.tiny)

//-----------------------------------------------------------------------------
// VOLUME IMBALANCE
//-----------------------------------------------------------------------------
var AMYLineLabel[] viList = array.new<AMYLineLabel>()

vImb_Bl = open > close[1] and high[1] > low and close > close[1] and open > open[1] and high[1] < mn
vImb_Br = open < close[1] and low[1] < high and close < close[1] and open < open[1] and low[1] > mx

if sVimbl and per
    if vImb_Bl
        _l1 = line.new(bar_index - 1, mx[1], bar_index + 3, mx[1], color=cVimbl)
        _l2 = line.new(bar_index, mn, bar_index + 3, mn, color=cVimbl)
        _lb = label.new(bar_index + 3, math.avg(mx[1], mn), "VI", color=color.new(color.white, 100), textcolor=cVimbl, style=label.style_label_left, size=size.tiny)
        array.unshift(viList, AMYLineLabel.new(_l1, _l2, _lb))
    if vImb_Br
        _l1 = line.new(bar_index - 1, mn[1], bar_index + 3, mn[1], color=cVimbl)
        _l2 = line.new(bar_index, mx, bar_index + 3, mx, color=cVimbl)
        _lb = label.new(bar_index + 3, math.avg(mn[1], mx), "VI", color=color.new(color.white, 100), textcolor=cVimbl, style=label.style_label_left, size=size.tiny)
        array.unshift(viList, AMYLineLabel.new(_l1, _l2, _lb))

while array.size(viList) > visVim
    _old = array.pop(viList)
    line.delete(_old.l1)
    line.delete(_old.l2)
    label.delete(_old.lb)

//-----------------------------------------------------------------------------
// FVG
//-----------------------------------------------------------------------------
var AMYZone[] fvgList = array.new<AMYZone>()

imbalanceUP = L_bodyUP[1] and (i_FVG == 'FVG' ? low > high[2] : low < high[2])
imbalanceDN = L_bodyDN[1] and (i_FVG == 'FVG' ? high < low[2] : high > low[2])

if shwFVG and per and imbalanceUP
    _top = i_FVG == 'FVG' ? low : high[2]
    _btm = i_FVG == 'FVG' ? high[2] : low
    _bx = box.new(bar_index - 2, _top, bar_index + 8, _btm, xloc=xloc.bar_index, bgcolor=color.new(cFVGbl, 90), border_color=color.new(cFVGbl, 65), text=i_FVG, text_color=color.new(cFVGbl, 50), text_size=size.small)
    array.unshift(fvgList, AMYZone.new(_bx, na, na, math.max(_top, _btm), math.min(_top, _btm), 1, true))

if shwFVG and per and imbalanceDN
    _top = i_FVG == 'FVG' ? low[2] : high
    _btm = i_FVG == 'FVG' ? high : low[2]
    _bx = box.new(bar_index - 2, _top, bar_index + 8, _btm, xloc=xloc.bar_index, bgcolor=color.new(cFVGbr, 90), border_color=color.new(cFVGbr, 65), text=i_FVG, text_color=color.new(cFVGbr, 50), text_size=size.small)
    array.unshift(fvgList, AMYZone.new(_bx, na, na, math.max(_top, _btm), math.min(_top, _btm), -1, true))

if array.size(fvgList) > 0
    for i = array.size(fvgList) - 1 to 0
        _z = array.get(fvgList, i)
        if _z.active
            box.set_right(_z.bx, bar_index + 8)
            if _z.dir == 1 and low < _z.top
                box.set_border_style(_z.bx, line.style_dashed)
            if _z.dir == 1 and low < _z.btm
                box.set_bgcolor(_z.bx, color.new(cFVGblBR, 95))
                box.set_border_style(_z.bx, line.style_dotted)
                box.set_right(_z.bx, bar_index)
                _z.active := false
                array.set(fvgList, i, _z)
            if _z.dir == -1 and high > _z.btm
                box.set_border_style(_z.bx, line.style_dashed)
            if _z.dir == -1 and high > _z.top
                box.set_bgcolor(_z.bx, color.new(cFVGbrBR, 95))
                box.set_border_style(_z.bx, line.style_dotted)
                box.set_right(_z.bx, bar_index)
                _z.active := false
                array.set(fvgList, i, _z)

while array.size(fvgList) > visBxs * 3
    _old = array.pop(fvgList)
    amy_delete_zone(_old)

//-----------------------------------------------------------------------------
// LIQUIDITY
//-----------------------------------------------------------------------------
var AMYZone[] liqList = array.new<AMYZone>()

liqPH = ta.pivothigh(high, length, length)
liqPL = ta.pivotlow(low, length, length)

var float lastLiqHigh = na
var int lastLiqHighBar = na
var float lastLiqLow = na
var int lastLiqLowBar = na

if showLq and per and not na(liqPH)
    _p = liqPH
    _b = bar_index - length
    if not na(lastLiqHigh) and math.abs(_p - lastLiqHigh) <= atr / a
        _top = math.max(_p, lastLiqHigh) + atr / a
        _btm = math.min(_p, lastLiqHigh) - atr / a
        _bx = box.new(lastLiqHighBar, _top, bar_index + 10, _btm, xloc=xloc.bar_index, bgcolor=color.new(cLIQ_B, 92), border_color=color.new(cLIQ_B, 70), text="Buyside liquidity", text_size=size.tiny, text_color=color.new(cLIQ_B, 20))
        _ln = line.new(lastLiqHighBar, lastLiqHigh, bar_index + 10, lastLiqHigh, color=color.new(cLIQ_B, 0), style=line.style_solid)
        array.unshift(liqList, AMYZone.new(_bx, na, _ln, _top, _btm, 1, true))
    lastLiqHigh := _p
    lastLiqHighBar := _b

if showLq and per and not na(liqPL)
    _p = liqPL
    _b = bar_index - length
    if not na(lastLiqLow) and math.abs(_p - lastLiqLow) <= atr / a
        _top = math.max(_p, lastLiqLow) + atr / a
        _btm = math.min(_p, lastLiqLow) - atr / a
        _bx = box.new(lastLiqLowBar, _top, bar_index + 10, _btm, xloc=xloc.bar_index, bgcolor=color.new(cLIQ_S, 92), border_color=color.new(cLIQ_S, 70), text="Sellside liquidity", text_size=size.tiny, text_color=color.new(cLIQ_S, 20))
        _ln = line.new(lastLiqLowBar, lastLiqLow, bar_index + 10, lastLiqLow, color=color.new(cLIQ_S, 0), style=line.style_solid)
        array.unshift(liqList, AMYZone.new(_bx, na, _ln, _top, _btm, -1, true))
    lastLiqLow := _p
    lastLiqLowBar := _b

if array.size(liqList) > 0
    for i = array.size(liqList) - 1 to 0
        _z = array.get(liqList, i)
        if _z.active
            box.set_right(_z.bx, bar_index + 3)
            if not na(_z.ln)
                line.set_x2(_z.ln, bar_index + 3)
            if _z.dir == 1 and close > _z.top
                _z.active := false
                box.set_right(_z.bx, bar_index)
                if not na(_z.ln)
                    line.delete(_z.ln)
                array.set(liqList, i, _z)
            if _z.dir == -1 and close < _z.btm
                _z.active := false
                box.set_right(_z.bx, bar_index)
                if not na(_z.ln)
                    line.delete(_z.ln)
                array.set(liqList, i, _z)

while array.size(liqList) > visLiq * 3
    _old = array.pop(liqList)
    amy_delete_zone(_old)

//-----------------------------------------------------------------------------
// ORDER BLOCKS
//-----------------------------------------------------------------------------
var AMYOB[] obList = array.new<AMYOB>()

if showOB and per and bullBreakMS
    float _top = na
    float _btm = na
    int _bar = na
    for j = 1 to length
        if na(_top) and close[j] < open[j]
            _top := useBody ? open[j] : high[j]
            _btm := low[j]
            _bar := bar_index - j
    if not na(_top)
        _bx = box.new(_bar, _top, bar_index + 20, _btm, xloc=xloc.bar_index, bgcolor=color.new(bullCss, 90), border_color=color.new(bullCss, 0))
        _ln = line.new(_bar, _btm, bar_index + 20, _btm, xloc=xloc.bar_index, color=bullCss, width=2)
        _lb = label.new(_bar, _btm, "+OB", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(bullCss, 100), textcolor=bullCss, size=size.small)
        array.unshift(obList, AMYOB.new(_bx, _lb, _ln, _top, _btm, 1, true, false))

if showOB and per and bearBreakMS
    float _top = na
    float _btm = na
    int _bar = na
    for j = 1 to length
        if na(_top) and close[j] > open[j]
            _top := high[j]
            _btm := useBody ? open[j] : low[j]
            _bar := bar_index - j
    if not na(_top)
        _bx = box.new(_bar, _top, bar_index + 20, _btm, xloc=xloc.bar_index, bgcolor=color.new(bearCss, 90), border_color=color.new(bearCss, 0))
        _ln = line.new(_bar, _top, bar_index + 20, _top, xloc=xloc.bar_index, color=bearCss, width=2)
        _lb = label.new(_bar, _top, "-OB", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(bearCss, 100), textcolor=bearCss, size=size.small)
        array.unshift(obList, AMYOB.new(_bx, _lb, _ln, _top, _btm, -1, true, false))

if array.size(obList) > 0
    for i = array.size(obList) - 1 to 0
        _oob = array.get(obList, i)
        if _oob.active
            box.set_right(_oob.bx, bar_index + 20)
            if not na(_oob.ln)
                line.set_x2(_oob.ln, bar_index + 20)
            if _oob.dir == 1 and close < _oob.btm
                _oob.active := false
                _oob.breaker := true
                box.set_bgcolor(_oob.bx, bullBrkCss)
                box.set_right(_oob.bx, bar_index)
                array.set(obList, i, _oob)
            if _oob.dir == -1 and close > _oob.top
                _oob.active := false
                _oob.breaker := true
                box.set_bgcolor(_oob.bx, bearBrkCss)
                box.set_right(_oob.bx, bar_index)
                array.set(obList, i, _oob)

while array.size(obList) > math.max(showBull + showBear, 1) * 8
    _old = array.pop(obList)
    amy_delete_ob(_old)

//-----------------------------------------------------------------------------
// NWOG / NDOG
//-----------------------------------------------------------------------------
var AMYZone[] nwogList = array.new<AMYZone>()
var AMYZone[] ndogList = array.new<AMYZone>()
var float friCp = na
var int friCi = na

if dayofweek == dayofweek.friday
    friCp := close
    friCi := bar_index

if ta.change(dayofweek) != 0
    if dayofweek == dayofweek.monday and iNWOG and not na(friCp)
        _top = math.max(friCp, open)
        _btm = math.min(friCp, open)
        _bx = box.new(friCi, _top, bar_index, _btm, xloc=xloc.bar_index, extend=extend.right, bgcolor=color.new(color.white, 100), border_color=cNWOG2)
        _ln = line.new(bar_index, math.avg(friCp, open), bar_index + 1, math.avg(friCp, open), xloc=xloc.bar_index, extend=extend.right, color=cNWOG1, style=line.style_dotted)
        array.unshift(nwogList, AMYZone.new(_bx, na, _ln, _top, _btm, 0, true))
    if iNDOG
        _top = math.max(close[1], open)
        _btm = math.min(close[1], open)
        _bx = box.new(bar_index - 1, _top, bar_index, _btm, xloc=xloc.bar_index, extend=extend.right, bgcolor=color.new(color.white, 100), border_color=cNDOG2)
        _ln = line.new(bar_index, math.avg(close[1], open), bar_index + 1, math.avg(close[1], open), xloc=xloc.bar_index, extend=extend.right, color=cNDOG1, style=line.style_dotted)
        array.unshift(ndogList, AMYZone.new(_bx, na, _ln, _top, _btm, 0, true))

while array.size(nwogList) > maxNWOG
    _old = array.pop(nwogList)
    amy_delete_zone(_old)

while array.size(ndogList) > maxNDOG
    _old = array.pop(ndogList)
    amy_delete_zone(_old)

//-----------------------------------------------------------------------------
// KILLZONE BACKGROUND
//-----------------------------------------------------------------------------
showNy   = showNyInp and showKZ
