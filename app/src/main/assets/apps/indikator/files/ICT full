alertcondition(amyEntryV3_newSignal and amyEntryV3_signalType == -1, title="AMY SELL ENTRY", message="AMY SELL ENTRY")
alertcondition(amyEntryV3_newSignal and amyEntryV3_signalType == 2, title="AMY PULLBACK BUY", message="AMY PULLBACK BUY")
alertcondition(amyEntryV3_newSignal and amyEntryV3_signalType == -2, title="AMY PULLBACK SELL", message="AMY PULLBACK SELL")
