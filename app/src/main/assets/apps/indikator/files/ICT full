amyEntryV3_ltfEngine(_swingLen, _dispMult, _rejectWickMult, _retestAtr, _validBars) =>
    var float _lastHigh = na
    var float _lastLow = na
    var float _bullBreakLevel = na
    var float _bearBreakLevel = na
    var int _bullAge = na
    var int _bearAge = na
    var bool _bullActive = false
    var bool _bearActive = false

    _ph = ta.pivothigh(high, _swingLen, _swingLen)
    _pl = ta.pivotlow(low, _swingLen, _swingLen)

    if not na(_ph)
        _lastHigh := _ph
    if not na(_pl)
        _lastLow := _pl

    _atr = ta.atr(14)
    _tol = _atr * _retestAtr
    _body = math.abs(close - open)
    _meanBody = ta.sma(math.abs(close - open), 20)
    _safeBody = math.max(_body, syminfo.mintick)
    _upperWick = high - math.max(open, close)
    _lowerWick = math.min(open, close) - low

    _bullDisp = close > open and _body > _meanBody * _dispMult and close > high[1]
    _bearDisp = close < open and _body > _meanBody * _dispMult and close < low[1]
    _bullBreak = not na(_lastHigh) and close > _lastHigh and close[1] <= _lastHigh and _bullDisp
    _bearBreak = not na(_lastLow) and close < _lastLow and close[1] >= _lastLow and _bearDisp

    if _bullBreak
        _bullBreakLevel := _lastHigh
        _bullAge := 0
        _bullActive := true
        _bearActive := false

    if _bearBreak
        _bearBreakLevel := _lastLow
        _bearAge := 0
        _bearActive := true
        _bullActive := false

    if _bullActive
        _bullAge := nz(_bullAge) + 1
        if close < _bullBreakLevel - _tol or _bullAge > _validBars
            _bullActive := false

    if _bearActive
        _bearAge := nz(_bearAge) + 1
        if close > _bearBreakLevel + _tol or _bearAge > _validBars
            _bearActive := false

    _bullRetest = _bullActive and _bullAge > 0 and low <= _bullBreakLevel + _tol and close >= _bullBreakLevel - _tol
    _bearRetest = _bearActive and _bearAge > 0 and high >= _bearBreakLevel - _tol and close <= _bearBreakLevel + _tol
    _bullReject = close > open and _lowerWick >= _safeBody * _rejectWickMult
    _bearReject = close < open and _upperWick >= _safeBody * _rejectWickMult
    _bullSignal = _bullRetest and _bullReject
    _bearSignal = _bearRetest and _bearReject

    _signalDir = _bullSignal and not _bearSignal ? 1 : _bearSignal and not _bullSignal ? -1 : 0
    _signalLevel = _signalDir == 1 ? _bullBreakLevel : _signalDir == -1 ? _bearBreakLevel : na
    _signalLow = _signalDir == 1 ? low : na
    _signalHigh = _signalDir == -1 ? high : na

    if _bullSignal
        _bullActive := false
    if _bearSignal
        _bearActive := false

    [_lastHigh, _lastLow, _signalDir, _signalLevel, _signalLow, _signalHigh, _bullBreak, _bearBreak, _bullActive, _bearActive, _bullReject, _bearReject, close]

[amyEntryV3_ltfHigh, amyEntryV3_ltfLow, amyEntryV3_ltfSignalDir, amyEntryV3_ltfSignalLevel, amyEntryV3_ltfSignalLow, amyEntryV3_ltfSignalHigh, amyEntryV3_ltfBullBreak, amyEntryV3_ltfBearBreak, amyEntryV3_ltfBullPending, amyEntryV3_ltfBearPending, amyEntryV3_ltfBullReject, amyEntryV3_ltfBearReject, amyEntryV3_ltfClose] = request.security(syminfo.tickerid, amyEntryV3_triggerTf, amyEntryV3_ltfEngine(amyEntryV3_swingLen, amyEntryV3_dispMult, amyEntryV3_rejectWickMult, amyEntryV3_retestAtr, amyEntryV3_validBars), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyEntryV3_contextOk = amyEntryV3_show and amyDashV2_biasDir != 0 and amyDashV2_invalidStatus != 2
amyEntryV3_atr14 = ta.atr(14)
amyEntryV3_body = math.abs(close - open)
amyEntryV3_safeBody = math.max(amyEntryV3_body, syminfo.mintick)
amyEntryV3_upperWick = high - math.max(open, close)
amyEntryV3_lowerWick = math.min(open, close) - low
amyEntryV3_bullRejectNow = close > open and amyEntryV3_lowerWick >= amyEntryV3_safeBody * amyEntryV3_rejectWickMult
amyEntryV3_bearRejectNow = close < open and amyEntryV3_upperWick >= amyEntryV3_safeBody * amyEntryV3_rejectWickMult

amyEntryV3_suppA = amyEntryV3_nearestBelow(close, amyDashV2_ssl, amyKeyV2_ssl, amyKeyV2_pdl, amyKeyV2_asiaLow, amyPivotV2_s1, amyPivotV2_s2, amyPivotV2_s3)
amyEntryV3_suppB = amyEntryV3_nearestBelow(close, amyPivotV2_s4, amyDashV2_rangeLow, amyDashV2_poiLow, amyKeyV2_midnightOpen, amyPivotV2_p, amyDashV2_eq, amyDashV2_invalidLevel)
amyEntryV3_support = na(amyEntryV3_suppA) ? amyEntryV3_suppB : na(amyEntryV3_suppB) ? amyEntryV3_suppA : math.max(amyEntryV3_suppA, amyEntryV3_suppB)

amyEntryV3_resA = amyEntryV3_nearestAbove(close, amyDashV2_bsl, amyKeyV2_bsl, amyKeyV2_pdh, amyKeyV2_asiaHigh, amyPivotV2_r1, amyPivotV2_r2, amyPivotV2_r3)
amyEntryV3_resB = amyEntryV3_nearestAbove(close, amyPivotV2_r4, amyDashV2_rangeHigh, amyDashV2_poiHigh, amyKeyV2_midnightOpen, amyPivotV2_p, amyDashV2_eq, amyDashV2_invalidLevel)
amyEntryV3_resistance = na(amyEntryV3_resA) ? amyEntryV3_resB : na(amyEntryV3_resB) ? amyEntryV3_resA : math.min(amyEntryV3_resA, amyEntryV3_resB)

amyEntryV3_dashRangeHigh = not na(amyDashV2_rangeHigh) and not na(amyDashV2_rangeLow) ? math.max(amyDashV2_rangeHigh, amyDashV2_rangeLow) : na
amyEntryV3_dashRangeLow = not na(amyDashV2_rangeHigh) and not na(amyDashV2_rangeLow) ? math.min(amyDashV2_rangeHigh, amyDashV2_rangeLow) : na
amyEntryV3_autoRangeHigh = not na(amyEntryV3_dashRangeHigh) ? amyEntryV3_dashRangeHigh : amyEntryV3_resistance
amyEntryV3_autoRangeLow = not na(amyEntryV3_dashRangeLow) ? amyEntryV3_dashRangeLow : amyEntryV3_support
amyEntryV3_autoRangeSize = not na(amyEntryV3_autoRangeHigh) and not na(amyEntryV3_autoRangeLow) ? math.max(amyEntryV3_autoRangeHigh - amyEntryV3_autoRangeLow, syminfo.mintick) : na
amyEntryV3_fibA = math.min(amyEntryV3_fibShallow, amyEntryV3_fibDeep)
amyEntryV3_fibB = math.max(amyEntryV3_fibShallow, amyEntryV3_fibDeep)

amyEntryV3_buyFibHigh = not na(amyEntryV3_autoRangeSize) ? amyEntryV3_autoRangeHigh - amyEntryV3_autoRangeSize * amyEntryV3_fibA : na
amyEntryV3_buyFibLow = not na(amyEntryV3_autoRangeSize) ? amyEntryV3_autoRangeHigh - amyEntryV3_autoRangeSize * amyEntryV3_fibB : na
amyEntryV3_sellFibLow = not na(amyEntryV3_autoRangeSize) ? amyEntryV3_autoRangeLow + amyEntryV3_autoRangeSize * amyEntryV3_fibA : na
amyEntryV3_sellFibHigh = not na(amyEntryV3_autoRangeSize) ? amyEntryV3_autoRangeLow + amyEntryV3_autoRangeSize * amyEntryV3_fibB : na
amyEntryV3_zoneTol = amyEntryV3_atr14 * amyEntryV3_zoneAtr
amyEntryV3_chaseTol = amyEntryV3_atr14 * amyEntryV3_maxChaseAtr

amyEntryV3_inBuyFibZone = not na(amyEntryV3_buyFibHigh) and not na(amyEntryV3_buyFibLow) and close >= amyEntryV3_buyFibLow - amyEntryV3_zoneTol and close <= amyEntryV3_buyFibHigh + amyEntryV3_zoneTol and low <= amyEntryV3_buyFibHigh + amyEntryV3_zoneTol and high >= amyEntryV3_buyFibLow - amyEntryV3_zoneTol
amyEntryV3_inSellFibZone = not na(amyEntryV3_sellFibHigh) and not na(amyEntryV3_sellFibLow) and close >= amyEntryV3_sellFibLow - amyEntryV3_zoneTol and close <= amyEntryV3_sellFibHigh + amyEntryV3_zoneTol and high >= amyEntryV3_sellFibLow - amyEntryV3_zoneTol and low <= amyEntryV3_sellFibHigh + amyEntryV3_zoneTol
amyEntryV3_nearSupport = not na(amyEntryV3_support) and low <= amyEntryV3_support + amyEntryV3_zoneTol and close >= amyEntryV3_support - amyEntryV3_zoneTol and close <= amyEntryV3_support + amyEntryV3_chaseTol
amyEntryV3_nearResistance = not na(amyEntryV3_resistance) and high >= amyEntryV3_resistance - amyEntryV3_zoneTol and close <= amyEntryV3_resistance + amyEntryV3_zoneTol and close >= amyEntryV3_resistance - amyEntryV3_chaseTol

amyEntryV3_inPoi = not na(amyDashV2_poiHigh) and not na(amyDashV2_poiLow) and high >= amyDashV2_poiLow and low <= amyDashV2_poiHigh
amyEntryV3_touchBullPoi = amyEntryV3_inPoi and amyDashV2_poiType > 0
amyEntryV3_touchBearPoi = amyEntryV3_inPoi and amyDashV2_poiType < 0
amyEntryV3_sslReject = not na(amyDashV2_ssl) and low <= amyDashV2_ssl and close > amyDashV2_ssl
amyEntryV3_bslReject = not na(amyDashV2_bsl) and high >= amyDashV2_bsl and close < amyDashV2_bsl
amyEntryV3_asiaLowReject = not na(amyKeyV2_asiaLow) and low <= amyKeyV2_asiaLow and close > amyKeyV2_asiaLow
amyEntryV3_asiaHighReject = not na(amyKeyV2_asiaHigh) and high >= amyKeyV2_asiaHigh and close < amyKeyV2_asiaHigh

amyEntryV3_breakBuy = amyEntryV3_ltfSignalDir == 1
amyEntryV3_breakSell = amyEntryV3_ltfSignalDir == -1
amyEntryV3_breakBuyFresh = amyEntryV3_breakBuy and not na(amyEntryV3_ltfSignalLevel) and close >= amyEntryV3_ltfSignalLevel - amyEntryV3_zoneTol and close <= amyEntryV3_ltfSignalLevel + amyEntryV3_chaseTol
amyEntryV3_breakSellFresh = amyEntryV3_breakSell and not na(amyEntryV3_ltfSignalLevel) and close <= amyEntryV3_ltfSignalLevel + amyEntryV3_zoneTol and close >= amyEntryV3_ltfSignalLevel - amyEntryV3_chaseTol

amyEntryV3_mathBuyZone = not amyEntryV3_useMathZones or amyEntryV3_inBuyFibZone or amyEntryV3_nearSupport or amyEntryV3_touchBullPoi or amyEntryV3_sslReject or amyEntryV3_asiaLowReject or amyEntryV3_breakBuyFresh
amyEntryV3_mathSellZone = not amyEntryV3_useMathZones or amyEntryV3_inSellFibZone or amyEntryV3_nearResistance or amyEntryV3_touchBearPoi or amyEntryV3_bslReject or amyEntryV3_asiaHighReject or amyEntryV3_breakSellFresh

amyEntryV3_baseTrendBuyZone = amyDashV2_priceZone == -1 or amyEntryV3_touchBullPoi or amyEntryV3_sslReject or amyEntryV3_asiaLowReject or amyEntryV3_inBuyFibZone or amyEntryV3_nearSupport
amyEntryV3_baseTrendSellZone = amyDashV2_priceZone == 1 or amyEntryV3_touchBearPoi or amyEntryV3_bslReject or amyEntryV3_asiaHighReject or amyEntryV3_inSellFibZone or amyEntryV3_nearResistance
amyEntryV3_basePullbackSellZone = amyDashV2_priceZone == 1 or amyEntryV3_bslReject or amyEntryV3_asiaHighReject or amyDashV2_dolStatus == 2 or amyEntryV3_inSellFibZone or amyEntryV3_nearResistance
amyEntryV3_basePullbackBuyZone = amyDashV2_priceZone == -1 or amyEntryV3_sslReject or amyEntryV3_asiaLowReject or amyDashV2_dolStatus == 2 or amyEntryV3_inBuyFibZone or amyEntryV3_nearSupport

amyEntryV3_trendBuyZone = amyEntryV3_baseTrendBuyZone and amyEntryV3_mathBuyZone
amyEntryV3_trendSellZone = amyEntryV3_baseTrendSellZone and amyEntryV3_mathSellZone
amyEntryV3_pullbackSellZone = amyEntryV3_basePullbackSellZone and amyEntryV3_mathSellZone
amyEntryV3_pullbackBuyZone = amyEntryV3_basePullbackBuyZone and amyEntryV3_mathBuyZone

amyEntryV3_trendBuyBreak = amyEntryV3_contextOk and amyDashV2_biasDir == 1 and amyEntryV3_trendBuyZone and amyEntryV3_breakBuy and (not amyEntryV3_useMathZones or amyEntryV3_breakBuyFresh)
amyEntryV3_trendSellBreak = amyEntryV3_contextOk and amyDashV2_biasDir == -1 and amyEntryV3_trendSellZone and amyEntryV3_breakSell and (not amyEntryV3_useMathZones or amyEntryV3_breakSellFresh)
amyEntryV3_pullbackSellBreak = amyEntryV3_contextOk and amyDashV2_biasDir == 1 and amyEntryV3_pullbackSellZone and amyEntryV3_breakSell and (not amyEntryV3_useMathZones or amyEntryV3_breakSellFresh)
amyEntryV3_pullbackBuyBreak = amyEntryV3_contextOk and amyDashV2_biasDir == -1 and amyEntryV3_pullbackBuyZone and amyEntryV3_breakBuy and (not amyEntryV3_useMathZones or amyEntryV3_breakBuyFresh)

amyEntryV3_trendBuyReject = amyEntryV3_contextOk and amyDashV2_biasDir == 1 and amyEntryV3_trendBuyZone and amyEntryV3_bullRejectNow
amyEntryV3_trendSellReject = amyEntryV3_contextOk and amyDashV2_biasDir == -1 and amyEntryV3_trendSellZone and amyEntryV3_bearRejectNow
amyEntryV3_pullbackSellReject = amyEntryV3_contextOk and amyDashV2_biasDir == 1 and amyEntryV3_pullbackSellZone and amyEntryV3_bearRejectNow
amyEntryV3_pullbackBuyReject = amyEntryV3_contextOk and amyDashV2_biasDir == -1 and amyEntryV3_pullbackBuyZone and amyEntryV3_bullRejectNow

amyEntryV3_rawSignalType = amyEntryV3_pullbackSellBreak or amyEntryV3_pullbackSellReject ? -2 :
 amyEntryV3_pullbackBuyBreak or amyEntryV3_pullbackBuyReject ? 2 :
 amyEntryV3_trendBuyBreak or amyEntryV3_trendBuyReject ? 1 :
 amyEntryV3_trendSellBreak or amyEntryV3_trendSellReject ? -1 : 0

amyEntryV3_rawSignalDir = amyEntryV3_rawSignalType == 1 or amyEntryV3_rawSignalType == 2 ? 1 : amyEntryV3_rawSignalType == -1 or amyEntryV3_rawSignalType == -2 ? -1 : 0
amyEntryV3_rawSignalIsBreak = amyEntryV3_rawSignalType == 1 ? amyEntryV3_trendBuyBreak :
 amyEntryV3_rawSignalType == -1 ? amyEntryV3_trendSellBreak :
 amyEntryV3_rawSignalType == -2 ? amyEntryV3_pullbackSellBreak :
 amyEntryV3_rawSignalType == 2 ? amyEntryV3_pullbackBuyBreak : false

amyEntryV3_buyZoneEntry = amyEntryV3_inBuyFibZone and not na(amyEntryV3_buyFibLow) and not na(amyEntryV3_buyFibHigh) ? math.max(amyEntryV3_buyFibLow, math.min(close, amyEntryV3_buyFibHigh)) : amyEntryV3_nearSupport ? amyEntryV3_support : close
amyEntryV3_sellZoneEntry = amyEntryV3_inSellFibZone and not na(amyEntryV3_sellFibLow) and not na(amyEntryV3_sellFibHigh) ? math.min(amyEntryV3_sellFibHigh, math.max(close, amyEntryV3_sellFibLow)) : amyEntryV3_nearResistance ? amyEntryV3_resistance : close
amyEntryV3_rawEntryCandidate = amyEntryV3_rawSignalIsBreak and not na(amyEntryV3_ltfSignalLevel) ? amyEntryV3_ltfSignalLevel : amyEntryV3_rawSignalDir == 1 ? amyEntryV3_buyZoneEntry : amyEntryV3_rawSignalDir == -1 ? amyEntryV3_sellZoneEntry : na

amyEntryV3_buyFresh = amyEntryV3_rawSignalDir == 1 and not na(amyEntryV3_rawEntryCandidate) and close >= amyEntryV3_rawEntryCandidate - amyEntryV3_zoneTol and close <= amyEntryV3_rawEntryCandidate + amyEntryV3_chaseTol
amyEntryV3_sellFresh = amyEntryV3_rawSignalDir == -1 and not na(amyEntryV3_rawEntryCandidate) and close <= amyEntryV3_rawEntryCandidate + amyEntryV3_zoneTol and close >= amyEntryV3_rawEntryCandidate - amyEntryV3_chaseTol
amyEntryV3_entryFresh = not amyEntryV3_useMathZones or amyEntryV3_rawSignalType == 0 ? true : amyEntryV3_rawSignalDir == 1 ? amyEntryV3_buyFresh : amyEntryV3_rawSignalDir == -1 ? amyEntryV3_sellFresh : false

amyEntryV3_signalTypeRaw = amyEntryV3_rawSignalType != 0 and amyEntryV3_entryFresh ? amyEntryV3_rawSignalType : 0

var int amyEntryV3_lastSigBar = na
var int amyEntryV3_lastSigTypeConfirm = 0

amyEntryV3_newSignal = amyEntryV3_signalTypeRaw != 0 and barstate.isconfirmed and (na(amyEntryV3_lastSigBar) or bar_index - amyEntryV3_lastSigBar >= amyEntryV3_cooldown or amyEntryV3_signalTypeRaw != amyEntryV3_lastSigTypeConfirm)

amyEntryV3_signalType = amyEntryV3_newSignal ? amyEntryV3_signalTypeRaw : 0
amyEntryV3_signalDir = amyEntryV3_signalType == 1 or amyEntryV3_signalType == 2 ? 1 : amyEntryV3_signalType == -1 or amyEntryV3_signalType == -2 ? -1 : 0
amyEntryV3_signalIsBreak = amyEntryV3_signalType == 1 ? amyEntryV3_trendBuyBreak :
 amyEntryV3_signalType == -1 ? amyEntryV3_trendSellBreak :
 amyEntryV3_signalType == -2 ? amyEntryV3_pullbackSellBreak :
 amyEntryV3_signalType == 2 ? amyEntryV3_pullbackBuyBreak : false

if amyEntryV3_newSignal
    amyEntryV3_lastSigBar := bar_index
    amyEntryV3_lastSigTypeConfirm := amyEntryV3_signalTypeRaw

amyEntryV3_entryCandidate = amyEntryV3_rawEntryCandidate

amyEntryV3_buyBaseSl = amy_min(low, amyEntryV3_ltfLow)
amyEntryV3_buyBaseSl := amyEntryV3_signalDir == 1 ? amy_min(amyEntryV3_buyBaseSl, amyDashV2_poiLow) : amyEntryV3_buyBaseSl
amyEntryV3_buyBaseSl := amyEntryV3_signalDir == 1 ? amy_min(amyEntryV3_buyBaseSl, amyEntryV3_support) : amyEntryV3_buyBaseSl
amyEntryV3_buyBaseSl := amyEntryV3_signalDir == 1 ? amy_min(amyEntryV3_buyBaseSl, amyEntryV3_autoRangeLow) : amyEntryV3_buyBaseSl

amyEntryV3_sellBaseSl = amy_max(high, amyEntryV3_ltfHigh)
amyEntryV3_sellBaseSl := amyEntryV3_signalDir == -1 ? amy_max(amyEntryV3_sellBaseSl, amyDashV2_poiHigh) : amyEntryV3_sellBaseSl
amyEntryV3_sellBaseSl := amyEntryV3_signalDir == -1 ? amy_max(amyEntryV3_sellBaseSl, amyEntryV3_resistance) : amyEntryV3_sellBaseSl
amyEntryV3_sellBaseSl := amyEntryV3_signalDir == -1 ? amy_max(amyEntryV3_sellBaseSl, amyEntryV3_autoRangeHigh) : amyEntryV3_sellBaseSl

amyEntryV3_slCandidate = amyEntryV3_signalDir == 1 ? amyEntryV3_buyBaseSl - amyEntryV3_atr14 * amyEntryV3_slBufferAtr : amyEntryV3_signalDir == -1 ? amyEntryV3_sellBaseSl + amyEntryV3_atr14 * amyEntryV3_slBufferAtr : na
amyEntryV3_riskCandidate = not na(amyEntryV3_entryCandidate) and not na(amyEntryV3_slCandidate) ? math.abs(amyEntryV3_entryCandidate - amyEntryV3_slCandidate) : na

amyEntryV3_buyTp1Raw = amyEntryV3_nearestAbove(amyEntryV3_entryCandidate, amyDashV2_dolDir == 1 ? amyDashV2_dolTarget : na, amyEntryV3_resistance, amyEntryV3_autoRangeHigh, amyDashV2_bsl, amyKeyV2_pdh, amyPivotV2_r1, amyDashV2_eq)
amyEntryV3_buyTp2Raw = amyEntryV3_nearestAbove(nz(amyEntryV3_buyTp1Raw, amyEntryV3_entryCandidate), amyDashV2_dolDir == 1 ? amyDashV2_dolTarget : na, amyEntryV3_resistance, amyKeyV2_pdh, amyKeyV2_asiaHigh, amyPivotV2_r2, amyPivotV2_r3, amyPivotV2_r4)
amyEntryV3_sellTp1Raw = amyEntryV3_nearestBelow(amyEntryV3_entryCandidate, amyDashV2_dolDir == -1 ? amyDashV2_dolTarget : na, amyEntryV3_support, amyEntryV3_autoRangeLow, amyDashV2_ssl, amyKeyV2_pdl, amyPivotV2_s1, amyDashV2_eq)
amyEntryV3_sellTp2Raw = amyEntryV3_nearestBelow(nz(amyEntryV3_sellTp1Raw, amyEntryV3_entryCandidate), amyDashV2_dolDir == -1 ? amyDashV2_dolTarget : na, amyEntryV3_support, amyKeyV2_pdl, amyKeyV2_asiaLow, amyPivotV2_s2, amyPivotV2_s3, amyPivotV2_s4)

amyEntryV3_tp1Candidate = amyEntryV3_signalDir == 1 ? (na(amyEntryV3_buyTp1Raw) ? amyEntryV3_entryCandidate + amyEntryV3_riskCandidate * amyEntryV3_tp1R : amyEntryV3_buyTp1Raw) : amyEntryV3_signalDir == -1 ? (na(amyEntryV3_sellTp1Raw) ? amyEntryV3_entryCandidate - amyEntryV3_riskCandidate * amyEntryV3_tp1R : amyEntryV3_sellTp1Raw) : na
amyEntryV3_tp2Candidate = amyEntryV3_signalDir == 1 ? (na(amyEntryV3_buyTp2Raw) ? amyEntryV3_entryCandidate + amyEntryV3_riskCandidate * amyEntryV3_tp2R : amyEntryV3_buyTp2Raw) : amyEntryV3_signalDir == -1 ? (na(amyEntryV3_sellTp2Raw) ? amyEntryV3_entryCandidate - amyEntryV3_riskCandidate * amyEntryV3_tp2R : amyEntryV3_sellTp2Raw) : na

amyEntryV3_zoneText = "NO ENTRY"
if amyEntryV3_signalDir == 1
    amyEntryV3_zoneText := amyEntryV3_inBuyFibZone ? "Fibo discount zone" : amyEntryV3_nearSupport ? "SNR support zone" : amyEntryV3_touchBullPoi ? "Bullish POI zone" : amyEntryV3_sslReject ? "SSL reject zone" : amyEntryV3_asiaLowReject ? "Asia Low reject zone" : amyEntryV3_breakBuyFresh ? "Break-retest zone" : "Math zone"
else if amyEntryV3_signalDir == -1
    amyEntryV3_zoneText := amyEntryV3_inSellFibZone ? "Fibo premium zone" : amyEntryV3_nearResistance ? "SNR resistance zone" : amyEntryV3_touchBearPoi ? "Bearish POI zone" : amyEntryV3_bslReject ? "BSL reject zone" : amyEntryV3_asiaHighReject ? "Asia High reject zone" : amyEntryV3_breakSellFresh ? "Break-retest zone" : "Math zone"

amyEntryV3_reason = ""
amyEntryV3_reason := amyEntryV3_addLine(amyEntryV3_reason, "Bias utama: " + amyEntryV3_biasName(amyDashV2_biasDir))
amyEntryV3_reason := amyEntryV3_addLine(amyEntryV3_reason, amyEntryV3_signalIsBreak ? "Pemicu: Break + Retest + Rejection" : amyEntryV3_signalType != 0 ? "Pemicu: Rejection area" : "Status: No entry")
amyEntryV3_reason := amyEntryV3_addLine(amyEntryV3_reason, "Math zone: " + amyEntryV3_zoneText)
amyEntryV3_reason := amyEntryV3_addLine(amyEntryV3_reason, amyDashV2_priceZone == 1 ? "Lokasi: Premium" : amyDashV2_priceZone == -1 ? "Lokasi: Discount" : "Lokasi: EQ Zone")
amyEntryV3_reason := amyEntryV3_signalType == -2 ? amyEntryV3_addLine(amyEntryV3_reason, "Catatan: sell ini pullback, bukan ubah bias utama") : amyEntryV3_reason
amyEntryV3_reason := amyEntryV3_signalType == 2 ? amyEntryV3_addLine(amyEntryV3_reason, "Catatan: buy ini pullback, bukan ubah bias utama") : amyEntryV3_reason
amyEntryV3_reason := amyEntryV3_touchBullPoi or amyEntryV3_touchBearPoi ? amyEntryV3_addLine(amyEntryV3_reason, "POI tersentuh: " + amyDashV2_poiTypeText) : amyEntryV3_reason
amyEntryV3_reason := amyEntryV3_sslReject ? amyEntryV3_addLine(amyEntryV3_reason, "SSL reject") : amyEntryV3_reason
amyEntryV3_reason := amyEntryV3_bslReject ? amyEntryV3_addLine(amyEntryV3_reason, "BSL reject") : amyEntryV3_reason

var float amyEntryV3_lastEntry = na
var float amyEntryV3_lastSl = na
var float amyEntryV3_lastTp1 = na
var float amyEntryV3_lastTp2 = na
var int amyEntryV3_lastType = 0
var int amyEntryV3_lastDir = 0
var string amyEntryV3_lastReason = "Belum ada entry valid"
var int amyEntryV3_lastBar = na

var line amyEntryV3_entryLine = na
var line amyEntryV3_slLine = na
var line amyEntryV3_tp1Line = na
var line amyEntryV3_tp2Line = na
var label amyEntryV3_entryLabel = na
var label amyEntryV3_slLabel = na
var label amyEntryV3_tp1Label = na
var label amyEntryV3_tp2Label = na
var label amyEntryV3_reasonLabel = na

if amyEntryV3_newSignal and not na(amyEntryV3_riskCandidate) and amyEntryV3_riskCandidate > syminfo.mintick
    amyEntryV3_lastEntry := amyEntryV3_entryCandidate
    amyEntryV3_lastSl := amyEntryV3_slCandidate
    amyEntryV3_lastTp1 := amyEntryV3_tp1Candidate
    amyEntryV3_lastTp2 := amyEntryV3_tp2Candidate
    amyEntryV3_lastType := amyEntryV3_signalType
    amyEntryV3_lastDir := amyEntryV3_signalDir
    amyEntryV3_lastReason := amyEntryV3_reason
    amyEntryV3_lastBar := bar_index

    if not na(amyEntryV3_entryLine)
        line.delete(amyEntryV3_entryLine)
    if not na(amyEntryV3_slLine)
        line.delete(amyEntryV3_slLine)
    if not na(amyEntryV3_tp1Line)
        line.delete(amyEntryV3_tp1Line)
    if not na(amyEntryV3_tp2Line)
        line.delete(amyEntryV3_tp2Line)
    if not na(amyEntryV3_entryLabel)
        label.delete(amyEntryV3_entryLabel)
    if not na(amyEntryV3_slLabel)
        label.delete(amyEntryV3_slLabel)
    if not na(amyEntryV3_tp1Label)
        label.delete(amyEntryV3_tp1Label)
    if not na(amyEntryV3_tp2Label)
        label.delete(amyEntryV3_tp2Label)

    _planColor = amyEntryV3_signalColor(amyEntryV3_signalType)
    _right = bar_index + amyEntryV3_extendBars

    amyEntryV3_entryLine := line.new(bar_index, amyEntryV3_lastEntry, _right, amyEntryV3_lastEntry, xloc=xloc.bar_index, extend=extend.none, color=_planColor, width=2)
    amyEntryV3_slLine := line.new(bar_index, amyEntryV3_lastSl, _right, amyEntryV3_lastSl, xloc=xloc.bar_index, extend=extend.none, color=color.new(#ff1744, 0), width=2)
    amyEntryV3_tp1Line := line.new(bar_index, amyEntryV3_lastTp1, _right, amyEntryV3_lastTp1, xloc=xloc.bar_index, extend=extend.none, color=color.new(#ffd600, 0), width=1)
    amyEntryV3_tp2Line := line.new(bar_index, amyEntryV3_lastTp2, _right, amyEntryV3_lastTp2, xloc=xloc.bar_index, extend=extend.none, color=color.new(#00e676, 0), width=1)

    amyEntryV3_entryLabel := label.new(_right, amyEntryV3_lastEntry, amyEntryV3_signalName(amyEntryV3_lastType) + "\nENTRY " + amy_price(amyEntryV3_lastEntry), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(_planColor, 8), textcolor=color.white, size=size.small)
    amyEntryV3_slLabel := label.new(_right, amyEntryV3_lastSl, "SL " + amy_price(amyEntryV3_lastSl), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(#ff1744, 8), textcolor=color.white, size=size.small)
    amyEntryV3_tp1Label := label.new(_right, amyEntryV3_lastTp1, "TP1 " + amy_price(amyEntryV3_lastTp1), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(#ffd600, 15), textcolor=color.black, size=size.small)
    amyEntryV3_tp2Label := label.new(_right, amyEntryV3_lastTp2, "TP2 " + amy_price(amyEntryV3_lastTp2), xloc=xloc.bar_index, style=label.style_label_left, color=color.new(#00e676, 10), textcolor=color.black, size=size.small)

if barstate.islast
    if amyEntryV3_show and amyEntryV3_showChartPlans and not na(amyEntryV3_entryLine)
        _rightLive = bar_index + amyEntryV3_extendBars
        line.set_x2(amyEntryV3_entryLine, _rightLive)
        line.set_x2(amyEntryV3_slLine, _rightLive)
        line.set_x2(amyEntryV3_tp1Line, _rightLive)
        line.set_x2(amyEntryV3_tp2Line, _rightLive)
        label.set_x(amyEntryV3_entryLabel, _rightLive)
        label.set_x(amyEntryV3_slLabel, _rightLive)
        label.set_x(amyEntryV3_tp1Label, _rightLive)
        label.set_x(amyEntryV3_tp2Label, _rightLive)

amyEntryV3_planText = amyEntryV3_signalName(amyEntryV3_lastType) + "\nENTRY " + amy_price(amyEntryV3_lastEntry) + " | SL " + amy_price(amyEntryV3_lastSl) + "\nTP1 " + amy_price(amyEntryV3_lastTp1) + " | TP2 " + amy_price(amyEntryV3_lastTp2) + "\n" + amyEntryV3_lastReason
amyEntryV3_reasonY = amyEntryV3_lastDir == 1 ? low - amyEntryV3_atr14 * amyEntryV3_noteOffsetAtr : high + amyEntryV3_atr14 * amyEntryV3_noteOffsetAtr
amyEntryV3_reasonStyle = amyEntryV3_lastDir == 1 ? label.style_label_up : label.style_label_down

if barstate.islast
    if amyEntryV3_show and amyEntryV3_showReasonLabel and amyEntryV3_lastType != 0
        if na(amyEntryV3_reasonLabel)
            amyEntryV3_reasonLabel := label.new(bar_index, amyEntryV3_reasonY, amyEntryV3_planText, xloc=xloc.bar_index, style=amyEntryV3_reasonStyle, color=color.new(amyEntryV3_signalColor(amyEntryV3_lastType), 10), textcolor=color.white, size=size.tiny)
        else
            label.set_xy(amyEntryV3_reasonLabel, bar_index, amyEntryV3_reasonY)
            label.set_text(amyEntryV3_reasonLabel, amyEntryV3_planText)
            label.set_style(amyEntryV3_reasonLabel, amyEntryV3_reasonStyle)
            label.set_color(amyEntryV3_reasonLabel, color.new(amyEntryV3_signalColor(amyEntryV3_lastType), 10))
            label.set_textcolor(amyEntryV3_reasonLabel, color.white)
            label.set_size(amyEntryV3_reasonLabel, size.tiny)
    else
        if not na(amyEntryV3_reasonLabel)
            label.delete(amyEntryV3_reasonLabel)
            amyEntryV3_reasonLabel := na

plotshape(amyEntryV3_newSignal and amyEntryV3_signalType == 1, title="BUY Entry", text="BUY", style=shape.labelup, location=location.belowbar, color=color.new(#00c853, 0), textcolor=color.white, size=size.small)
plotshape(amyEntryV3_newSignal and amyEntryV3_signalType == -1, title="SELL Entry", text="SELL", style=shape.labeldown, location=location.abovebar, color=color.new(#d50000, 0), textcolor=color.white, size=size.small)
plotshape(amyEntryV3_newSignal and amyEntryV3_signalType == -2, title="Pullback Sell", text="PB SELL", style=shape.labeldown, location=location.abovebar, color=color.new(#ff6d00, 0), textcolor=color.white, size=size.small)
plotshape(amyEntryV3_newSignal and amyEntryV3_signalType == 2, title="Pullback Buy", text="PB BUY", style=shape.labelup, location=location.belowbar, color=color.new(#00b0ff, 0), textcolor=color.white, size=size.small)

