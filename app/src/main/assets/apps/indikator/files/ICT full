amyDashV2_group = "AMY Dashboard Bias V2"
amyDashV2_show = input.bool(true, "Show Dashboard", group=amyDashV2_group)
amyDashV2_showZones = input.bool(true, "Show Premium / Discount UI", group=amyDashV2_group)
amyDashV2_posInput = input.string("Bottom Right", "Dashboard Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=amyDashV2_group)
amyDashV2_swingLen = input.int(3, "M15 Protected Swing Length", minval=2, maxval=10, group=amyDashV2_group)
amyDashV2_sweepFreshBars = input.int(8, "Sweep Fresh Bars", minval=3, maxval=30, group=amyDashV2_group)
amyDashV2_nearInvalidAtr = input.float(0.35, "Near Invalid ATR", minval=0.05, maxval=2.0, step=0.05, group=amyDashV2_group)
amyDashV2_dispMult = input.float(1.20, "Displacement Body Mult", minval=0.80, maxval=3.0, step=0.05, group=amyDashV2_group)
amyDashV2_minSweepTicks = input.int(1, "False Sweep Filter Ticks", minval=0, maxval=20, group=amyDashV2_group)

amyDashV2_pos(_pos) =>
    _pos == "Top Left" ? position.top_left :
     _pos == "Bottom Right" ? position.bottom_right :
     _pos == "Bottom Left" ? position.bottom_left :
     position.top_right

amyDashV2_range(_a, _b) =>
    na(_a) or na(_b) ? "-" : amy_price(math.max(_a, _b)) + " - " + amy_price(math.min(_a, _b))

amyDashV2_dist(_price, _current) =>
    na(_price) or na(_current) ? "-" : amy_price(math.abs(_current - _price))

amyDashV2_join(_a, _b) =>
    _a == "" ? _b : _b == "" ? _a : _a + " | " + _b

amyDashV2_clip(_s, _max) =>
    str.length(_s) > _max ? str.substring(_s, 0, _max) + "..." : _s

amyDashV2_engine(_swingLen, _freshBars, _nearAtr, _dispMult, _minSweepTicks) =>
    var float _lastPH = na
    var float _lastPL = na
    var int _biasDir = 0
    var int _mssDir = 0
    var float _lockedInvalid = na
    var float _rangeHigh = na
    var float _rangeLow = na
    var int _lastSweepDir = 0
    var int _lastSweepBar = na
    var float _sweptPrice = na
    var float _sweepExtreme = na
    var float _bullFvgTop = na
    var float _bullFvgBtm = na
    var int _bullFvgStatus = 0
    var float _bearFvgTop = na
    var float _bearFvgBtm = na
    var int _bearFvgStatus = 0
    var float _bullObTop = na
    var float _bullObBtm = na
    var int _bullObStatus = 0
    var float _bearObTop = na
    var float _bearObBtm = na
    var int _bearObStatus = 0

    _atr = ta.atr(14)
    _body = math.abs(close - open)
    _meanBody = ta.sma(math.abs(close - open), 20)

    _ph = ta.pivothigh(high, _swingLen, _swingLen)
    _pl = ta.pivotlow(low, _swingLen, _swingLen)

    if not na(_ph)
        _lastPH := _ph
    if not na(_pl)
        _lastPL := _pl

    _bullMss = not na(_lastPH) and close > _lastPH and close[1] <= _lastPH
    _bearMss = not na(_lastPL) and close < _lastPL and close[1] >= _lastPL

    _invalidNow = false
    _biasChanged = false

    if _biasDir == 1 and not na(_lockedInvalid) and close < _lockedInvalid
        _invalidNow := true
        if _bearMss
            _biasDir := -1
            _mssDir := -1
            _lockedInvalid := _lastPH
            _rangeHigh := _lastPH
            _rangeLow := math.min(_lastPL, low)
        else
            _biasDir := 0
            _mssDir := 0
        _biasChanged := true
    else if _biasDir == -1 and not na(_lockedInvalid) and close > _lockedInvalid
        _invalidNow := true
        if _bullMss
            _biasDir := 1
            _mssDir := 1
            _lockedInvalid := _lastPL
            _rangeHigh := math.max(_lastPH, high)
            _rangeLow := _lastPL
        else
            _biasDir := 0
            _mssDir := 0
        _biasChanged := true
    else if _bullMss and _biasDir != 1
        _biasDir := 1
        _mssDir := 1
        _lockedInvalid := _lastPL
        _rangeHigh := math.max(_lastPH, high)
        _rangeLow := _lastPL
        _biasChanged := true
    else if _bearMss and _biasDir != -1
        _biasDir := -1
        _mssDir := -1
        _lockedInvalid := _lastPH
        _rangeHigh := _lastPH
        _rangeLow := math.min(_lastPL, low)
        _biasChanged := true

    if _biasChanged
        _lastSweepDir := 0
        _lastSweepBar := na
        _sweptPrice := na
        _sweepExtreme := na

    _nearInvalid = _biasDir == 1 and not na(_lockedInvalid) ? close <= _lockedInvalid + _atr * _nearAtr :
     _biasDir == -1 and not na(_lockedInvalid) ? close >= _lockedInvalid - _atr * _nearAtr : false
    _invalidStatus = _biasDir == 0 and _invalidNow ? 2 : _nearInvalid ? 1 : _biasDir != 0 ? 0 : 3

    _bsl = _lastPH
    _ssl = _lastPL
    _sweepMin = syminfo.mintick * _minSweepTicks

    _bslSweepNow = not na(_bsl) and high > _bsl and close < _bsl and (high - _bsl) >= _sweepMin
    _sslSweepNow = not na(_ssl) and low < _ssl and close > _ssl and (_ssl - low) >= _sweepMin

    if _sslSweepNow and not _bslSweepNow
        _lastSweepDir := 1
        _lastSweepBar := bar_index
        _sweptPrice := _ssl
        _sweepExtreme := low

    if _bslSweepNow and not _sslSweepNow
        _lastSweepDir := -1
        _lastSweepBar := bar_index
        _sweptPrice := _bsl
        _sweepExtreme := high

    _sweepInvalidNow = (_lastSweepDir == 1 and not na(_sweptPrice) and close < _sweptPrice) or (_lastSweepDir == -1 and not na(_sweptPrice) and close > _sweptPrice)
    if _sweepInvalidNow
        _lastSweepDir := 0
        _lastSweepBar := na

    _sweepFresh = not na(_lastSweepBar) and bar_index - _lastSweepBar <= _freshBars
    _sweepOld = not na(_lastSweepBar) and bar_index - _lastSweepBar > _freshBars
    _sweepStatus = _sweepInvalidNow ? 3 : _sweepFresh ? 1 : _sweepOld ? 2 : 0

    _dolDir = _sweepFresh and _lastSweepDir == 1 and not na(_bsl) ? 1 :
     _sweepFresh and _lastSweepDir == -1 and not na(_ssl) ? -1 : 0
    _dolTarget = _dolDir == 1 ? _bsl : _dolDir == -1 ? _ssl : na
    _dolReached = (_dolDir == 1 and high >= _dolTarget) or (_dolDir == -1 and low <= _dolTarget)
    _dolStatus = _dolDir == 0 ? 0 : _dolReached ? 2 : 1
    _dolDistance = na(_dolTarget) ? na : math.abs(_dolTarget - close)
    _dolAlign = _dolDir == 0 or _biasDir == 0 ? 0 : _dolDir == _biasDir ? 1 : -1

    _bullFvgNew = low > high[2] and close[1] > open[1] and math.abs(close[1] - open[1]) > _meanBody[1] * _dispMult
    _bearFvgNew = high < low[2] and close[1] < open[1] and math.abs(close[1] - open[1]) > _meanBody[1] * _dispMult

    if _bullFvgNew
        _bullFvgTop := low
        _bullFvgBtm := high[2]
        _bullFvgStatus := 1

    if _bearFvgNew
        _bearFvgTop := low[2]
