amyEntryV3_panelPos() =>
    amyDashV2_posInput == "Bottom Left" ? position.bottom_right : position.bottom_left

var table amyEntryV3_panel = table.new(position.bottom_left, 2, 8, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 55))

if amyEntryV3_show and amyEntryV3_showPanel and barstate.islast
    table.set_position(amyEntryV3_panel, amyEntryV3_panelPos())
    table.clear(amyEntryV3_panel, 0, 0, 1, 7)
    _headBg = color.new(#07111D, 0)
    _keyBg = color.new(#0B1623, 0)
    _cellBg = color.new(#050B12, 0)
    _sigBg = amyEntryV3_signalColor(amyEntryV3_lastType)

    table.cell(amyEntryV3_panel, 0, 0, "ENTRY ASSISTANT V3", text_color=color.white, bgcolor=_headBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 0, amyEntryV3_signalName(amyEntryV3_lastType), text_color=color.white, bgcolor=_sigBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 1, "ENTRY", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 1, amy_price(amyEntryV3_lastEntry), text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 2, "SL", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 2, amy_price(amyEntryV3_lastSl), text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 3, "TP1", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 3, amy_price(amyEntryV3_lastTp1), text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 4, "TP2", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 4, amy_price(amyEntryV3_lastTp2), text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 5, "BIAS", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 5, amyEntryV3_biasName(amyDashV2_biasDir), text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 6, "LTF", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 6, amyEntryV3_triggerTf + " | " + (amyEntryV3_ltfBullPending ? "Buy retest wait" : amyEntryV3_ltfBearPending ? "Sell retest wait" : "No pending"), text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 0, 7, "REASON", text_color=color.white, bgcolor=_keyBg, text_size=size.tiny)
    table.cell(amyEntryV3_panel, 1, 7, amyEntryV3_lastReason, text_color=color.white, bgcolor=_cellBg, text_size=size.tiny)

if (not amyEntryV3_show or not amyEntryV3_showPanel) and barstate.islast
    table.clear(amyEntryV3_panel, 0, 0, 1, 7)

