    ent_signalText = ent_isBuy ? ent_readyMode == 1 ? "BUY TREND" : "BUY REVERSAL" : ent_readyMode == -1 ? "SELL TREND" : "SELL REVERSAL"

    ent_lb_signal := label.new(bar_index, ent_isBuy ? low : high, ent_signalText, style=ent_isBuy ? label.style_label_up : label.style_label_down, color=ent_colEntry, textcolor=ent_isBuy ? color.black : color.white, size=size.normal)
    ent_lb_entry := label.new(bar_index + ent_levelBars, ent_entry, "Entry: " + str.tostring(ent_entry, format.mintick), style=label.style_label_left, color=ent_colEntry, textcolor=ent_isBuy ? color.black : color.white, size=size.small)
    ent_lb_sl := label.new(bar_index + ent_levelBars, ent_sl, "Stoploss: " + str.tostring(ent_sl, format.mintick), style=label.style_label_left, color=ent_colSL, textcolor=color.white, size=size.small)
