float shortSL = na
float longTP1 = na
float longTP2 = na
float longTP3 = na
float shortTP1 = na
float shortTP2 = na
float shortTP3 = na

longSL := bullCtxOk ? bullInvalid : na
shortSL := bearCtxOk ? bearInvalid : na

longTP1 := bullCtxOk ? bullExt1 : na
longTP2 := bullCtxOk ? bullExt2 : na
longTP3 := bullCtxOk ? bullExt3 : na
shortTP1 := bearCtxOk ? bearExt1 : na
shortTP2 := bearCtxOk ? bearExt2 : na
shortTP3 := bearCtxOk ? bearExt3 : na

string planText = "Belum ada rencana eksekusi yang jelas."
