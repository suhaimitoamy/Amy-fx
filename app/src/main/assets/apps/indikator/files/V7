bearFvgLowPlot = plot(showPoiZones and bearFvgPoi and bearCtxOk ? bearFvgLow : na, "Bear FVG POI Low", color = color.new(color.orange, 55), style = plot.style_linebr)
bearFvgHighPlot = plot(showPoiZones and bearFvgPoi and bearCtxOk ? bearFvgHigh : na, "Bear FVG POI High", color = color.new(color.orange, 55), style = plot.style_linebr)
