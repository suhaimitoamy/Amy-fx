string breakText = ctxBreakType == 1 and ctxDir == 1 ? "Break bullish valid by close." :
     ctxBreakType == 1 and ctxDir == -1 ? "Break bearish valid by close." :
     ctxBreakType == 2 and ctxDir == 1 ? "Break bullish impulsif." :
     ctxBreakType == 2 and ctxDir == -1 ? "Break bearish impulsif." :
     ctxBreakType == 3 and ctxDir == 1 ? "Sweep bawah lalu reclaim bullish." :
     ctxBreakType == 3 and ctxDir == -1 ? "Sweep atas lalu reclaim bearish." :
