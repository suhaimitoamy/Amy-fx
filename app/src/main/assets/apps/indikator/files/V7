bullObHighPlot = plot(showPoiZones and bullObPoi and bullCtxOk ? bullObHigh : na, "Bull OB POI High", color = color.new(color.green, 60), style = plot.style_linebr)
fill(bullObLowPlot, bullObHighPlot, color = color.new(color.green, 92), title = "Bull OB POI Fill")

