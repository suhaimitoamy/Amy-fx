     ctxState == 5 and ctxDir == -1 ? "Sweep atas terkonfirmasi dan seller reclaim level." :
     ctxState == 6 and ctxDir == 1 ? "Setup bullish gagal hold level." :
     ctxState == 6 and ctxDir == -1 ? "Setup bearish gagal hold level." :
     "Konfirmasi belum terbentuk."

string narrativeText = ctxState == 5 and ctxDir == 1 ? "Buyer mengambil likuiditas bawah lalu reclaim area penting." :
     ctxState == 5 and ctxDir == -1 ? "Seller mengambil likuiditas atas lalu reclaim area penting." :
     ctxState == 4 and ctxDir == 1 ? "Buyer memegang kontrol dan market sedang mode continuation." :
     ctxState == 4 and ctxDir == -1 ? "Seller memegang kontrol dan market sedang mode continuation." :
     ctxState == 3 and ctxDir == 1 ? "Break sudah diuji dan area hold sebagai support baru." :
     ctxState == 3 and ctxDir == -1 ? "Break sudah diuji dan area hold sebagai resistance baru." :
     ctxState == 2 and ctxDir == 1 ? "Belum ada full retest, tapi market accepted di atas level break." :
     ctxState == 2 and ctxDir == -1 ? "Belum ada full retest, tapi market accepted di bawah level break." :
     ctxState == 1 and ctxDir == 1 ? "Bias naik ada, market baru mulai pecah ke atas." :
     ctxState == 1 and ctxDir == -1 ? "Bias turun ada, market baru mulai pecah ke bawah." :
     ctxState == 6 and ctxDir == 1 ? "Buyer gagal mempertahankan break." :
     ctxState == 6 and ctxDir == -1 ? "Seller gagal mempertahankan break." :
     bullBias ? "Bias HTF masih bullish, tunggu setup bersih." :
     bearBias ? "Bias HTF masih bearish, tunggu setup bersih." :
     "Market masih mixed."

poiSummaryText = bullCtxOk ? (bullObPoi and bullFvgPoi ? "Bull OB + FVG POI" : bullObPoi ? "Bull OB POI" : bullFvgPoi ? "Bull FVG POI" : "No bull POI") :
     bearCtxOk ? (bearObPoi and bearFvgPoi ? "Bear OB + FVG POI" : bearObPoi ? "Bear OB POI" : bearFvgPoi ? "Bear FVG POI" : "No bear POI") :
     "No active POI"

