bearObHighPlot = plot(showPoiZones and bearObPoi and bearCtxOk ? bearObHigh : na, "Bear OB POI High", color = color.new(color.red, 60), style = plot.style_linebr)
fill(bearObLowPlot, bearObHighPlot, color = color.new(color.red, 92), title = "Bear OB POI Fill")

