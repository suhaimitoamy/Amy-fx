        table.cell(ctx_dash, 0, 11, "LIQUIDITY", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
        table.cell(ctx_dash, 1, 11, "BSL " + ctx_price(ctx_bslLevel) + " | SSL " + ctx_price(ctx_sslLevel), text_color=color.white, bgcolor=ctx_cellBg, text_size=ctx_dashTextSize)

        table.cell(ctx_dash, 0, 12, "SESSION", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
        table.cell(ctx_dash, 1, 12, ctx_killzoneText, text_color=color.white, bgcolor=ctx_cellBg, text_size=ctx_dashTextSize)

if not ctx_showDashboard and barstate.islast
