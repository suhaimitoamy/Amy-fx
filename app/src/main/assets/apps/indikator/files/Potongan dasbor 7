//==================== CUSTOM MARKET TRANSLATOR DASHBOARD M1-READY ====================//
ctx_groupDash = "Custom Market Translator Dashboard"
ctx_showDashboard = input.bool(true, "Show Dashboard", group=ctx_groupDash)
ctx_dashPositionInput = input.string("Bottom Right", "Dashboard Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=ctx_groupDash)
ctx_dashboardMode = input.string("Simple", "Dashboard Mode", options=["Simple", "Detail"], group=ctx_groupDash)
ctx_rangeLen = input.int(50, "Price Location Range", minval=20, maxval=300, group=ctx_groupDash)
ctx_nearInvalidAtr = input.float(0.35, "Near Invalidation ATR", minval=0.05, maxval=2.0, step=0.05, group=ctx_groupDash)
ctx_closeMssLen = input.int(5, "Close-Based MSS Lookback", minval=3, maxval=15, group=ctx_groupDash)
ctx_sweepFreshBars = input.int(8, "Sweep Fresh Bars", minval=3, maxval=30, group=ctx_groupDash)
ctx_falseSweepBodyAtr = input.float(0.30, "False Sweep Body ATR Filter", minval=0.05, maxval=1.0, step=0.05, group=ctx_groupDash)
ctx_scanDepth = input.int(5, "POI Scan Depth", minval=1, maxval=10, group=ctx_groupDash)
ctx_useBiasLatch = input.bool(true, "Latch Invalid Bias", group=ctx_groupDash)

ctx_dashPos(_pos) =>
    _pos == "Top Left" ? position.top_left :
     _pos == "Bottom Right" ? position.bottom_right :
     _pos == "Bottom Left" ? position.bottom_left :
     position.top_right

ctx_price(_x) =>
    na(_x) ? "-" : str.tostring(_x, format.mintick)

ctx_range(_a, _b) =>
    na(_a) or na(_b) ? "-" : ctx_price(math.min(_a, _b)) + " - " + ctx_price(math.max(_a, _b))

ctx_join(_a, _b) =>
    _a == "" ? _b : _b == "" ? _a : _a + " + " + _b

ctx_clip(_s, _max) =>
    str.length(_s) > _max ? str.substring(_s, 0, _max) + "..." : _s

ctx_clamp(_x, _lo, _hi) =>
    math.max(_lo, math.min(_x, _hi))

ctx_pct(_v) =>
    str.tostring(int(math.round(_v))) + "%"

//==================== CLOSE-BASED MSS CONFIRMED ====================//
ctx_mssBullRaw = close > ta.highest(close[1], ctx_closeMssLen)
ctx_mssBearRaw = close < ta.lowest(close[1], ctx_closeMssLen)

var int ctx_lastCloseMssDir = 0

if barstate.isconfirmed and ctx_mssBullRaw
    ctx_lastCloseMssDir := 1

if barstate.isconfirmed and ctx_mssBearRaw
    ctx_lastCloseMssDir := -1

ctx_mssDir = ctx_lastCloseMssDir
ctx_mssBull = ctx_mssDir == 1
ctx_mssBear = ctx_mssDir == -1
ctx_mssText = ctx_mssBull ? "MSS Bullish" : ctx_mssBear ? "MSS Bearish" : "MSS Neutral"

//==================== READ VISUAL ENGINE DATA ====================//
float ctx_bslTop = na
float ctx_bslBtm = na
float ctx_bslLevel = na
bool ctx_bslActive = false
bool ctx_bslSwept = false

if b_liq_B.size() > 0
    _bsl = b_liq_B.get(0)
    ctx_bslTop := _bsl.bx.get_top()
    ctx_bslBtm := _bsl.bx.get_bottom()
    ctx_bslLevel := not na(ctx_bslTop) and not na(ctx_bslBtm) ? math.max(ctx_bslTop, ctx_bslBtm) : na
    ctx_bslActive := not na(ctx_bslLevel) and not _bsl.broken

float ctx_sslTop = na
float ctx_sslBtm = na
float ctx_sslLevel = na
bool ctx_sslActive = false
bool ctx_sslSwept = false

if b_liq_S.size() > 0
    _ssl = b_liq_S.get(0)
    ctx_sslTop := _ssl.bx.get_top()
    ctx_sslBtm := _ssl.bx.get_bottom()
    ctx_sslLevel := not na(ctx_sslTop) and not na(ctx_sslBtm) ? math.min(ctx_sslTop, ctx_sslBtm) : na
    ctx_sslActive := not na(ctx_sslLevel) and not _ssl.broken

ctx_sweepBodyOk = body > atr * ctx_falseSweepBodyAtr

ctx_bslSweepNow = barstate.isconfirmed and not na(ctx_bslLevel) and high > ctx_bslLevel and close < ctx_bslLevel and ctx_sweepBodyOk
ctx_sslSweepNow = barstate.isconfirmed and not na(ctx_sslLevel) and low < ctx_sslLevel and close > ctx_sslLevel and ctx_sweepBodyOk

var int ctx_lastSweepDir = 0
var int ctx_lastSweepBar = na

if ctx_sslSweepNow and not ctx_bslSweepNow
    ctx_lastSweepDir := 1
    ctx_lastSweepBar := bar_index

if ctx_bslSweepNow and not ctx_sslSweepNow
    ctx_lastSweepDir := -1
    ctx_lastSweepBar := bar_index

ctx_sslSweepInvalidated = ctx_lastSweepDir == 1 and not na(ctx_sslLevel) and close < ctx_sslLevel
ctx_bslSweepInvalidated = ctx_lastSweepDir == -1 and not na(ctx_bslLevel) and close > ctx_bslLevel

if barstate.isconfirmed and (ctx_sslSweepInvalidated or ctx_bslSweepInvalidated)
    ctx_lastSweepDir := 0
    ctx_lastSweepBar := na

ctx_sweepFresh = not na(ctx_lastSweepBar) and bar_index - ctx_lastSweepBar <= ctx_sweepFreshBars

ctx_sslSwept := ctx_sslSweepNow or (ctx_sweepFresh and ctx_lastSweepDir == 1)
ctx_bslSwept := ctx_bslSweepNow or (ctx_sweepFresh and ctx_lastSweepDir == -1)

//==================== DOL ONLY AFTER SWEEP ====================//
int ctx_dolDir = 0
float ctx_dolTop = na
float ctx_dolBtm = na
float ctx_dolPrice = na
string ctx_dolText = "NEUTRAL"
string ctx_dolTargetText = "Belum ada DOL valid"
string ctx_dolStatusText = "Waiting"

ctx_dolDir := ctx_sslSwept and ctx_bslActive ? 1 :
     ctx_bslSwept and ctx_sslActive ? -1 :
     0

ctx_dolTop := ctx_dolDir == 1 ? ctx_bslTop : ctx_dolDir == -1 ? ctx_sslTop : na
ctx_dolBtm := ctx_dolDir == 1 ? ctx_bslBtm : ctx_dolDir == -1 ? ctx_sslBtm : na
ctx_dolPrice := ctx_dolDir == 1 ? ctx_bslLevel : ctx_dolDir == -1 ? ctx_sslLevel : na

ctx_dolText := ctx_dolDir == 1 ? "BSL" :
     ctx_dolDir == -1 ? "SSL" :
     "NEUTRAL"

ctx_dolReached = (ctx_dolDir == 1 and not na(ctx_dolPrice) and high >= ctx_dolPrice) or
     (ctx_dolDir == -1 and not na(ctx_dolPrice) and low <= ctx_dolPrice)

ctx_dolStatusText := ctx_dolDir == 0 ? "Waiting" :
     ctx_dolReached ? "Reached" :
     "Active"

ctx_dolTargetText := ctx_dolDir == 1 ? "Target BSL @ " + ctx_price(ctx_dolPrice) :
     ctx_dolDir == -1 ? "Target SSL @ " + ctx_price(ctx_dolPrice) :
     "Belum ada DOL valid"

//==================== POI SCAN ====================//
float ctx_bullFvgTop = na
float ctx_bullFvgBtm = na
bool ctx_bullFvgActive = false
bool ctx_bullFvgFailed = false

if bFVG_UP.size() > 0
    for i = 0 to math.min(bFVG_UP.size() - 1, ctx_scanDepth)
        _fvg = bFVG_UP.get(i)
        _top = _fvg.box.get_top()
        _btm = _fvg.box.get_bottom()
        if _fvg.active and not na(_top) and not na(_btm) and not ctx_bullFvgActive
            ctx_bullFvgTop := _top
            ctx_bullFvgBtm := _btm
            ctx_bullFvgActive := true
        if not _fvg.active and not na(_top) and not na(_btm) and close < math.min(_top, _btm)
            ctx_bullFvgFailed := true

float ctx_bearFvgTop = na
float ctx_bearFvgBtm = na
bool ctx_bearFvgActive = false
bool ctx_bearFvgFailed = false

if bFVG_DN.size() > 0
    for i = 0 to math.min(bFVG_DN.size() - 1, ctx_scanDepth)
        _fvg = bFVG_DN.get(i)
        _top = _fvg.box.get_top()
        _btm = _fvg.box.get_bottom()
        if _fvg.active and not na(_top) and not na(_btm) and not ctx_bearFvgActive
            ctx_bearFvgTop := _top
            ctx_bearFvgBtm := _btm
            ctx_bearFvgActive := true
        if not _fvg.active and not na(_top) and not na(_btm) and close > math.max(_top, _btm)
            ctx_bearFvgFailed := true

float ctx_bullObTop = na
float ctx_bullObBtm = na
bool ctx_bullObActive = false
bool ctx_bullObBreaker = false

if bullish_ob.size() > 0
    for i = 0 to math.min(bullish_ob.size() - 1, ctx_scanDepth)
        _ob = bullish_ob.get(i)
        if not _ob.breaker and not ctx_bullObActive
            ctx_bullObTop := _ob.top
            ctx_bullObBtm := _ob.btm
            ctx_bullObActive := true
        if _ob.breaker
            ctx_bullObBreaker := true

float ctx_bearObTop = na
float ctx_bearObBtm = na
bool ctx_bearObActive = false
bool ctx_bearObBreaker = false

if bearish_ob.size() > 0
    for i = 0 to math.min(bearish_ob.size() - 1, ctx_scanDepth)
        _ob = bearish_ob.get(i)
        if not _ob.breaker and not ctx_bearObActive
            ctx_bearObTop := _ob.top
            ctx_bearObBtm := _ob.btm
            ctx_bearObActive := true
        if _ob.breaker
            ctx_bearObBreaker := true

ctx_inBullFvg = ctx_bullFvgActive and low <= math.max(ctx_bullFvgTop, ctx_bullFvgBtm) and high >= math.min(ctx_bullFvgTop, ctx_bullFvgBtm)
ctx_inBearFvg = ctx_bearFvgActive and low <= math.max(ctx_bearFvgTop, ctx_bearFvgBtm) and high >= math.min(ctx_bearFvgTop, ctx_bearFvgBtm)

ctx_inBullOb = ctx_bullObActive and low <= math.max(ctx_bullObTop, ctx_bullObBtm) and high >= math.min(ctx_bullObTop, ctx_bullObBtm)
ctx_inBearOb = ctx_bearObActive and low <= math.max(ctx_bearObTop, ctx_bearObBtm) and high >= math.min(ctx_bearObTop, ctx_bearObBtm)

ctx_viActive = Vimbal.size() > 0

ctx_inKillzone = ny or ldn_open or ldn_close or asian
ctx_killzoneText = ny ? "New York" :
     ldn_open ? "London Open" :
     ldn_close ? "London Close" :
     asian ? "Asian" :
     "Off"

//==================== PRICE LOCATION / STATE ====================//
ctx_rangeHigh = ta.highest(high, ctx_rangeLen)
ctx_rangeLow = ta.lowest(low, ctx_rangeLen)
ctx_rangeSize = math.max(ctx_rangeHigh - ctx_rangeLow, syminfo.mintick)
ctx_pricePct = ctx_clamp((close - ctx_rangeLow) / ctx_rangeSize * 100.0, 0.0, 100.0)

ctx_priceLocation = ctx_pricePct >= 75 ? "PREMIUM / ATAS" :
     ctx_pricePct >= 50 ? "UPPER MID" :
     ctx_pricePct >= 25 ? "LOWER MID" :
     "DISCOUNT / BAWAH"

ctx_atrFast = ta.atr(5)
ctx_atrSlow = ta.sma(ctx_atrFast, 20)

ctx_expansion = body > meanBody * 1.30 or ctx_atrFast > ctx_atrSlow * 1.25
ctx_compression = body < meanBody * 0.70 and ctx_atrFast < ctx_atrSlow * 0.85
ctx_marketState = ctx_expansion ? "EXPANSION" : ctx_compression ? "COMPRESSION" : "BALANCED"

ctx_upperWick = high - math.max(open, close)
ctx_lowerWick = math.min(open, close) - low
ctx_bodySafe = math.max(body, syminfo.mintick)

ctx_bullRejection = ctx_lowerWick > ctx_bodySafe * 1.25 and close > open
ctx_bearRejection = ctx_upperWick > ctx_bodySafe * 1.25 and close < open
ctx_bullDisplacement = L_bodyUP
ctx_bearDisplacement = L_bodyDN

ctx_bullPA = ctx_bullRejection or ctx_bullDisplacement or vImb_Bl
ctx_bearPA = ctx_bearRejection or ctx_bearDisplacement or vImb_Br

//==================== MARKET SCORE ====================//
ctx_buyStrengthScore = 0
ctx_buyStrengthScore += ctx_mssBull ? 25 : 0
ctx_buyStrengthScore += ctx_sslSwept ? 30 : 0
ctx_buyStrengthScore += ctx_dolDir == 1 ? 20 : 0
ctx_buyStrengthScore += ctx_inBullFvg or ctx_inBullOb ? 15 : 0
ctx_buyStrengthScore += ctx_pricePct <= 50 ? 10 : 0

ctx_sellStrengthScore = 0
ctx_sellStrengthScore += ctx_mssBear ? 25 : 0
ctx_sellStrengthScore += ctx_bslSwept ? 30 : 0
ctx_sellStrengthScore += ctx_dolDir == -1 ? 20 : 0
ctx_sellStrengthScore += ctx_inBearFvg or ctx_inBearOb ? 15 : 0
ctx_sellStrengthScore += ctx_pricePct >= 50 ? 10 : 0

ctx_buyWeaknessScore = 0
ctx_buyWeaknessScore += ctx_mssBear ? 25 : 0
ctx_buyWeaknessScore += ctx_bslSwept ? 25 : 0
ctx_buyWeaknessScore += ctx_bearPA ? 10 : 0
ctx_buyWeaknessScore += ctx_pricePct >= 75 ? 10 : 0

ctx_sellWeaknessScore = 0
ctx_sellWeaknessScore += ctx_mssBull ? 25 : 0
ctx_sellWeaknessScore += ctx_sslSwept ? 25 : 0
ctx_sellWeaknessScore += ctx_bullPA ? 10 : 0
ctx_sellWeaknessScore += ctx_pricePct <= 25 ? 10 : 0

ctx_buyNet = ctx_buyStrengthScore - ctx_buyWeaknessScore
ctx_sellNet = ctx_sellStrengthScore - ctx_sellWeaknessScore

ctx_rawMarketDir = ctx_dolDir != 0 ? ctx_dolDir :
     ctx_buyNet > ctx_sellNet + 10 ? 1 :
     ctx_sellNet > ctx_buyNet + 10 ? -1 :
     ctx_mssBull and ctx_buyNet >= ctx_sellNet ? 1 :
     ctx_mssBear and ctx_sellNet >= ctx_buyNet ? -1 :
     0

//==================== INVALIDATION LATCH ====================//
float ctx_bullInvalid = na
float ctx_bearInvalid = na

ctx_bullInvalid := ctx_bullObActive ? ctx_bullObBtm : ctx_sslActive ? ctx_sslLevel : ta.lowest(low, len)
ctx_bearInvalid := ctx_bearObActive ? ctx_bearObTop : ctx_bslActive ? ctx_bslLevel : ta.highest(high, len)

ctx_activeInvalid = ctx_rawMarketDir == 1 ? ctx_bullInvalid : ctx_rawMarketDir == -1 ? ctx_bearInvalid : na

ctx_rawNearInvalid = ctx_rawMarketDir == 1 and not na(ctx_activeInvalid) ? close <= ctx_activeInvalid + atr * ctx_nearInvalidAtr :
     ctx_rawMarketDir == -1 and not na(ctx_activeInvalid) ? close >= ctx_activeInvalid - atr * ctx_nearInvalidAtr :
     false

ctx_rawInvalidNow = ctx_rawMarketDir == 1 and not na(ctx_activeInvalid) ? close < ctx_activeInvalid :
     ctx_rawMarketDir == -1 and not na(ctx_activeInvalid) ? close > ctx_activeInvalid :
     false

var bool ctx_biasInvalidated = false
var int ctx_lastConfirmedDir = 0

ctx_resetInvalid = ctx_biasInvalidated and (
     ctx_lastConfirmedDir == 1 and ctx_bslSwept and ctx_mssBear and ctx_bearPA or
     ctx_lastConfirmedDir == -1 and ctx_sslSwept and ctx_mssBull and ctx_bullPA)

if barstate.isconfirmed and ctx_resetInvalid
    ctx_biasInvalidated := false

if barstate.isconfirmed and ctx_useBiasLatch and ctx_rawInvalidNow and ctx_rawMarketDir != 0
    ctx_biasInvalidated := true

if barstate.isconfirmed and not ctx_biasInvalidated and ctx_rawMarketDir != 0
    ctx_lastConfirmedDir := ctx_rawMarketDir

ctx_invalidNow = ctx_useBiasLatch ? ctx_biasInvalidated : ctx_rawInvalidNow
ctx_nearInvalid = not ctx_invalidNow and ctx_rawNearInvalid

ctx_marketDir = ctx_invalidNow ? 0 : ctx_rawMarketDir

ctx_activeStrength = ctx_marketDir == 1 ? ctx_buyStrengthScore : ctx_marketDir == -1 ? ctx_sellStrengthScore : math.max(ctx_buyStrengthScore, ctx_sellStrengthScore)
ctx_activeWeakness = ctx_marketDir == 1 ? ctx_buyWeaknessScore : ctx_marketDir == -1 ? ctx_sellWeaknessScore : math.max(ctx_buyWeaknessScore, ctx_sellWeaknessScore)

ctx_bullConditionsMet = (ctx_mssBull ? 1 : 0) + (ctx_sslSwept ? 1 : 0) + (ctx_dolDir == 1 ? 1 : 0) + (ctx_inBullFvg or ctx_inBullOb ? 1 : 0) + (ctx_pricePct <= 50 ? 1 : 0)
ctx_bearConditionsMet = (ctx_mssBear ? 1 : 0) + (ctx_bslSwept ? 1 : 0) + (ctx_dolDir == -1 ? 1 : 0) + (ctx_inBearFvg or ctx_inBearOb ? 1 : 0) + (ctx_pricePct >= 50 ? 1 : 0)
ctx_confluenceScore = ctx_marketDir == 1 ? ctx_bullConditionsMet : ctx_marketDir == -1 ? ctx_bearConditionsMet : math.max(ctx_bullConditionsMet, ctx_bearConditionsMet)
ctx_healthValue = ctx_confluenceScore * 20

ctx_strengthText = ctx_marketDir == 1 ? "BUY FLOW" :
     ctx_marketDir == -1 ? "SELL FLOW" :
     "NO FLOW"

ctx_marketDirText = ctx_invalidNow ? "INVALID" :
     ctx_marketDir == 1 ? "NAIK" :
     ctx_marketDir == -1 ? "TURUN" :
     "SIDEWAYS"

ctx_marketIcon = ctx_invalidNow ? "×" :
     ctx_marketDir == 1 ? "▲" :
     ctx_marketDir == -1 ? "▼" :
     "◆"

ctx_invalidText = ctx_invalidNow ? "BIAS INVALID / WAIT RESET" :
     ctx_rawMarketDir == 1 ? "BUY invalid < " + ctx_price(ctx_activeInvalid) :
     ctx_rawMarketDir == -1 ? "SELL invalid > " + ctx_price(ctx_activeInvalid) :
     "Belum ada bias valid"

//==================== REVERSAL RISK INTERNAL ====================//
ctx_bearRevSigns = 0
ctx_bearRevSigns += ctx_mssBear ? 2 : 0
ctx_bearRevSigns += ctx_bslSwept ? 1 : 0
ctx_bearRevSigns += ctx_dolDir == -1 ? 1 : 0
ctx_bearRevSigns += ctx_bearPA ? 1 : 0
ctx_bearRevSigns += ctx_nearInvalid and ctx_rawMarketDir == 1 ? 1 : 0
ctx_bearRevSigns += ctx_pricePct >= 75 ? 1 : 0

ctx_bullRevSigns = 0
ctx_bullRevSigns += ctx_mssBull ? 2 : 0
ctx_bullRevSigns += ctx_sslSwept ? 1 : 0
ctx_bullRevSigns += ctx_dolDir == 1 ? 1 : 0
ctx_bullRevSigns += ctx_bullPA ? 1 : 0
ctx_bullRevSigns += ctx_nearInvalid and ctx_rawMarketDir == -1 ? 1 : 0
ctx_bullRevSigns += ctx_pricePct <= 25 ? 1 : 0

ctx_reversalLevel = ctx_rawMarketDir == 1 ? ctx_bearRevSigns :
     ctx_rawMarketDir == -1 ? ctx_bullRevSigns :
     math.max(ctx_bearRevSigns, ctx_bullRevSigns)

ctx_reversalWarningText = ctx_invalidNow ? "INVALIDATED" :
     ctx_rawMarketDir == 1 and ctx_reversalLevel >= 5 ? "BUY INVALID RISK" :
     ctx_rawMarketDir == -1 and ctx_reversalLevel >= 5 ? "SELL INVALID RISK" :
     ctx_rawMarketDir == 0 ? "NO CLEAR BIAS" :
     "OK"

ctx_reversalRiskHigh = ctx_reversalLevel >= 3
ctx_reversalConfirmed = ctx_reversalLevel >= 5

//==================== TRANSLATOR OUTPUT ====================//
ctx_conditionText = ctx_invalidNow ? "BIAS INVALID" :
     ctx_marketDir == 1 ? "BUY bias aktif selama invalid belum tembus" :
     ctx_marketDir == -1 ? "SELL bias aktif selama invalid belum tembus" :
     "WAIT, belum ada bias"

ctx_focusText = ctx_invalidNow ? "WAIT" :
     ctx_marketDir == 1 ? "BUY pullback / retrace" :
     ctx_marketDir == -1 ? "SELL retest / retrace" :
     "WAIT"

ctx_entryStatusText = ctx_invalidNow ? "WAIT / INVALID" :
     ctx_marketDir == 1 and ctx_dolDir == 1 ? "BUY ONLY" :
     ctx_marketDir == -1 and ctx_dolDir == -1 ? "SELL ONLY" :
     ctx_marketDir == 1 ? "BUY WAIT DOL" :
     ctx_marketDir == -1 ? "SELL WAIT DOL" :
     "WAIT"

ctx_reasonText = ""
ctx_reasonText := ctx_join(ctx_reasonText, ctx_mssText)
ctx_reasonText := ctx_join(ctx_reasonText, ctx_dolDir != 0 ? ctx_dolTargetText : "")
ctx_reasonText := ctx_join(ctx_reasonText, ctx_sslSwept ? "SSL swept" : "")
ctx_reasonText := ctx_join(ctx_reasonText, ctx_bslSwept ? "BSL swept" : "")
ctx_reasonText := ctx_reasonText == "" ? "Belum ada alasan kuat" : ctx_reasonText

ctx_detailText = ""
ctx_detailText := ctx_join(ctx_detailText, "State " + ctx_marketState)
ctx_detailText := ctx_join(ctx_detailText, "Location " + ctx_priceLocation + " " + ctx_pct(ctx_pricePct))
ctx_detailText := ctx_join(ctx_detailText, "Confluence " + str.tostring(ctx_confluenceScore) + "/5")
ctx_detailText := ctx_join(ctx_detailText, ctx_viActive ? "VI Active" : "")
ctx_detailText := ctx_join(ctx_detailText, ctx_nearInvalid ? "Near Invalid" : "")
ctx_detailText := ctx_join(ctx_detailText, ctx_invalidNow ? "Invalid Broken" : "")

//==================== DASHBOARD STYLE ====================//
ctx_dashTextSize = size.tiny
ctx_headBg = color.new(#08131f, 0)
ctx_panelBg = color.new(#050b12, 0)
ctx_cellBg = color.new(#07111d, 0)
ctx_mutedBg = color.new(color.gray, 45)
ctx_greenBg = color.new(color.lime, 22)
ctx_redBg = color.new(color.red, 18)
ctx_orangeBg = color.new(color.orange, 15)

ctx_dirColor = ctx_invalidNow ? ctx_redBg : ctx_marketDir == 1 ? ctx_greenBg : ctx_marketDir == -1 ? ctx_redBg : ctx_orangeBg
ctx_dolColor = ctx_dolDir == 1 ? ctx_greenBg : ctx_dolDir == -1 ? ctx_redBg : ctx_mutedBg

ctx_strengthColor = ctx_marketDir == 1 ? ctx_greenBg :
     ctx_marketDir == -1 ? ctx_redBg :
     ctx_mutedBg

ctx_statusColor = ctx_invalidNow ? ctx_redBg :
     str.contains(ctx_entryStatusText, "WAIT") ? ctx_orangeBg :
     ctx_dirColor

ctx_invalidColor = ctx_invalidNow ? ctx_redBg : ctx_nearInvalid ? ctx_orangeBg : ctx_greenBg
ctx_focusColor = str.contains(ctx_focusText, "WAIT") ? ctx_orangeBg : ctx_dirColor

var table ctx_dash = table.new(ctx_dashPos(ctx_dashPositionInput), 2, 13, bgcolor=color.new(color.black, 8), border_width=1, border_color=color.new(color.gray, 45))

if ctx_showDashboard and barstate.islast
    table.clear(ctx_dash, 0, 0, 1, 12)

    table.cell(ctx_dash, 0, 0, "SCALPING DASHBOARD", text_color=color.white, bgcolor=ctx_headBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 0, syminfo.ticker, text_color=color.white, bgcolor=ctx_headBg, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 1, "BIAS", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 1, ctx_marketIcon + " " + ctx_marketDirText, text_color=color.white, bgcolor=ctx_dirColor, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 2, "FLOW", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 2, ctx_strengthText, text_color=color.white, bgcolor=ctx_strengthColor, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 3, "DOL", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 3, ctx_dolText + " @ " + ctx_price(ctx_dolPrice) + " | " + ctx_dolStatusText, text_color=color.white, bgcolor=ctx_dolColor, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 4, "POSISI HARGA", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 4, ctx_priceLocation + " | " + ctx_pct(ctx_pricePct), text_color=color.white, bgcolor=ctx_cellBg, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 5, "ENTRY PLAN", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 5, ctx_entryStatusText, text_color=color.white, bgcolor=ctx_statusColor, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 6, "INVALID", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 6, ctx_invalidText, text_color=color.white, bgcolor=ctx_invalidColor, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 7, "FOKUS", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 7, ctx_clip(ctx_focusText, 48), text_color=color.white, bgcolor=ctx_focusColor, text_size=ctx_dashTextSize)

    table.cell(ctx_dash, 0, 8, "ALASAN INTI", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
    table.cell(ctx_dash, 1, 8, ctx_clip(ctx_reasonText, 56), text_color=color.white, bgcolor=ctx_cellBg, text_size=ctx_dashTextSize)

    if ctx_dashboardMode == "Detail"
        table.cell(ctx_dash, 0, 9, "DETAIL", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
        table.cell(ctx_dash, 1, 9, ctx_clip(ctx_detailText, 56), text_color=color.white, bgcolor=ctx_cellBg, text_size=ctx_dashTextSize)

        table.cell(ctx_dash, 0, 10, "POI", text_color=color.white, bgcolor=ctx_panelBg, text_size=ctx_dashTextSize)
