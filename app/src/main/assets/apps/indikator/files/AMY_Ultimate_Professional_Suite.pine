//@version=5
indicator("AMY Ultimate Professional Suite", shorttitle="AMY Ultimate", overlay=true, max_lines_count=500, max_boxes_count=300, max_labels_count=500, max_bars_back=3000)

//==================== INPUTS ====================//
amy_groupCore = "AMY Core Settings"
amy_swingLen = input.int(5, "Swing Length", minval=2, maxval=30, group=amy_groupCore)
amy_atrLen = input.int(14, "ATR Length", minval=5, maxval=50, group=amy_groupCore)
amy_extendBars = input.int(45, "Extend Right Bars", minval=10, maxval=300, group=amy_groupCore)

amy_groupDisplay = "AMY Clean Display"
amy_displayMode = input.string("Compact", "Display Mode", options=["Compact", "Balanced", "Full"], group=amy_groupDisplay)
amy_showZones = input.bool(false, "Show Supply/Demand Zones", group=amy_groupDisplay)
amy_showSnr = input.bool(false, "Show SNR Lines", group=amy_groupDisplay)
amy_showFibo = input.bool(false, "Show Fibo Lines", group=amy_groupDisplay)
amy_showPanel = input.bool(true, "Show Dashboard", group=amy_groupDisplay)
amy_panelPositionInput = input.string("Bottom Right", "Dashboard Position", options=["Top Right", "Top Left", "Middle Right", "Middle Left", "Bottom Right", "Bottom Left", "Bottom Center"], group=amy_groupDisplay)
amy_showLabels = input.bool(true, "Show Signal Labels", group=amy_groupDisplay)

amy_groupSnd = "AMY Supply Demand Engine"
amy_maxZones = input.int(8, "Stored Supply/Demand Zones", minval=1, maxval=30, group=amy_groupSnd)
amy_dispAtr = input.float(1.0, "Minimum Impulse Away ATR", minval=0.2, step=0.1, group=amy_groupSnd)
amy_zoneAtrPad = input.float(0.15, "Zone Minimum Size ATR", minval=0.0, step=0.05, group=amy_groupSnd)
amy_baseLookback = input.int(3, "Base Candle Scan", minval=1, maxval=8, group=amy_groupSnd)
amy_baseBodyMax = input.float(0.55, "Base Max Body / Range", minval=0.1, maxval=0.9, step=0.05, group=amy_groupSnd)
amy_baseNearAtr = input.float(0.45, "Base Near Pivot ATR", minval=0.1, maxval=2.0, step=0.05, group=amy_groupSnd)
amy_keepFreshZones = input.bool(true, "Remove Broken Zones", group=amy_groupSnd)

amy_groupSnr = "AMY SNR Engine"
amy_maxSnr = input.int(10, "Stored SNR Levels", minval=2, maxval=40, group=amy_groupSnr)
amy_snrMergeAtr = input.float(0.30, "Merge Nearby SNR ATR", minval=0.05, step=0.05, group=amy_groupSnr)
amy_snrMinTouches = input.int(1, "Minimum SNR Touches For Confluence", minval=1, maxval=5, group=amy_groupSnr)

amy_groupFibo = "AMY Fibo Engine"
amy_fiboMode = input.string("Auto", "Fibo Mode", options=["Auto", "Manual Price"], group=amy_groupFibo)
amy_manualLow = input.float(0.0, "Manual Low Price", minval=0.0, step=0.01, group=amy_groupFibo)
amy_manualHigh = input.float(0.0, "Manual High Price", minval=0.0, step=0.01, group=amy_groupFibo)
amy_manualBias = input.string("Bullish", "Manual Fibo Bias", options=["Bullish", "Bearish"], group=amy_groupFibo)
amy_useFibo = input.bool(true, "Use Fibo 0.618 - 0.786", group=amy_groupFibo)
amy_fibA = input.float(0.618, "Fibo Zone Start", minval=0.1, maxval=1.0, step=0.001, group=amy_groupFibo)
amy_fibB = input.float(0.786, "Fibo Zone End", minval=0.1, maxval=1.0, step=0.001, group=amy_groupFibo)

amy_groupEntry = "AMY Entry Engine"
amy_showEntry = input.bool(true, "Show Entry Engine", group=amy_groupEntry)
amy_useConfluence = input.bool(true, "Require SNR / SD Confluence", group=amy_groupEntry)
amy_useHtfFilter = input.bool(false, "Use HTF Bias Filter", group=amy_groupEntry)
amy_htfTf = input.timeframe("60", "HTF Bias Timeframe", group=amy_groupEntry)
amy_htfEmaLen = input.int(50, "HTF EMA Length", minval=10, maxval=200, group=amy_groupEntry)
amy_tolAtr = input.float(0.30, "Entry Tolerance ATR", minval=0.05, step=0.05, group=amy_groupEntry)
amy_rejectRatio = input.float(1.2, "Rejection Wick Ratio", minval=0.2, step=0.1, group=amy_groupEntry)
amy_slAtr = input.float(0.35, "SL Buffer ATR", minval=0.05, step=0.05, group=amy_groupEntry)
amy_rr1 = input.float(1.0, "TP1 RR", minval=0.2, step=0.1, group=amy_groupEntry)
amy_rr2 = input.float(2.0, "TP2 RR", minval=0.5, step=0.1, group=amy_groupEntry)
amy_showTradeLines = input.bool(true, "Show Entry / SL / TP Lines Only On Signal", group=amy_groupEntry)
amy_showMissed = input.bool(true, "Show Missed Labels", group=amy_groupEntry)

//==================== BASE CALC ====================//
amy_atr = ta.atr(amy_atrLen)
amy_body = math.abs(close - open)
amy_bodySafe = math.max(amy_body, syminfo.mintick)
amy_upperWick = high - math.max(open, close)
amy_lowerWick = math.min(open, close) - low
amy_bullReject = close > open and amy_lowerWick >= amy_bodySafe * amy_rejectRatio
amy_bearReject = close < open and amy_upperWick >= amy_bodySafe * amy_rejectRatio
amy_tol = amy_atr * amy_tolAtr
amy_lowestAfterPivotHigh = ta.lowest(low, amy_swingLen)
amy_highestAfterPivotLow = ta.highest(high, amy_swingLen)
amy_htfClose = request.security(syminfo.tickerid, amy_htfTf, close, barmerge.gaps_off, barmerge.lookahead_off)
amy_htfEma = request.security(syminfo.tickerid, amy_htfTf, ta.ema(close, amy_htfEmaLen), barmerge.gaps_off, barmerge.lookahead_off)
amy_htfBull = amy_htfClose >= amy_htfEma
amy_htfBear = amy_htfClose < amy_htfEma

//==================== STORAGE ====================//
var box[] amy_sdBoxes = array.new_box()
var label[] amy_sdLabels = array.new_label()
var float[] amy_sdTops = array.new_float()
var float[] amy_sdBtms = array.new_float()
var int[] amy_sdDirs = array.new_int()

var line[] amy_snrLines = array.new_line()
var label[] amy_snrLabels = array.new_label()
var float[] amy_snrPrices = array.new_float()
var int[] amy_snrDirs = array.new_int()
var int[] amy_snrTouches = array.new_int()

var line[] amy_fibLines = array.new_line()
var label[] amy_fibLabels = array.new_label()
var float[] amy_fibRatios = array.from(0.0, 0.382, 0.5, 0.618, 0.705, 0.786, 1.0, 1.272)
var string[] amy_fibNames = array.from("0", "0.382", "0.5", "0.618", "0.705", "0.786", "1", "1.272")

var float amy_prevSwingPrice = na
var int amy_prevSwingIndex = na
var int amy_prevSwingType = 0
var float amy_lastSwingPrice = na
var int amy_lastSwingIndex = na
var int amy_lastSwingType = 0

var line amy_entryLine = na
var line amy_slLine = na
var line amy_tp1Line = na
var line amy_tp2Line = na
var label amy_tradeLabel = na
var box amy_entryZoneBox = na

var int amy_legId = na
var bool amy_buyZoneTouched = false
var bool amy_sellZoneTouched = false

//==================== HELPERS ====================//
amy_panelPosition(_pos) =>
    _pos == "Top Right" ? position.top_right :
     _pos == "Top Left" ? position.top_left :
     _pos == "Middle Right" ? position.middle_right :
     _pos == "Middle Left" ? position.middle_left :
     _pos == "Bottom Left" ? position.bottom_left :
     _pos == "Bottom Center" ? position.bottom_center :
     position.bottom_right

amy_snrColor(_dir, _transp) =>
    _dir == 1 ? color.new(color.red, _transp) : color.new(color.lime, _transp)

amy_zoneColor(_dir, _transp) =>
    _dir == 1 ? color.new(color.lime, _transp) : color.new(color.red, _transp)

amy_zoneBorder(_dir, _transp) =>
    _dir == 1 ? color.new(color.lime, _transp) : color.new(color.red, _transp)

amy_zoneOverlap(_top, _btm, _dir) =>
    bool _overlap = false
    if array.size(amy_sdTops) > 0
        for i = 0 to array.size(amy_sdTops) - 1
            _oldDir = array.get(amy_sdDirs, i)
            _oldTop = array.get(amy_sdTops, i)
            _oldBtm = array.get(amy_sdBtms, i)
            _isOverlap = not (_btm > _oldTop or _top < _oldBtm)
            if _oldDir == _dir and _isOverlap
                _overlap := true
    _overlap

amy_findSupplyZone(_pivotOff) =>
    float _top = high[_pivotOff]
    float _btm = math.min(open[_pivotOff], close[_pivotOff])
    float _pivotHigh = high[_pivotOff]
    float _atrAt = math.max(amy_atr[_pivotOff], syminfo.mintick)
    for j = 0 to amy_baseLookback - 1
        _off = _pivotOff + j
        _rng = math.max(high[_off] - low[_off], syminfo.mintick)
        _bodyNow = math.abs(close[_off] - open[_off])
        _smallBase = _bodyNow <= _rng * amy_baseBodyMax
        _nearPivot = math.abs(high[_off] - _pivotHigh) <= _atrAt * amy_baseNearAtr
        if _smallBase and _nearPivot
            _top := math.max(_top, high[_off])
            _btm := math.min(_btm, math.min(open[_off], close[_off]))
    [_top, _btm]

amy_findDemandZone(_pivotOff) =>
    float _top = math.max(open[_pivotOff], close[_pivotOff])
    float _btm = low[_pivotOff]
    float _pivotLow = low[_pivotOff]
    float _atrAt = math.max(amy_atr[_pivotOff], syminfo.mintick)
    for j = 0 to amy_baseLookback - 1
        _off = _pivotOff + j
        _rng = math.max(high[_off] - low[_off], syminfo.mintick)
        _bodyNow = math.abs(close[_off] - open[_off])
        _smallBase = _bodyNow <= _rng * amy_baseBodyMax
        _nearPivot = math.abs(low[_off] - _pivotLow) <= _atrAt * amy_baseNearAtr
        if _smallBase and _nearPivot
            _top := math.max(_top, math.max(open[_off], close[_off]))
            _btm := math.min(_btm, low[_off])
    [_top, _btm]

[amy_supplyTopCalc, amy_supplyBtmCalc] = amy_findSupplyZone(amy_swingLen)
[amy_demandTopCalc, amy_demandBtmCalc] = amy_findDemandZone(amy_swingLen)

amy_addZone(_top, _btm, _idx, _dir) =>
    _pad = math.max(amy_atr * amy_zoneAtrPad, syminfo.mintick)
    _zTop = math.max(_top, _btm)
    _zBtm = math.min(_top, _btm)
    _mid = math.avg(_zTop, _zBtm)
    if math.abs(_zTop - _zBtm) < _pad
        _zTop := _mid + _pad * 0.5
        _zBtm := _mid - _pad * 0.5
    if not amy_zoneOverlap(_zTop, _zBtm, _dir)
        _txt = _dir == 1 ? "DEMAND" : "SUPPLY"
        _fill = amy_showZones ? amy_zoneColor(_dir, 86) : amy_zoneColor(_dir, 100)
        _border = amy_showZones ? amy_zoneBorder(_dir, 35) : amy_zoneBorder(_dir, 100)
        _bx = box.new(_idx, _zTop, bar_index + amy_extendBars, _zBtm, xloc=xloc.bar_index, bgcolor=_fill, border_color=_border, text=amy_showZones ? _txt : "", text_color=_border, text_size=size.tiny, text_halign=text.align_left)
        _lb = label.new(_idx, _dir == 1 ? _zBtm : _zTop, _txt, xloc=xloc.bar_index, style=_dir == 1 ? label.style_label_up : label.style_label_down, color=color.new(_border, 85), textcolor=_border, size=size.tiny)
        array.unshift(amy_sdBoxes, _bx)
        array.unshift(amy_sdLabels, _lb)
        array.unshift(amy_sdTops, _zTop)
        array.unshift(amy_sdBtms, _zBtm)
        array.unshift(amy_sdDirs, _dir)
        while array.size(amy_sdBoxes) > amy_maxZones
            box.delete(array.pop(amy_sdBoxes))
            label.delete(array.pop(amy_sdLabels))
            array.pop(amy_sdTops)
            array.pop(amy_sdBtms)
            array.pop(amy_sdDirs)

amy_addSNR(_price, _idx, _dir) =>
    if not na(_price)
        _merge = amy_atr * amy_snrMergeAtr
        bool _merged = false
        if array.size(amy_snrPrices) > 0
            for i = 0 to array.size(amy_snrPrices) - 1
                _oldPrice = array.get(amy_snrPrices, i)
                _oldDir = array.get(amy_snrDirs, i)
                if _oldDir == _dir and math.abs(_price - _oldPrice) <= _merge and not _merged
                    _oldTouches = array.get(amy_snrTouches, i)
                    _newTouches = _oldTouches + 1
                    _newPrice = (_oldPrice * _oldTouches + _price) / _newTouches
                    array.set(amy_snrPrices, i, _newPrice)
                    array.set(amy_snrTouches, i, _newTouches)
                    _merged := true
        if not _merged
            _col = amy_snrColor(_dir, 100)
            _ln = line.new(_idx, _price, bar_index + amy_extendBars, _price, xloc=xloc.bar_index, extend=extend.none, color=_col, width=1, style=line.style_solid)
            _lb = label.new(bar_index + amy_extendBars, _price, "", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(_col, 100), textcolor=_col, size=size.tiny)
            array.unshift(amy_snrLines, _ln)
            array.unshift(amy_snrLabels, _lb)
            array.unshift(amy_snrPrices, _price)
            array.unshift(amy_snrDirs, _dir)
            array.unshift(amy_snrTouches, 1)
            while array.size(amy_snrLines) > amy_maxSnr
                line.delete(array.pop(amy_snrLines))
                label.delete(array.pop(amy_snrLabels))
                array.pop(amy_snrPrices)
                array.pop(amy_snrDirs)
                array.pop(amy_snrTouches)

amy_deleteTradeLines() =>
    if not na(amy_entryLine)
        line.delete(amy_entryLine)
    if not na(amy_slLine)
        line.delete(amy_slLine)
    if not na(amy_tp1Line)
        line.delete(amy_tp1Line)
    if not na(amy_tp2Line)
        line.delete(amy_tp2Line)
    if not na(amy_tradeLabel)
        label.delete(amy_tradeLabel)

//==================== PIVOT, ZONE, SNR ====================//
amy_ph = ta.pivothigh(high, amy_swingLen, amy_swingLen)
amy_pl = ta.pivotlow(low, amy_swingLen, amy_swingLen)

if not na(amy_ph)
    amy_pIdx = bar_index - amy_swingLen
    amy_pPrice = amy_ph
    amy_dropAway = amy_ph - amy_lowestAfterPivotHigh
    amy_validSupply = amy_dropAway >= amy_atr[amy_swingLen] * amy_dispAtr
    if amy_validSupply
        amy_addZone(amy_supplyTopCalc, amy_supplyBtmCalc, amy_pIdx, -1)
    amy_addSNR(amy_pPrice, amy_pIdx, 1)
    if amy_lastSwingType == 1
        if na(amy_lastSwingPrice) or amy_pPrice > amy_lastSwingPrice
            amy_lastSwingPrice := amy_pPrice
            amy_lastSwingIndex := amy_pIdx
    else
        amy_prevSwingPrice := amy_lastSwingPrice
        amy_prevSwingIndex := amy_lastSwingIndex
        amy_prevSwingType := amy_lastSwingType
        amy_lastSwingPrice := amy_pPrice
        amy_lastSwingIndex := amy_pIdx
        amy_lastSwingType := 1

if not na(amy_pl)
    amy_pIdx = bar_index - amy_swingLen
    amy_pPrice = amy_pl
    amy_riseAway = amy_highestAfterPivotLow - amy_pl
    amy_validDemand = amy_riseAway >= amy_atr[amy_swingLen] * amy_dispAtr
    if amy_validDemand
        amy_addZone(amy_demandTopCalc, amy_demandBtmCalc, amy_pIdx, 1)
    amy_addSNR(amy_pPrice, amy_pIdx, -1)
    if amy_lastSwingType == -1
        if na(amy_lastSwingPrice) or amy_pPrice < amy_lastSwingPrice
            amy_lastSwingPrice := amy_pPrice
            amy_lastSwingIndex := amy_pIdx
    else
        amy_prevSwingPrice := amy_lastSwingPrice
        amy_prevSwingIndex := amy_lastSwingIndex
        amy_prevSwingType := amy_lastSwingType
        amy_lastSwingPrice := amy_pPrice
        amy_lastSwingIndex := amy_pIdx
        amy_lastSwingType := -1

//==================== EXTEND / INVALIDATE ZONES ====================//
if array.size(amy_sdBoxes) > 0
    for i = array.size(amy_sdBoxes) - 1 to 0
        _bx = array.get(amy_sdBoxes, i)
        _dir = array.get(amy_sdDirs, i)
        _top = array.get(amy_sdTops, i)
        _btm = array.get(amy_sdBtms, i)
        box.set_right(_bx, bar_index + amy_extendBars)
        _invalid = amy_keepFreshZones and ((_dir == 1 and close < _btm) or (_dir == -1 and close > _top))
        if _invalid
            box.delete(array.remove(amy_sdBoxes, i))
            label.delete(array.remove(amy_sdLabels, i))
            array.remove(amy_sdTops, i)
            array.remove(amy_sdBtms, i)
            array.remove(amy_sdDirs, i)

//==================== FIBO ====================//
amy_autoLegReady = not na(amy_prevSwingPrice) and not na(amy_lastSwingPrice) and amy_prevSwingType != 0 and amy_lastSwingType != 0 and amy_prevSwingType != amy_lastSwingType
amy_autoBullLeg = amy_autoLegReady and amy_prevSwingType == -1 and amy_lastSwingType == 1
amy_autoBearLeg = amy_autoLegReady and amy_prevSwingType == 1 and amy_lastSwingType == -1
amy_manualReady = amy_fiboMode == "Manual Price" and amy_manualLow > 0 and amy_manualHigh > 0 and amy_manualHigh > amy_manualLow
amy_manualBullLeg = amy_manualReady and amy_manualBias == "Bullish"
amy_manualBearLeg = amy_manualReady and amy_manualBias == "Bearish"

amy_legReady = amy_fiboMode == "Manual Price" ? amy_manualReady : amy_autoLegReady
amy_bullLeg = amy_fiboMode == "Manual Price" ? amy_manualBullLeg : amy_autoBullLeg
amy_bearLeg = amy_fiboMode == "Manual Price" ? amy_manualBearLeg : amy_autoBearLeg
amy_legHigh = amy_fiboMode == "Manual Price" and amy_manualReady ? amy_manualHigh : amy_autoLegReady ? math.max(amy_prevSwingPrice, amy_lastSwingPrice) : na
amy_legLow = amy_fiboMode == "Manual Price" and amy_manualReady ? amy_manualLow : amy_autoLegReady ? math.min(amy_prevSwingPrice, amy_lastSwingPrice) : na
amy_legRange = amy_legReady ? amy_legHigh - amy_legLow : na
amy_fibAnchorIndex = amy_fiboMode == "Manual Price" ? bar_index - math.min(150, bar_index) : amy_lastSwingIndex

amy_currentLegId = amy_legReady ? (amy_fiboMode == "Manual Price" ? 999999 + (amy_bullLeg ? 1 : -1) : amy_lastSwingIndex * 10 + amy_lastSwingType) : na
if amy_legReady and amy_currentLegId != amy_legId
    amy_legId := amy_currentLegId
    amy_buyZoneTouched := false
    amy_sellZoneTouched := false

amy_fibPrice(_ratio) =>
    amy_bullLeg ? amy_legHigh - amy_legRange * _ratio : amy_bearLeg ? amy_legLow + amy_legRange * _ratio : na

if barstate.isfirst
    for i = 0 to array.size(amy_fibRatios) - 1
        array.push(amy_fibLines, line.new(bar_index, close, bar_index, close, xloc=xloc.bar_index, color=color.new(color.gray, 100)))
        array.push(amy_fibLabels, label.new(bar_index, close, "", xloc=xloc.bar_index, style=label.style_label_left, color=color.new(color.gray, 100), textcolor=color.new(color.gray, 100), size=size.tiny))

//==================== LOCATION CONFLUENCE ====================//
float amy_nearDemandTop = na
float amy_nearDemandBtm = na
float amy_nearSupplyTop = na
float amy_nearSupplyBtm = na
int amy_displayDemandIdx = na
int amy_displaySupplyIdx = na
float amy_bestDemandDist = na
float amy_bestSupplyDist = na

if array.size(amy_sdBoxes) > 0
    for i = 0 to array.size(amy_sdBoxes) - 1
        _dir = array.get(amy_sdDirs, i)
        _top = array.get(amy_sdTops, i)
        _btm = array.get(amy_sdBtms, i)
        _mid = math.avg(_top, _btm)
        _dist = math.abs(close - _mid)
        if _dir == 1 and (na(amy_bestDemandDist) or _dist < amy_bestDemandDist)
            amy_bestDemandDist := _dist
            amy_displayDemandIdx := i
        if _dir == -1 and (na(amy_bestSupplyDist) or _dist < amy_bestSupplyDist)
            amy_bestSupplyDist := _dist
            amy_displaySupplyIdx := i
        _inside = close <= _top + amy_tol and close >= _btm - amy_tol
        if _inside and _dir == 1 and na(amy_nearDemandTop)
            amy_nearDemandTop := _top
            amy_nearDemandBtm := _btm
        if _inside and _dir == -1 and na(amy_nearSupplyTop)
            amy_nearSupplyTop := _top
            amy_nearSupplyBtm := _btm

float amy_nearestSupport = na
float amy_nearestResistance = na
int amy_nearestSupportTouches = 0
int amy_nearestResistanceTouches = 0
int amy_nearestSupportIdx = na
int amy_nearestResistanceIdx = na

if array.size(amy_snrPrices) > 0
    for i = 0 to array.size(amy_snrPrices) - 1
        _price = array.get(amy_snrPrices, i)
        _dir = array.get(amy_snrDirs, i)
        _touch = array.get(amy_snrTouches, i)
        if _dir == -1 and _touch >= amy_snrMinTouches and _price <= close + amy_tol
            _dist = math.abs(close - _price)
            _best = na(amy_nearestSupport) ? 1000000000.0 : math.abs(close - amy_nearestSupport)
            if _dist < _best
                amy_nearestSupport := _price
                amy_nearestSupportTouches := _touch
                amy_nearestSupportIdx := i
        if _dir == 1 and _touch >= amy_snrMinTouches and _price >= close - amy_tol
            _dist = math.abs(close - _price)
            _best = na(amy_nearestResistance) ? 1000000000.0 : math.abs(close - amy_nearestResistance)
            if _dist < _best
                amy_nearestResistance := _price
                amy_nearestResistanceTouches := _touch
                amy_nearestResistanceIdx := i

amy_nearSupport = not na(amy_nearestSupport) and math.abs(close - amy_nearestSupport) <= amy_tol
amy_nearResistance = not na(amy_nearestResistance) and math.abs(close - amy_nearestResistance) <= amy_tol
amy_nearDemand = not na(amy_nearDemandTop)
amy_nearSupply = not na(amy_nearSupplyTop)

//==================== DISPLAY CLEANUP ====================//
if array.size(amy_sdBoxes) > 0
    for i = 0 to array.size(amy_sdBoxes) - 1
        _bx = array.get(amy_sdBoxes, i)
        _lb = array.get(amy_sdLabels, i)
        _dir = array.get(amy_sdDirs, i)
        _visibleCompact = i == amy_displayDemandIdx or i == amy_displaySupplyIdx
        _visibleBalanced = i < 4
        _visibleFull = true
        _visible = amy_showZones and (amy_displayMode == "Compact" ? _visibleCompact : amy_displayMode == "Balanced" ? _visibleBalanced : _visibleFull)
        _fill = _visible ? amy_zoneColor(_dir, amy_displayMode == "Compact" ? 88 : 86) : amy_zoneColor(_dir, 100)
        _border = _visible ? amy_zoneBorder(_dir, 40) : amy_zoneBorder(_dir, 100)
        _txt = _dir == 1 ? "DEMAND" : "SUPPLY"
        box.set_bgcolor(_bx, _fill)
        box.set_border_color(_bx, _border)
        box.set_text(_bx, _visible ? _txt : "")
        label.set_color(_lb, color.new(_border, _visible ? 85 : 100))
        label.set_textcolor(_lb, _border)
        label.set_text(_lb, _visible ? _txt : "")

if array.size(amy_snrLines) > 0
    for i = 0 to array.size(amy_snrLines) - 1
        _ln = array.get(amy_snrLines, i)
        _lb = array.get(amy_snrLabels, i)
        _price = array.get(amy_snrPrices, i)
        _dir = array.get(amy_snrDirs, i)
        _touch = array.get(amy_snrTouches, i)
        _visibleCompact = i == amy_nearestSupportIdx or i == amy_nearestResistanceIdx
        _visibleBalanced = i < 4 or _touch >= amy_snrMinTouches + 1
        _visibleFull = true
        _visible = amy_showSnr and (amy_displayMode == "Compact" ? _visibleCompact : amy_displayMode == "Balanced" ? _visibleBalanced : _visibleFull)
        _col = amy_snrColor(_dir, _visible ? 10 : 100)
        _name = _dir == 1 ? "R" : "S"
        line.set_x2(_ln, bar_index + amy_extendBars)
        line.set_y1(_ln, _price)
        line.set_y2(_ln, _price)
        line.set_color(_ln, _col)
        label.set_xy(_lb, bar_index + amy_extendBars, _price)
        label.set_text(_lb, _visible ? _name + " x" + str.tostring(_touch) + "  " + str.tostring(_price, format.mintick) : "")
        label.set_color(_lb, color.new(_col, _visible ? 85 : 100))
        label.set_textcolor(_lb, _col)

if barstate.islast
    for i = 0 to array.size(amy_fibRatios) - 1
        _ratio = array.get(amy_fibRatios, i)
        _name = array.get(amy_fibNames, i)
        _ln = array.get(amy_fibLines, i)
        _lb = array.get(amy_fibLabels, i)
        _level = amy_fibPrice(_ratio)
        _isZone = _ratio == 0.618 or _ratio == 0.705 or _ratio == 0.786
        _isBalanced = _isZone or _ratio == 0.5 or _ratio == 1.0
        _visible = amy_showFibo and amy_legReady and (amy_displayMode == "Compact" ? _isZone : amy_displayMode == "Balanced" ? _isBalanced : true)
        _col = _isZone ? color.new(color.orange, _visible ? 0 : 100) : color.new(color.silver, _visible ? 45 : 100)
        if _visible and not na(_level)
            line.set_xy1(_ln, amy_fibAnchorIndex, _level)
            line.set_xy2(_ln, bar_index + amy_extendBars, _level)
            line.set_color(_ln, _col)
            line.set_width(_ln, _isZone ? 2 : 1)
            label.set_xy(_lb, bar_index + amy_extendBars, _level)
            label.set_text(_lb, _name + "  " + str.tostring(_level, format.mintick))
            label.set_color(_lb, color.new(_col, 88))
            label.set_textcolor(_lb, _col)
        else
            line.set_color(_ln, color.new(color.gray, 100))
            label.set_text(_lb, "")

//==================== ENTRY ENGINE ====================//
amy_lowRatio = math.min(amy_fibA, amy_fibB)
amy_highRatio = math.max(amy_fibA, amy_fibB)

amy_buyZoneHigh = amy_bullLeg ? amy_legHigh - amy_legRange * amy_lowRatio : na
amy_buyZoneLow = amy_bullLeg ? amy_legHigh - amy_legRange * amy_highRatio : na
amy_sellZoneLow = amy_bearLeg ? amy_legLow + amy_legRange * amy_lowRatio : na
amy_sellZoneHigh = amy_bearLeg ? amy_legLow + amy_legRange * amy_highRatio : na

amy_inBuyFibo = amy_bullLeg and close >= amy_buyZoneLow - amy_tol and close <= amy_buyZoneHigh + amy_tol
amy_inSellFibo = amy_bearLeg and close >= amy_sellZoneLow - amy_tol and close <= amy_sellZoneHigh + amy_tol

if amy_inBuyFibo
    amy_buyZoneTouched := true
if amy_inSellFibo
    amy_sellZoneTouched := true

amy_buyLocation = amy_useFibo ? amy_inBuyFibo : (amy_nearDemand or amy_nearSupport)
amy_sellLocation = amy_useFibo ? amy_inSellFibo : (amy_nearSupply or amy_nearResistance)
amy_buyConfluence = not amy_useConfluence or amy_nearDemand or amy_nearSupport
amy_sellConfluence = not amy_useConfluence or amy_nearSupply or amy_nearResistance
amy_buyHtfOk = not amy_useHtfFilter or amy_htfBull
amy_sellHtfOk = not amy_useHtfFilter or amy_htfBear

amy_buyReady = amy_showEntry and amy_buyLocation and amy_buyConfluence and amy_bullReject and amy_buyHtfOk
amy_sellReady = amy_showEntry and amy_sellLocation and amy_sellConfluence and amy_bearReject and amy_sellHtfOk

amy_missedBuyRaw = amy_showEntry and amy_showMissed and amy_buyZoneTouched and amy_bullLeg and not amy_buyReady and close > amy_buyZoneHigh + amy_tol and close < amy_legHigh
amy_missedSellRaw = amy_showEntry and amy_showMissed and amy_sellZoneTouched and amy_bearLeg and not amy_sellReady and close < amy_sellZoneLow - amy_tol and close > amy_legLow

amy_buySignal = amy_buyReady and not nz(amy_buyReady[1], false)
amy_sellSignal = amy_sellReady and not nz(amy_sellReady[1], false)
amy_missedBuy = amy_missedBuyRaw and not nz(amy_missedBuyRaw[1], false)
amy_missedSell = amy_missedSellRaw and not nz(amy_missedSellRaw[1], false)

float amy_buySlBase = amy_buyZoneLow
if not na(amy_nearDemandBtm)
    amy_buySlBase := na(amy_buySlBase) ? amy_nearDemandBtm : math.min(amy_buySlBase, amy_nearDemandBtm)
if not na(amy_nearestSupport)
    amy_buySlBase := na(amy_buySlBase) ? amy_nearestSupport : math.min(amy_buySlBase, amy_nearestSupport)

float amy_sellSlBase = amy_sellZoneHigh
if not na(amy_nearSupplyTop)
    amy_sellSlBase := na(amy_sellSlBase) ? amy_nearSupplyTop : math.max(amy_sellSlBase, amy_nearSupplyTop)
if not na(amy_nearestResistance)
    amy_sellSlBase := na(amy_sellSlBase) ? amy_nearestResistance : math.max(amy_sellSlBase, amy_nearestResistance)

amy_buySL = amy_buyReady ? amy_buySlBase - amy_atr * amy_slAtr : na
amy_sellSL = amy_sellReady ? amy_sellSlBase + amy_atr * amy_slAtr : na
amy_buyRisk = amy_buyReady ? close - amy_buySL : na
amy_sellRisk = amy_sellReady ? amy_sellSL - close : na
amy_buyTP1 = amy_buyReady ? close + amy_buyRisk * amy_rr1 : na
amy_buyTP2 = amy_buyReady ? close + amy_buyRisk * amy_rr2 : na
amy_sellTP1 = amy_sellReady ? close - amy_sellRisk * amy_rr1 : na
amy_sellTP2 = amy_sellReady ? close - amy_sellRisk * amy_rr2 : na

amy_locationScore = (amy_inBuyFibo or amy_inSellFibo) ? 25 : 0
amy_sdScore = (amy_nearDemand or amy_nearSupply) ? 25 : 0
amy_snrScore = (amy_nearSupport or amy_nearResistance) ? 20 : 0
amy_rejectScore = (amy_bullReject or amy_bearReject) ? 20 : 0
amy_htfScore = ((amy_bullLeg and amy_buyHtfOk) or (amy_bearLeg and amy_sellHtfOk)) ? 10 : 0
amy_finalScore = amy_locationScore + amy_sdScore + amy_snrScore + amy_rejectScore + amy_htfScore
amy_rating = amy_finalScore >= 80 ? "A" : amy_finalScore >= 60 ? "B" : amy_finalScore >= 40 ? "C" : "D"

//==================== ENTRY ZONE BOX ====================//
if barstate.islast
    if not na(amy_entryZoneBox)
        box.delete(amy_entryZoneBox)
        amy_entryZoneBox := na
    if amy_showEntry and amy_bullLeg and not na(amy_buyZoneHigh) and not na(amy_buyZoneLow)
        amy_entryZoneBox := box.new(bar_index - 5, amy_buyZoneHigh, bar_index + amy_extendBars, amy_buyZoneLow, xloc=xloc.bar_index, bgcolor=color.new(color.lime, 92), border_color=color.new(color.lime, 55), text="BUY MATH ZONE", text_color=color.new(color.lime, 15), text_size=size.tiny, text_halign=text.align_left)
    if amy_showEntry and amy_bearLeg and not na(amy_sellZoneHigh) and not na(amy_sellZoneLow)
        amy_entryZoneBox := box.new(bar_index - 5, amy_sellZoneHigh, bar_index + amy_extendBars, amy_sellZoneLow, xloc=xloc.bar_index, bgcolor=color.new(color.red, 92), border_color=color.new(color.red, 55), text="SELL MATH ZONE", text_color=color.new(color.red, 15), text_size=size.tiny, text_halign=text.align_left)

//==================== TRADE LINES ====================//
if amy_showTradeLines and amy_buySignal and not na(amy_buySL) and not na(amy_buyTP1) and not na(amy_buyTP2)
    amy_deleteTradeLines()
    amy_txt = "BUY READY\nEntry: " + str.tostring(close, format.mintick) + "\nSL: " + str.tostring(amy_buySL, format.mintick) + "\nTP1: " + str.tostring(amy_buyTP1, format.mintick) + "\nTP2: " + str.tostring(amy_buyTP2, format.mintick)
    amy_entryLine := line.new(bar_index, close, bar_index + amy_extendBars, close, xloc=xloc.bar_index, color=color.new(color.yellow, 0), width=2)
    amy_slLine := line.new(bar_index, amy_buySL, bar_index + amy_extendBars, amy_buySL, xloc=xloc.bar_index, color=color.new(color.red, 0), width=2)
    amy_tp1Line := line.new(bar_index, amy_buyTP1, bar_index + amy_extendBars, amy_buyTP1, xloc=xloc.bar_index, color=color.new(color.aqua, 0), width=1)
    amy_tp2Line := line.new(bar_index, amy_buyTP2, bar_index + amy_extendBars, amy_buyTP2, xloc=xloc.bar_index, color=color.new(color.lime, 0), width=1)
    amy_tradeLabel := label.new(bar_index, low, amy_txt, xloc=xloc.bar_index, style=label.style_label_up, color=color.new(color.lime, 75), textcolor=color.lime, size=size.small)

if amy_showTradeLines and amy_sellSignal and not na(amy_sellSL) and not na(amy_sellTP1) and not na(amy_sellTP2)
    amy_deleteTradeLines()
    amy_txt = "SELL READY\nEntry: " + str.tostring(close, format.mintick) + "\nSL: " + str.tostring(amy_sellSL, format.mintick) + "\nTP1: " + str.tostring(amy_sellTP1, format.mintick) + "\nTP2: " + str.tostring(amy_sellTP2, format.mintick)
    amy_entryLine := line.new(bar_index, close, bar_index + amy_extendBars, close, xloc=xloc.bar_index, color=color.new(color.yellow, 0), width=2)
    amy_slLine := line.new(bar_index, amy_sellSL, bar_index + amy_extendBars, amy_sellSL, xloc=xloc.bar_index, color=color.new(color.red, 0), width=2)
    amy_tp1Line := line.new(bar_index, amy_sellTP1, bar_index + amy_extendBars, amy_sellTP1, xloc=xloc.bar_index, color=color.new(color.aqua, 0), width=1)
    amy_tp2Line := line.new(bar_index, amy_sellTP2, bar_index + amy_extendBars, amy_sellTP2, xloc=xloc.bar_index, color=color.new(color.lime, 0), width=1)
    amy_tradeLabel := label.new(bar_index, high, amy_txt, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(color.red, 75), textcolor=color.red, size=size.small)

//==================== SIGNAL PLOTS ====================//
plotshape(amy_showLabels and amy_buySignal, title="BUY READY", style=shape.labelup, text="BUY\nREADY", location=location.belowbar, color=color.new(color.lime, 0), textcolor=color.black, size=size.tiny)
plotshape(amy_showLabels and amy_sellSignal, title="SELL READY", style=shape.labeldown, text="SELL\nREADY", location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(amy_showLabels and amy_missedBuy, title="MISSED BUY", style=shape.labeldown, text="MISSED\nBUY", location=location.abovebar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
plotshape(amy_showLabels and amy_missedSell, title="MISSED SELL", style=shape.labelup, text="MISSED\nSELL", location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)

//==================== DASHBOARD ====================//
var table amy_panel = table.new(position.bottom_right, 2, 9, border_width=1)

if barstate.islast
    if amy_showPanel
        table.set_position(amy_panel, amy_panelPosition(amy_panelPositionInput))
        amy_status = amy_buyReady ? "BUY READY" : amy_sellReady ? "SELL READY" : amy_missedBuyRaw ? "MISSED BUY" : amy_missedSellRaw ? "MISSED SELL" : "NO ENTRY"
        amy_statusCol = amy_buyReady ? color.lime : amy_sellReady ? color.red : (amy_missedBuyRaw or amy_missedSellRaw) ? color.orange : color.gray
        amy_legText = amy_bullLeg ? "Bullish" : amy_bearLeg ? "Bearish" : "Waiting"
        amy_activeZone = amy_bullLeg and not na(amy_buyZoneLow) ? str.tostring(amy_buyZoneLow, format.mintick) + " - " + str.tostring(amy_buyZoneHigh, format.mintick) : amy_bearLeg and not na(amy_sellZoneLow) ? str.tostring(amy_sellZoneLow, format.mintick) + " - " + str.tostring(amy_sellZoneHigh, format.mintick) : "-"
        amy_sdText = amy_nearDemand ? "Demand" : amy_nearSupply ? "Supply" : "No"
        amy_srText = amy_nearSupport ? "Support x" + str.tostring(amy_nearestSupportTouches) : amy_nearResistance ? "Resistance x" + str.tostring(amy_nearestResistanceTouches) : "No"
        amy_rejectText = amy_bullReject ? "Bull Reject" : amy_bearReject ? "Bear Reject" : "No"
        amy_zoneTouchedText = amy_bullLeg ? (amy_buyZoneTouched ? "Buy touched" : "No") : amy_bearLeg ? (amy_sellZoneTouched ? "Sell touched" : "No") : "No"
        amy_htfText = amy_useHtfFilter ? (amy_htfBull ? "HTF Bull" : "HTF Bear") : "Off"

        table.cell(amy_panel, 0, 0, "AMY PRO CLEAN", text_color=color.white, bgcolor=color.new(color.blue, 35))
        table.cell(amy_panel, 1, 0, amy_status, text_color=color.white, bgcolor=color.new(amy_statusCol, 35))
        table.cell(amy_panel, 0, 1, "Leg", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 1, amy_legText, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 2, "Fibo Zone", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 2, amy_activeZone, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 3, "Zone Touched", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 3, amy_zoneTouchedText, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 4, "S/D", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 4, amy_sdText, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 5, "S/R", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 5, amy_srText, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 6, "Rejection", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 6, amy_rejectText, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 7, "HTF", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 7, amy_htfText, text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 0, 8, "Score", text_color=color.white, bgcolor=color.new(color.black, 70))
        table.cell(amy_panel, 1, 8, str.tostring(amy_finalScore) + " / " + amy_rating, text_color=color.white, bgcolor=color.new(color.black, 70))
    else
        table.clear(amy_panel, 0, 0, 1, 8)

//==================== ALERTS ====================//
alertcondition(amy_buySignal, title="AMY PRO CLEAN BUY READY", message="AMY PRO CLEAN: BUY READY")
alertcondition(amy_sellSignal, title="AMY PRO CLEAN SELL READY", message="AMY PRO CLEAN: SELL READY")
alertcondition(amy_missedBuy, title="AMY PRO CLEAN MISSED BUY", message="AMY PRO CLEAN: MISSED BUY")
alertcondition(amy_missedSell, title="AMY PRO CLEAN MISSED SELL", message="AMY PRO CLEAN: MISSED SELL")


//==================== AMY PIVOT V2 ====================//
amyPivotV2_group = "AMY Pivot V2"
amyPivotV2_show = input.bool(false, "Show Pivot Levels", group=amyPivotV2_group)
amyPivotV2_tf = input.string("D", "Pivot Source TF", options=["D", "W", "M"], group=amyPivotV2_group)
amyPivotV2_displayMode = input.string("Clean", "Pivot Display Mode", options=["All", "Clean", "Major Only"], group=amyPivotV2_group)
amyPivotV2_showLabels = input.bool(true, "Show Pivot Price Labels", group=amyPivotV2_group)
amyPivotV2_backBars = input.int(80, "Left Bars", minval=10, maxval=500, group=amyPivotV2_group)
amyPivotV2_extendBars = input.int(40, "Right Bars", minval=5, maxval=300, group=amyPivotV2_group)
amyPivotV2_lineWidth = input.int(1, "Line Width", minval=1, maxval=4, group=amyPivotV2_group)
amyPivotV2_nearAtrMult = input.float(2.0, "Show Level If Near ATR", minval=0.5, step=0.5, group=amyPivotV2_group)

amyPivotV2_rawHigh = request.security(syminfo.tickerid, amyPivotV2_tf, high, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
amyPivotV2_rawLow = request.security(syminfo.tickerid, amyPivotV2_tf, low, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
amyPivotV2_rawClose = request.security(syminfo.tickerid, amyPivotV2_tf, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyPivotV2_newTfBar = ta.change(time(amyPivotV2_tf)) != 0

var float amyPivotV2_prevHigh = na
var float amyPivotV2_prevLow = na
var float amyPivotV2_prevClose = na

if amyPivotV2_newTfBar or na(amyPivotV2_prevHigh)
    amyPivotV2_prevHigh := amyPivotV2_rawHigh[1]
    amyPivotV2_prevLow := amyPivotV2_rawLow[1]
    amyPivotV2_prevClose := amyPivotV2_rawClose[1]

amyPivotV2_atr = ta.atr(14)
amyPivotV2_range = amyPivotV2_prevHigh - amyPivotV2_prevLow
amyPivotV2_p = (amyPivotV2_prevHigh + amyPivotV2_prevLow + amyPivotV2_prevClose) / 3.0

amyPivotV2_r1 = 2.0 * amyPivotV2_p - amyPivotV2_prevLow
amyPivotV2_s1 = 2.0 * amyPivotV2_p - amyPivotV2_prevHigh
amyPivotV2_r2 = amyPivotV2_p + amyPivotV2_range
amyPivotV2_s2 = amyPivotV2_p - amyPivotV2_range
amyPivotV2_r3 = amyPivotV2_prevHigh + 2.0 * (amyPivotV2_p - amyPivotV2_prevLow)
amyPivotV2_s3 = amyPivotV2_prevLow - 2.0 * (amyPivotV2_prevHigh - amyPivotV2_p)
amyPivotV2_r4 = amyPivotV2_r3 + amyPivotV2_range
amyPivotV2_s4 = amyPivotV2_s3 - amyPivotV2_range

amyPivotV2_isNear(_lvl) =>
    not na(_lvl) and math.abs(close - _lvl) <= amyPivotV2_atr * amyPivotV2_nearAtrMult

amyPivotV2_showLevel(_lvl, _name) =>
    amyPivotV2_displayMode == "All" ? true :
     amyPivotV2_displayMode == "Major Only" ? (_name == "PIVOT" or _name == "R1" or _name == "S1") :
     _name == "PIVOT" or _name == "R1" or _name == "S1" or amyPivotV2_isNear(_lvl)

var line[] amyPivotV2_lines = array.new<line>(9, na)
var label[] amyPivotV2_labels = array.new<label>(9, na)
var string amyPivotV2_lastTf = ""

if amyPivotV2_lastTf != amyPivotV2_tf
    for i = 0 to array.size(amyPivotV2_lines) - 1
        amyPivotV2_oldLine = array.get(amyPivotV2_lines, i)
        amyPivotV2_oldLabel = array.get(amyPivotV2_labels, i)
        if not na(amyPivotV2_oldLine)
            line.delete(amyPivotV2_oldLine)
            array.set(amyPivotV2_lines, i, na)
        if not na(amyPivotV2_oldLabel)
            label.delete(amyPivotV2_oldLabel)
            array.set(amyPivotV2_labels, i, na)
    amyPivotV2_lastTf := amyPivotV2_tf

amyPivotV2_draw(_idx, _price, _name, _baseColor) =>
    line _ln = array.get(amyPivotV2_lines, _idx)
    label _lb = array.get(amyPivotV2_labels, _idx)
    _show = amyPivotV2_show and not na(_price) and amyPivotV2_showLevel(_price, _name)
    _txt = _name + "  " + str.tostring(_price, format.mintick)
    _left = math.max(0, bar_index - amyPivotV2_backBars)
    _right = bar_index + amyPivotV2_extendBars

    if _show
        if na(_ln)
            _ln := line.new(_left, _price, _right, _price, xloc=xloc.bar_index, extend=extend.none, color=_baseColor, width=amyPivotV2_lineWidth)
        else
            line.set_xy1(_ln, _left, _price)
            line.set_xy2(_ln, _right, _price)
            line.set_color(_ln, _baseColor)
            line.set_width(_ln, amyPivotV2_lineWidth)
            line.set_style(_ln, line.style_solid)

        if amyPivotV2_showLabels
            if na(_lb)
                _lb := label.new(_right, _price, _txt, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(_baseColor, 82), textcolor=_baseColor, size=size.tiny)
            else
                label.set_xy(_lb, _right, _price)
                label.set_text(_lb, _txt)
                label.set_color(_lb, color.new(_baseColor, 82))
                label.set_textcolor(_lb, _baseColor)
                label.set_size(_lb, size.tiny)
        else
            if not na(_lb)
                label.delete(_lb)
                _lb := na
    else
        if not na(_ln)
            line.delete(_ln)
            _ln := na
        if not na(_lb)
            label.delete(_lb)
            _lb := na

    array.set(amyPivotV2_lines, _idx, _ln)
    array.set(amyPivotV2_labels, _idx, _lb)

amyPivotV2_draw(0, amyPivotV2_r4, "R4", color.new(color.red, 35))
amyPivotV2_draw(1, amyPivotV2_r3, "R3", color.new(color.red, 30))
amyPivotV2_draw(2, amyPivotV2_r2, "R2", color.new(color.red, 20))
amyPivotV2_draw(3, amyPivotV2_r1, "R1", color.new(color.red, 10))
amyPivotV2_draw(4, amyPivotV2_p, "PIVOT", color.new(color.blue, 0))
amyPivotV2_draw(5, amyPivotV2_s1, "S1", color.new(color.lime, 10))
amyPivotV2_draw(6, amyPivotV2_s2, "S2", color.new(color.lime, 20))
amyPivotV2_draw(7, amyPivotV2_s3, "S3", color.new(color.lime, 30))
amyPivotV2_draw(8, amyPivotV2_s4, "S4", color.new(color.lime, 35))

//==================== AMY KEY LEVELS V2 ====================//
amyKeyV2_group = "AMY Key Levels V2"
amyKeyV2_show = input.bool(false, "Show Key Levels", group=amyKeyV2_group)
amyKeyV2_showLabels = input.bool(true, "Show Key Level Labels", group=amyKeyV2_group)
amyKeyV2_backBars = input.int(80, "Left Bars", minval=10, maxval=500, group=amyKeyV2_group)
amyKeyV2_extendBars = input.int(40, "Right Bars", minval=5, maxval=300, group=amyKeyV2_group)
amyKeyV2_lineWidth = input.int(1, "Line Width", minval=1, maxval=4, group=amyKeyV2_group)

amyKeyV2_showMO = input.bool(true, "Show Midnight Open", group=amyKeyV2_group)
amyKeyV2_showPDH = input.bool(true, "Show PDH", group=amyKeyV2_group)
amyKeyV2_showPDL = input.bool(true, "Show PDL", group=amyKeyV2_group)
amyKeyV2_showBSL = input.bool(false, "Show BSL", group=amyKeyV2_group)
amyKeyV2_showSSL = input.bool(false, "Show SSL", group=amyKeyV2_group)

amyKeyV2_moTz = input.string("America/New_York", "Midnight Open Timezone", group=amyKeyV2_group)
amyKeyV2_swingLen = input.int(5, "BSL / SSL Swing Length", minval=1, maxval=50, group=amyKeyV2_group)

amyKeyV2_moEngine() =>
    var float _mo = na
    _newDay = ta.change(time("D", "0000-2359", amyKeyV2_moTz)) != 0
    if _newDay or na(_mo)
        _mo := open
    _mo

amyKeyV2_moFixed = request.security(syminfo.tickerid, "1", amyKeyV2_moEngine(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

var float amyKeyV2_moFallback = na
amyKeyV2_newDayChart = ta.change(time("D", "0000-2359", amyKeyV2_moTz)) != 0

if amyKeyV2_newDayChart or na(amyKeyV2_moFallback)
    amyKeyV2_moFallback := open

amyKeyV2_midnightOpen = na(amyKeyV2_moFixed) ? amyKeyV2_moFallback : amyKeyV2_moFixed

amyKeyV2_asiaSession = not na(time(timeframe.period, "1000-1400", "Asia/Tokyo"))

var float amyKeyV2_asiaHigh = na
var float amyKeyV2_asiaLow = na

if amyKeyV2_asiaSession and not amyKeyV2_asiaSession[1]
    amyKeyV2_asiaHigh := high
    amyKeyV2_asiaLow := low
else if amyKeyV2_asiaSession
    amyKeyV2_asiaHigh := math.max(amyKeyV2_asiaHigh, high)
    amyKeyV2_asiaLow := math.min(amyKeyV2_asiaLow, low)


amyKeyV2_rawDailyHigh = request.security(syminfo.tickerid, "D", high, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
amyKeyV2_rawDailyLow = request.security(syminfo.tickerid, "D", low, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyKeyV2_newExchangeDay = ta.change(time("D")) != 0

var float amyKeyV2_pdh = na
var float amyKeyV2_pdl = na

if amyKeyV2_newExchangeDay or na(amyKeyV2_pdh)
    amyKeyV2_pdh := amyKeyV2_rawDailyHigh[1]
    amyKeyV2_pdl := amyKeyV2_rawDailyLow[1]

amyKeyV2_ph = ta.pivothigh(high, amyKeyV2_swingLen, amyKeyV2_swingLen)
amyKeyV2_pl = ta.pivotlow(low, amyKeyV2_swingLen, amyKeyV2_swingLen)

var float amyKeyV2_bsl = na
var float amyKeyV2_ssl = na

if not na(amyKeyV2_ph)
    amyKeyV2_bsl := amyKeyV2_ph

if not na(amyKeyV2_pl)
    amyKeyV2_ssl := amyKeyV2_pl

var line[] amyKeyV2_lines = array.new<line>(5, na)
var label[] amyKeyV2_labels = array.new<label>(5, na)

amyKeyV2_draw(_idx, _price, _name, _col, _showLevel) =>
    line _ln = array.get(amyKeyV2_lines, _idx)
    label _lb = array.get(amyKeyV2_labels, _idx)
    _show = amyKeyV2_show and _showLevel and not na(_price)
    _txt = _name + "  " + str.tostring(_price, format.mintick)
    _left = math.max(0, bar_index - amyKeyV2_backBars)
    _right = bar_index + amyKeyV2_extendBars

    if _show
        if na(_ln)
            _ln := line.new(_left, _price, _right, _price, xloc=xloc.bar_index, extend=extend.none, color=_col, width=amyKeyV2_lineWidth)
        else
            line.set_xy1(_ln, _left, _price)
            line.set_xy2(_ln, _right, _price)
            line.set_color(_ln, _col)
            line.set_width(_ln, amyKeyV2_lineWidth)
            line.set_style(_ln, line.style_solid)

        if amyKeyV2_showLabels
            if na(_lb)
                _lb := label.new(_right, _price, _txt, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(_col, 82), textcolor=_col, size=size.tiny)
            else
                label.set_xy(_lb, _right, _price)
                label.set_text(_lb, _txt)
                label.set_color(_lb, color.new(_col, 82))
                label.set_textcolor(_lb, _col)
                label.set_size(_lb, size.tiny)
        else
            if not na(_lb)
                label.delete(_lb)
                _lb := na
    else
        if not na(_ln)
            line.delete(_ln)
            _ln := na
        if not na(_lb)
            label.delete(_lb)
            _lb := na

    array.set(amyKeyV2_lines, _idx, _ln)
    array.set(amyKeyV2_labels, _idx, _lb)

amyKeyV2_draw(0, amyKeyV2_midnightOpen, "MO", color.new(color.yellow, 0), amyKeyV2_showMO)
amyKeyV2_draw(1, amyKeyV2_pdh, "PDH", color.new(color.red, 0), amyKeyV2_showPDH)
amyKeyV2_draw(2, amyKeyV2_pdl, "PDL", color.new(color.lime, 0), amyKeyV2_showPDL)
amyKeyV2_draw(3, amyKeyV2_bsl, "BSL", color.new(color.fuchsia, 0), amyKeyV2_showBSL)
amyKeyV2_draw(4, amyKeyV2_ssl, "SSL", color.new(color.aqua, 0), amyKeyV2_showSSL)


//==================== AMY DASHBOARD BIAS V2 ====================//

amyDashV2_group = "AMY Dashboard Bias V2"
amyDashV2_show = input.bool(true, "Show Dashboard", group=amyDashV2_group)
amyDashV2_posInput = input.string("Bottom Right", "Dashboard Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=amyDashV2_group)
amyDashV2_swingLen = input.int(3, "M15 Protected Swing Length", minval=2, maxval=10, group=amyDashV2_group)
amyDashV2_sweepFreshBars = input.int(8, "Sweep Fresh Bars", minval=3, maxval=30, group=amyDashV2_group)
amyDashV2_nearInvalidAtr = input.float(0.35, "Near Invalid ATR", minval=0.05, maxval=2.0, step=0.05, group=amyDashV2_group)
amyDashV2_dispMult = input.float(1.20, "Displacement Body Mult", minval=0.80, maxval=3.0, step=0.05, group=amyDashV2_group)
amyDashV2_minSweepTicks = input.int(1, "False Sweep Filter Ticks", minval=0, maxval=20, group=amyDashV2_group)

amyDashV2_pos(_pos) =>
    _pos == "Top Left" ? position.top_left :
     _pos == "Bottom Right" ? position.bottom_right :
     _pos == "Bottom Left" ? position.bottom_left :
     position.top_right

amyDashV2_price(_x) =>
    na(_x) ? "-" : str.tostring(_x, format.mintick)

amyDashV2_range(_a, _b) =>
    na(_a) or na(_b) ? "-" : amyDashV2_price(math.max(_a, _b)) + " - " + amyDashV2_price(math.min(_a, _b))

amyDashV2_dist(_price, _current) =>
    na(_price) or na(_current) ? "-" : amyDashV2_price(math.abs(_current - _price))

amyDashV2_join(_a, _b) =>
    _a == "" ? _b : _b == "" ? _a : _a + " | " + _b

amyDashV2_clip(_s, _max) =>
    str.length(_s) > _max ? str.substring(_s, 0, _max) + "..." : _s

amyDashV2_engine(_swingLen, _freshBars, _nearAtr, _dispMult, _minSweepTicks) =>
    var float _lastPH = na
    var float _lastPL = na
    var int _biasDir = 0
    var int _mssDir = 0
    var float _lockedInvalid = na
    var float _rangeHigh = na
    var float _rangeLow = na
    var int _lastSweepDir = 0
    var int _lastSweepBar = na
    var float _sweptPrice = na
    var float _sweepExtreme = na
    var float _bullFvgTop = na
    var float _bullFvgBtm = na
    var int _bullFvgStatus = 0
    var float _bearFvgTop = na
    var float _bearFvgBtm = na
    var int _bearFvgStatus = 0
    var float _bullObTop = na
    var float _bullObBtm = na
    var int _bullObStatus = 0
    var float _bearObTop = na
    var float _bearObBtm = na
    var int _bearObStatus = 0

    _o = open
    _h = high
    _l = low
    _c = close
    _pc = close[1]
    _bi = bar_index[1]
    _atr = ta.atr(14)[1]
    _body = math.abs(close[1] - open[1])
    _meanBody = ta.sma(math.abs(close - open), 20)[1]

    _ph = ta.pivothigh(high, _swingLen, _swingLen)[1]
    _pl = ta.pivotlow(low, _swingLen, _swingLen)[1]

    if not na(_ph)
        _lastPH := _ph

    if not na(_pl)
        _lastPL := _pl

    _bullMss = not na(_lastPH) and not na(_lastPL) and _c > _lastPH and _pc <= _lastPH
    _bearMss = not na(_lastPH) and not na(_lastPL) and _c < _lastPL and _pc >= _lastPL

    _invalidNow = false
    _biasChanged = false

    if _biasDir == 1 and not na(_lockedInvalid) and _c < _lockedInvalid
        _invalidNow := true
        if _bearMss
            _biasDir := -1
            _mssDir := -1
            _lockedInvalid := _lastPH
            _rangeHigh := _lastPH
            _rangeLow := math.min(_lastPL, _l)
        else
            _biasDir := 0
            _mssDir := 0
        _biasChanged := true

    else if _biasDir == -1 and not na(_lockedInvalid) and _c > _lockedInvalid
        _invalidNow := true
        if _bullMss
            _biasDir := 1
            _mssDir := 1
            _lockedInvalid := _lastPL
            _rangeHigh := math.max(_lastPH, _h)
            _rangeLow := _lastPL
        else
            _biasDir := 0
            _mssDir := 0
        _biasChanged := true

    else if _bullMss and _biasDir != 1
        _biasDir := 1
        _mssDir := 1
        _lockedInvalid := _lastPL
        _rangeHigh := math.max(_lastPH, _h)
        _rangeLow := _lastPL
        _biasChanged := true

    else if _bearMss and _biasDir != -1
        _biasDir := -1
        _mssDir := -1
        _lockedInvalid := _lastPH
        _rangeHigh := _lastPH
        _rangeLow := math.min(_lastPL, _l)
        _biasChanged := true

    else if _bullMss and _biasDir == 1
        _mssDir := 1
        _rangeHigh := na(_rangeHigh) ? math.max(_lastPH, _h) : math.max(_rangeHigh, _h)

    else if _bearMss and _biasDir == -1
        _mssDir := -1
        _rangeLow := na(_rangeLow) ? math.min(_lastPL, _l) : math.min(_rangeLow, _l)

    if _biasChanged
        _lastSweepDir := 0
        _lastSweepBar := na
        _sweptPrice := na
        _sweepExtreme := na

    _nearInvalid = _biasDir == 1 and not na(_lockedInvalid) ? _c <= _lockedInvalid + _atr * _nearAtr :
     _biasDir == -1 and not na(_lockedInvalid) ? _c >= _lockedInvalid - _atr * _nearAtr :
     false

    _invalidStatus = _biasDir == 0 and _invalidNow ? 2 : _nearInvalid ? 1 : _biasDir != 0 ? 0 : 3

    _bsl = _lastPH
    _ssl = _lastPL
    _sweepMin = syminfo.mintick * _minSweepTicks

    _bslSweepNow = not na(_bsl) and _h > _bsl and _c < _bsl and (_h - _bsl) >= _sweepMin
    _sslSweepNow = not na(_ssl) and _l < _ssl and _c > _ssl and (_ssl - _l) >= _sweepMin

    if _sslSweepNow and not _bslSweepNow
        _lastSweepDir := 1
        _lastSweepBar := _bi
        _sweptPrice := _ssl
        _sweepExtreme := _l

    if _bslSweepNow and not _sslSweepNow
        _lastSweepDir := -1
        _lastSweepBar := _bi
        _sweptPrice := _bsl
        _sweepExtreme := _h

    _sweepInvalidNow = (_lastSweepDir == 1 and not na(_sweptPrice) and _c < _sweptPrice) or (_lastSweepDir == -1 and not na(_sweptPrice) and _c > _sweptPrice)

    if _sweepInvalidNow
        _lastSweepDir := 0
        _lastSweepBar := na

    _sweepFresh = not na(_lastSweepBar) and _bi - _lastSweepBar <= _freshBars
    _sweepOld = not na(_lastSweepBar) and _bi - _lastSweepBar > _freshBars
    _sweepStatus = _sweepInvalidNow ? 3 : _sweepFresh ? 1 : _sweepOld ? 2 : 0

    _dolDir = _sweepFresh and _lastSweepDir == 1 and not na(_bsl) ? 1 :
     _sweepFresh and _lastSweepDir == -1 and not na(_ssl) ? -1 :
     0

    _dolTarget = _dolDir == 1 ? _bsl : _dolDir == -1 ? _ssl : na
    _dolReached = (_dolDir == 1 and _h >= _dolTarget) or (_dolDir == -1 and _l <= _dolTarget)
    _dolStatus = _dolDir == 0 ? 0 : _dolReached ? 2 : 1
    _dolDistance = na(_dolTarget) ? na : math.abs(_dolTarget - _c)
    _dolAlign = _dolDir == 0 or _biasDir == 0 ? 0 : _dolDir == _biasDir ? 1 : -1

    _bullFvgNew = not na(high[3]) and low[1] > high[3]
    _bearFvgNew = not na(low[3]) and high[1] < low[3]

    if _bullFvgNew
        _bullFvgTop := low[1]
        _bullFvgBtm := high[3]
        _bullFvgStatus := 1

    if _bearFvgNew
        _bearFvgTop := low[3]
        _bearFvgBtm := high[1]
        _bearFvgStatus := 1

    _bullFvgTouched = _bullFvgStatus > 0 and _bullFvgStatus < 4 and not na(_bullFvgTop) and not na(_bullFvgBtm) and _l <= _bullFvgTop and _h >= _bullFvgBtm
    _bearFvgTouched = _bearFvgStatus > 0 and _bearFvgStatus < 4 and not na(_bearFvgTop) and not na(_bearFvgBtm) and _h >= _bearFvgBtm and _l <= _bearFvgTop

    if _bullFvgStatus > 0 and _bullFvgStatus < 4 and not na(_bullFvgBtm)
        if _c < _bullFvgBtm
            _bullFvgStatus := 4
        else if _bullFvgTouched
            _bullFvgStatus := 2
        else if _bullFvgStatus == 2
            _bullFvgStatus := 3

    if _bearFvgStatus > 0 and _bearFvgStatus < 4 and not na(_bearFvgTop)
        if _c > _bearFvgTop
            _bearFvgStatus := 4
        else if _bearFvgTouched
            _bearFvgStatus := 2
        else if _bearFvgStatus == 2
            _bearFvgStatus := 3

    _bullDisp = _c > _o and _body > _meanBody * _dispMult and _c > high[2]
    _bearDisp = _c < _o and _body > _meanBody * _dispMult and _c < low[2]

    if _bullDisp
        _bullObTop := close[2] < open[2] ? open[2] : open[1]
        _bullObBtm := close[2] < open[2] ? low[2] : low[1]
        _bullObStatus := 1

    if _bearDisp
        _bearObTop := close[2] > open[2] ? high[2] : high[1]
        _bearObBtm := close[2] > open[2] ? open[2] : open[1]
        _bearObStatus := 1

    _bullObTouched = _bullObStatus > 0 and _bullObStatus < 4 and not na(_bullObTop) and not na(_bullObBtm) and _l <= math.max(_bullObTop, _bullObBtm) and _h >= math.min(_bullObTop, _bullObBtm)
    _bearObTouched = _bearObStatus > 0 and _bearObStatus < 4 and not na(_bearObTop) and not na(_bearObBtm) and _h >= math.min(_bearObTop, _bearObBtm) and _l <= math.max(_bearObTop, _bearObBtm)

    if _bullObStatus > 0 and _bullObStatus < 4 and not na(_bullObBtm)
        if _c < math.min(_bullObTop, _bullObBtm)
            _bullObStatus := 4
        else if _bullObTouched
            _bullObStatus := 2
        else if _bullObStatus == 2
            _bullObStatus := 3

    if _bearObStatus > 0 and _bearObStatus < 4 and not na(_bearObTop)
        if _c > math.max(_bearObTop, _bearObBtm)
            _bearObStatus := 4
        else if _bearObTouched
            _bearObStatus := 2
        else if _bearObStatus == 2
            _bearObStatus := 3

    _rh = not na(_rangeHigh) and not na(_rangeLow) ? math.max(_rangeHigh, _rangeLow) : na
    _rl = not na(_rangeHigh) and not na(_rangeLow) ? math.min(_rangeHigh, _rangeLow) : na
    _rs = not na(_rh) and not na(_rl) ? math.max(_rh - _rl, syminfo.mintick) : na
    _eq = not na(_rs) ? _rl + _rs * 0.50 : na
    _eqLow = not na(_rs) ? _rl + _rs * 0.48 : na
    _eqHigh = not na(_rs) ? _rl + _rs * 0.52 : na

    _priceZone = na(_eqLow) or na(_eqHigh) ? 0 : _c > _eqHigh ? 1 : _c < _eqLow ? -1 : 0
    _locStatus = _biasDir == 1 and _priceZone == -1 ? 1 :
     _biasDir == 1 and _priceZone == 1 ? -1 :
     _biasDir == -1 and _priceZone == 1 ? 1 :
     _biasDir == -1 and _priceZone == -1 ? -1 :
     0

    _bullObActive = _bullObStatus > 0 and _bullObStatus < 4
    _bullFvgActive = _bullFvgStatus > 0 and _bullFvgStatus < 4
    _bearObActive = _bearObStatus > 0 and _bearObStatus < 4
    _bearFvgActive = _bearFvgStatus > 0 and _bearFvgStatus < 4

    _bullObHigh = _bullObActive ? math.max(_bullObTop, _bullObBtm) : na
    _bullObLow = _bullObActive ? math.min(_bullObTop, _bullObBtm) : na
    _bullFvgHigh = _bullFvgActive ? math.max(_bullFvgTop, _bullFvgBtm) : na
    _bullFvgLow = _bullFvgActive ? math.min(_bullFvgTop, _bullFvgBtm) : na
    _bearObHigh = _bearObActive ? math.max(_bearObTop, _bearObBtm) : na
    _bearObLow = _bearObActive ? math.min(_bearObTop, _bearObBtm) : na
    _bearFvgHigh = _bearFvgActive ? math.max(_bearFvgTop, _bearFvgBtm) : na
    _bearFvgLow = _bearFvgActive ? math.min(_bearFvgTop, _bearFvgBtm) : na

    _bullObDist = _bullObActive ? (_c >= _bullObLow and _c <= _bullObHigh ? 0.0 : math.min(math.abs(_c - _bullObHigh), math.abs(_c - _bullObLow))) : na
    _bullFvgDist = _bullFvgActive ? (_c >= _bullFvgLow and _c <= _bullFvgHigh ? 0.0 : math.min(math.abs(_c - _bullFvgHigh), math.abs(_c - _bullFvgLow))) : na
    _bearObDist = _bearObActive ? (_c >= _bearObLow and _c <= _bearObHigh ? 0.0 : math.min(math.abs(_c - _bearObHigh), math.abs(_c - _bearObLow))) : na
    _bearFvgDist = _bearFvgActive ? (_c >= _bearFvgLow and _c <= _bearFvgHigh ? 0.0 : math.min(math.abs(_c - _bearFvgHigh), math.abs(_c - _bearFvgLow))) : na

    int _poiType = 0
    float _poiHigh = na
    float _poiLow = na
    int _poiStatus = 0

    if _biasDir == 1
        if _bullObActive and (not _bullFvgActive or _bullObDist <= _bullFvgDist)
            _poiType := 1
            _poiHigh := _bullObHigh
            _poiLow := _bullObLow
            _poiStatus := _bullObStatus
        else if _bullFvgActive
            _poiType := 2
            _poiHigh := _bullFvgHigh
            _poiLow := _bullFvgLow
            _poiStatus := _bullFvgStatus

    if _biasDir == -1
        if _bearObActive and (not _bearFvgActive or _bearObDist <= _bearFvgDist)
            _poiType := -1
            _poiHigh := _bearObHigh
            _poiLow := _bearObLow
            _poiStatus := _bearObStatus
        else if _bearFvgActive
            _poiType := -2
            _poiHigh := _bearFvgHigh
            _poiLow := _bearFvgLow
            _poiStatus := _bearFvgStatus

    _poiMid = not na(_poiHigh) and not na(_poiLow) ? (_poiHigh + _poiLow) / 2.0 : na
    _poiDist = not na(_poiHigh) and not na(_poiLow) ? (_c >= _poiLow and _c <= _poiHigh ? 0.0 : math.min(math.abs(_c - _poiHigh), math.abs(_c - _poiLow))) : na
    _poiAlign = _biasDir == 0 or _poiType == 0 ? 0 : (_biasDir == 1 and _poiType > 0) or (_biasDir == -1 and _poiType < 0) ? 1 : -1
    _poiLoc = na(_poiMid) or na(_eqLow) or na(_eqHigh) ? 0 : _poiMid > _eqHigh ? 1 : _poiMid < _eqLow ? -1 : 0
    _poiLocationOk = (_biasDir == 1 and _poiLoc == -1) or (_biasDir == -1 and _poiLoc == 1)
    _poiPriority = _poiType == 0 ? 0 : _poiAlign == 1 and _poiLocationOk and _dolAlign == 1 ? 2 : _poiAlign == 1 ? 1 : 0

    [_o, _h, _l, _c, _lastPH, _lastPL, _biasDir, _mssDir, _bullMss, _bearMss, _lockedInvalid, _invalidStatus, _rh, _rl, _eq, _eqLow, _eqHigh, _priceZone, _locStatus, _bsl, _ssl, _lastSweepDir, _sweepStatus, _sweptPrice, _sweepExtreme, _dolDir, _dolTarget, _dolStatus, _dolDistance, _dolAlign, _poiType, _poiHigh, _poiLow, _poiMid, _poiDist, _poiStatus, _poiAlign, _poiLoc, _poiPriority]

[amyDashV2_o15, amyDashV2_h15, amyDashV2_l15, amyDashV2_c15, amyDashV2_protectedHigh, amyDashV2_protectedLow, amyDashV2_biasDir, amyDashV2_mssDir, amyDashV2_bullMssNow, amyDashV2_bearMssNow, amyDashV2_invalidLevel, amyDashV2_invalidStatus, amyDashV2_rangeHigh, amyDashV2_rangeLow, amyDashV2_eq, amyDashV2_eqLow, amyDashV2_eqHigh, amyDashV2_priceZone, amyDashV2_locationStatus, amyDashV2_bsl, amyDashV2_ssl, amyDashV2_sweepDir, amyDashV2_sweepStatus, amyDashV2_sweptPrice, amyDashV2_sweepExtreme, amyDashV2_dolDir, amyDashV2_dolTarget, amyDashV2_dolStatus, amyDashV2_dolDistance, amyDashV2_dolAlign, amyDashV2_poiType, amyDashV2_poiHigh, amyDashV2_poiLow, amyDashV2_poiMid, amyDashV2_poiDistance, amyDashV2_poiStatus, amyDashV2_poiAlign, amyDashV2_poiLocation, amyDashV2_poiPriority] = request.security(syminfo.tickerid, "15", amyDashV2_engine(amyDashV2_swingLen, amyDashV2_sweepFreshBars, amyDashV2_nearInvalidAtr, amyDashV2_dispMult, amyDashV2_minSweepTicks), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

amyDashV2_biasText = amyDashV2_biasDir == 1 ? "BUY CTX" : amyDashV2_biasDir == -1 ? "SELL CTX" : "NO CLEAR BIAS"
amyDashV2_arahText = amyDashV2_biasDir == 1 ? "NAIK" : amyDashV2_biasDir == -1 ? "TURUN" : "BELUM JELAS"
amyDashV2_mssText = amyDashV2_mssDir == 1 ? "M15 Bullish" : amyDashV2_mssDir == -1 ? "M15 Bearish" : "M15 Neutral"

amyDashV2_sweepText = amyDashV2_sweepDir == 1 ? "SSL Swept" : amyDashV2_sweepDir == -1 ? "BSL Swept" : "None"
amyDashV2_sweepStatusText = amyDashV2_sweepStatus == 1 ? "Fresh" : amyDashV2_sweepStatus == 2 ? "Old" : amyDashV2_sweepStatus == 3 ? "Invalid" : "None"

amyDashV2_dolText = amyDashV2_dolDir == 1 ? "Draw to BSL" : amyDashV2_dolDir == -1 ? "Draw to SSL" : "Neutral"
amyDashV2_dolStatusText = amyDashV2_dolStatus == 2 ? "Reached" : amyDashV2_dolStatus == 1 ? "Active" : "Neutral"
amyDashV2_dolAlignText = amyDashV2_dolAlign == 1 ? "With Bias" : amyDashV2_dolAlign == -1 ? "Against Bias" : "Neutral"

amyDashV2_poiTypeText = amyDashV2_poiType == 1 ? "Bull OB" : amyDashV2_poiType == 2 ? "Bull FVG" : amyDashV2_poiType == -1 ? "Bear OB" : amyDashV2_poiType == -2 ? "Bear FVG" : "None"
amyDashV2_poiStatusText = amyDashV2_poiStatus == 1 ? "Fresh" : amyDashV2_poiStatus == 2 ? "Active" : amyDashV2_poiStatus == 3 ? "Mitigated" : amyDashV2_poiStatus == 4 ? "Failed" : "None"
amyDashV2_poiAlignText = amyDashV2_poiAlign == 1 ? "With Bias" : amyDashV2_poiAlign == -1 ? "Against Bias" : "Neutral"
amyDashV2_poiLocationText = amyDashV2_poiLocation == 1 ? "Premium" : amyDashV2_poiLocation == -1 ? "Discount" : "EQ Zone"
amyDashV2_poiPriorityText = amyDashV2_poiPriority == 2 ? "Main" : amyDashV2_poiPriority == 1 ? "Secondary" : "Ignore"

amyDashV2_priceLocationText = amyDashV2_priceZone == 1 ? "Premium" : amyDashV2_priceZone == -1 ? "Discount" : "EQ Zone"
amyDashV2_locationStatusText = amyDashV2_locationStatus == 1 ? "Healthy" : amyDashV2_locationStatus == -1 ? "Bad Location" : "Neutral"

amyDashV2_invalidText = amyDashV2_invalidStatus == 2 ? "Invalid" : amyDashV2_invalidStatus == 1 ? "Near Invalid" : amyDashV2_invalidStatus == 0 ? "Valid" : "No Bias"

amyDashV2_reason = ""
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_mssText)
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_sweepStatus == 1 ? amyDashV2_sweepText + " Fresh" : "")
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_dolStatus == 1 ? amyDashV2_dolText + " " + amyDashV2_price(amyDashV2_dolTarget) : "")
amyDashV2_reason := amyDashV2_join(amyDashV2_reason, amyDashV2_poiPriority == 2 ? amyDashV2_poiTypeText + " Main" : "")
amyDashV2_reason := amyDashV2_reason == "" ? "Belum ada alasan kuat" : amyDashV2_reason

amyDashV2_headBg = color.new(#07111D, 0)
amyDashV2_keyBg = color.new(#0B1623, 0)
amyDashV2_cellBg = color.new(#050B12, 0)
amyDashV2_buyBg = color.new(color.lime, 25)
amyDashV2_sellBg = color.new(color.red, 22)
amyDashV2_neutralBg = color.new(color.gray, 55)
amyDashV2_warnBg = color.new(color.orange, 20)

amyDashV2_biasBg = amyDashV2_biasDir == 1 ? amyDashV2_buyBg : amyDashV2_biasDir == -1 ? amyDashV2_sellBg : amyDashV2_warnBg
amyDashV2_dolBg = amyDashV2_dolDir == 1 ? amyDashV2_buyBg : amyDashV2_dolDir == -1 ? amyDashV2_sellBg : amyDashV2_neutralBg
amyDashV2_invalidBg = amyDashV2_invalidStatus == 2 ? amyDashV2_sellBg : amyDashV2_invalidStatus == 1 ? amyDashV2_warnBg : amyDashV2_invalidStatus == 0 ? amyDashV2_buyBg : amyDashV2_neutralBg
amyDashV2_locBg = amyDashV2_locationStatus == 1 ? amyDashV2_buyBg : amyDashV2_locationStatus == -1 ? amyDashV2_warnBg : amyDashV2_neutralBg
amyDashV2_poiBg = amyDashV2_poiPriority == 2 ? (amyDashV2_poiType > 0 ? amyDashV2_buyBg : amyDashV2_sellBg) : amyDashV2_poiPriority == 1 ? amyDashV2_warnBg : amyDashV2_neutralBg

var table amyDashV2_table = table.new(amyDashV2_pos(amyDashV2_posInput), 2, 16, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 55))

if amyDashV2_show and barstate.islast
    table.clear(amyDashV2_table, 0, 0, 1, 15)

    table.cell(amyDashV2_table, 0, 0, "AMY BIAS DASHBOARD V2", text_color=color.white, bgcolor=amyDashV2_headBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 0, "M15 CLOSED", text_color=color.white, bgcolor=amyDashV2_headBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 1, "BIAS", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 1, amyDashV2_biasText + " | " + amyDashV2_arahText, text_color=color.white, bgcolor=amyDashV2_biasBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 2, "STRUKTUR", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 2, amyDashV2_mssText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 3, "PROTECTED", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 3, "H " + amyDashV2_price(amyDashV2_protectedHigh) + " | L " + amyDashV2_price(amyDashV2_protectedLow), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 4, "LIQUIDITY", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 4, "BSL " + amyDashV2_price(amyDashV2_bsl) + " | SSL " + amyDashV2_price(amyDashV2_ssl), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 5, "SWEEP", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 5, amyDashV2_sweepText + " | " + amyDashV2_sweepStatusText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 6, "SWEEP PRICE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 6, "Swept " + amyDashV2_price(amyDashV2_sweptPrice) + " | Extreme " + amyDashV2_price(amyDashV2_sweepExtreme), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 7, "DOL", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 7, amyDashV2_dolText + " @ " + amyDashV2_price(amyDashV2_dolTarget) + " | " + amyDashV2_dolStatusText, text_color=color.white, bgcolor=amyDashV2_dolBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 8, "DOL DETAIL", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 8, "Dist " + amyDashV2_price(amyDashV2_dolDistance) + " | " + amyDashV2_dolAlignText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 9, "POI", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 9, amyDashV2_poiTypeText + " | " + amyDashV2_poiStatusText + " | " + amyDashV2_poiPriorityText, text_color=color.white, bgcolor=amyDashV2_poiBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 10, "POI PRICE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 10, amyDashV2_range(amyDashV2_poiHigh, amyDashV2_poiLow) + " | CE " + amyDashV2_price(amyDashV2_poiMid), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 11, "POI DETAIL", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 11, "Dist " + amyDashV2_price(amyDashV2_poiDistance) + " | " + amyDashV2_poiAlignText + " | " + amyDashV2_poiLocationText, text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 12, "POSISI", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 12, amyDashV2_priceLocationText + " | " + amyDashV2_locationStatusText, text_color=color.white, bgcolor=amyDashV2_locBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 13, "RANGE", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 13, "H " + amyDashV2_price(amyDashV2_rangeHigh) + " | L " + amyDashV2_price(amyDashV2_rangeLow) + " | EQ " + amyDashV2_range(amyDashV2_eqHigh, amyDashV2_eqLow), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 14, "INVALID", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 14, amyDashV2_invalidText + " | Level " + amyDashV2_price(amyDashV2_invalidLevel) + " | Dist " + amyDashV2_dist(amyDashV2_invalidLevel, amyDashV2_c15), text_color=color.white, bgcolor=amyDashV2_invalidBg, text_size=size.tiny)

    table.cell(amyDashV2_table, 0, 15, "ALASAN INTI", text_color=color.white, bgcolor=amyDashV2_keyBg, text_size=size.tiny)
    table.cell(amyDashV2_table, 1, 15, amyDashV2_clip(amyDashV2_reason, 85), text_color=color.white, bgcolor=amyDashV2_cellBg, text_size=size.tiny)

if not amyDashV2_show and barstate.islast
    table.clear(amyDashV2_table, 0, 0, 1, 15)