nx_sell_proj_high_plot = plot(nx_show_proj_zone and nx_show_zones and nx_bear_setup_armed ? nx_sell_zone_high : na, "NX Sell Proj High", color=color.new(color.red, 80), style=plot.style_linebr, linewidth=1)
fill(nx_sell_proj_low_plot, nx_sell_proj_high_plot, color=color.new(color.red, 92), title="NX Sell Proj Fill")

nx_buy_exec_low_plot  = plot(nx_show_exec_zone and nx_show_zones and nx_bull_setup_armed ? nx_buy_exec_low : na, "NX Buy Exec Low", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
nx_buy_exec_high_plot = plot(nx_show_exec_zone and nx_show_zones and nx_bull_setup_armed ? nx_buy_exec_high : na, "NX Buy Exec High", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
fill(nx_buy_exec_low_plot, nx_buy_exec_high_plot, color=color.new(color.green, 84), title="NX Buy Exec Fill")

nx_sell_exec_low_plot  = plot(nx_show_exec_zone and nx_show_zones and nx_bear_setup_armed ? nx_sell_exec_low : na, "NX Sell Exec Low", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
nx_sell_exec_high_plot = plot(nx_show_exec_zone and nx_show_zones and nx_bear_setup_armed ? nx_sell_exec_high : na, "NX Sell Exec High", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
fill(nx_sell_exec_low_plot, nx_sell_exec_high_plot, color=color.new(color.red, 84), title="NX Sell Exec Fill")

plotshape(series=nx_show_signals and nx_ready_buy,  title="NX READY BUY",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="BUY",  textcolor=color.white)
plotshape(series=nx_show_signals and nx_ready_sell, title="NX READY SELL", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),   size=size.small, text="SELL", textcolor=color.white)

// ===== OBJECT STORAGE =====
var line  nx_ln_ep   = na
var line  nx_ln_sl   = na
var line  nx_ln_tp1  = na
var line  nx_ln_tp2  = na
var line  nx_ln_tp3  = na
var label nx_lb_ep   = na
var label nx_lb_sl   = na
var label nx_lb_tp1  = na
var label nx_lb_tp2  = na
var label nx_lb_tp3  = na
var line  nx_path_1  = na
var line  nx_path_2  = na

var int   nx_plan_dir   = 0
var int   nx_plan_mode  = 0   // 0 none, 1 mapping buy, 2 ready buy, -1 mapping sell, -2 ready sell
var float nx_plan_ep    = na
var float nx_plan_sl    = na
var float nx_plan_tp1   = na
var float nx_plan_tp2   = na
var float nx_plan_tp3   = na

// ===== PLAN VALUES =====
int nx_new_mode =
     nx_ready_buy  ?  2 :
     nx_ready_sell ? -2 :
     nx_bull_setup_armed ?  1 :
     nx_bear_setup_armed ? -1 : 0

int nx_new_dir = nx_new_mode > 0 ? 1 : nx_new_mode < 0 ? -1 : 0
bool nx_new_ready = math.abs(nx_new_mode) == 2

float nx_new_ep =
     nx_new_dir == 1  ? nx_buy_exec_mid :
     nx_new_dir == -1 ? nx_sell_exec_mid : na

float nx_new_sl =
     nx_new_dir == 1  ? nx_long_invalid :
     nx_new_dir == -1 ? nx_short_invalid : na

float nx_new_tp1 =
     nx_new_dir == 1  ? nx_long_tp1 :
     nx_new_dir == -1 ? nx_short_tp1 : na

float nx_new_tp2 =
     nx_new_dir == 1  ? nx_long_tp2 :
     nx_new_dir == -1 ? nx_short_tp2 : na

float nx_new_tp3 =
     nx_new_dir == 1  ? nx_long_tp3 :
     nx_new_dir == -1 ? nx_short_tp3 : na

bool nx_has_objects =
     not na(nx_ln_ep) or not na(nx_ln_sl) or not na(nx_ln_tp1) or not na(nx_ln_tp2) or not na(nx_ln_tp3) or
     not na(nx_lb_ep) or not na(nx_lb_sl) or not na(nx_lb_tp1) or not na(nx_lb_tp2) or not na(nx_lb_tp3) or
     not na(nx_path_1) or not na(nx_path_2)

bool nx_refresh = false
nx_refresh :=
     nx_new_mode != nx_plan_mode or
     nx_new_dir  != nx_plan_dir  or
     (nx_new_dir != 0 and (
         na(nx_plan_ep) or
         math.abs(nx_new_ep  - nx_plan_ep)  > syminfo.mintick * 2 or
         math.abs(nx_new_sl  - nx_plan_sl)  > syminfo.mintick * 2 or
         math.abs(nx_new_tp1 - nx_plan_tp1) > syminfo.mintick * 2
     ))

// ===== REFRESH OBJECTS =====
if barstate.isconfirmed and (nx_refresh or (not nx_show_plan and nx_has_objects))
    if not na(nx_ln_ep)
        line.delete(nx_ln_ep)
    if not na(nx_ln_sl)
        line.delete(nx_ln_sl)
    if not na(nx_ln_tp1)
        line.delete(nx_ln_tp1)
    if not na(nx_ln_tp2)
        line.delete(nx_ln_tp2)
    if not na(nx_ln_tp3)
        line.delete(nx_ln_tp3)

    if not na(nx_lb_ep)
        label.delete(nx_lb_ep)
    if not na(nx_lb_sl)
        label.delete(nx_lb_sl)
    if not na(nx_lb_tp1)
        label.delete(nx_lb_tp1)
    if not na(nx_lb_tp2)
        label.delete(nx_lb_tp2)
    if not na(nx_lb_tp3)
        label.delete(nx_lb_tp3)

    if not na(nx_path_1)
        line.delete(nx_path_1)
    if not na(nx_path_2)
        line.delete(nx_path_2)

    nx_ln_ep  := na
    nx_ln_sl  := na
    nx_ln_tp1 := na
    nx_ln_tp2 := na
    nx_ln_tp3 := na
    nx_lb_ep  := na
    nx_lb_sl  := na
    nx_lb_tp1 := na
    nx_lb_tp2 := na
    nx_lb_tp3 := na
    nx_path_1 := na
    nx_path_2 := na

    if nx_show_plan and nx_new_dir != 0 and not na(nx_new_ep)
        color nx_col_ep   = nx_new_dir == 1 ? color.new(color.orange, 0) : color.new(color.orange, 0)
        color nx_col_sl   = color.new(color.red, 0)
        color nx_col_tp12 = color.new(color.blue, 0)
        color nx_col_tp3  = color.new(color.purple, 0)

        line_style_ep  = nx_new_ready ? line.style_solid  : line.style_dashed
        line_style_sl  = nx_new_ready ? line.style_solid  : line.style_dotted
        line_style_tp  = nx_new_ready ? line.style_solid  : line.style_dashed
        line_style_tp3 = line.style_dashed

        string nx_ep_text = nx_new_ready ? (nx_new_dir == 1 ? "READY BUY" : "READY SELL") : (nx_new_dir == 1 ? "PLAN BUY" : "PLAN SELL")
        string nx_ep_note = nx_new_ready ? " [" + nx_trigger_name + "]" : " [ZONE MID]"

        nx_ln_ep  := line.new(bar_index, nx_new_ep,  bar_index + nx_plan_bars, nx_new_ep,  color=nx_col_ep,   style=line_style_ep,  extend=extend.right)
        nx_ln_sl  := line.new(bar_index, nx_new_sl,  bar_index + nx_plan_bars, nx_new_sl,  color=nx_col_sl,   style=line_style_sl,  extend=extend.right)
        nx_ln_tp1 := line.new(bar_index, nx_new_tp1, bar_index + nx_plan_bars, nx_new_tp1, color=nx_col_tp12, style=line_style_tp,  extend=extend.right)
        nx_ln_tp2 := line.new(bar_index, nx_new_tp2, bar_index + nx_plan_bars, nx_new_tp2, color=nx_col_tp12, style=line_style_tp,  extend=extend.right)
        nx_ln_tp3 := line.new(bar_index, nx_new_tp3, bar_index + nx_plan_bars, nx_new_tp3, color=nx_col_tp3,  style=line_style_tp3, extend=extend.right)

        nx_lb_ep  := label.new(bar_index + nx_plan_bars, nx_new_ep,  nx_ep_text + nx_ep_note + " : " + nx_price(nx_new_ep), color=nx_col_ep,   textcolor=color.white, style=label.style_label_left, size=size.small)
        nx_lb_sl  := label.new(bar_index + nx_plan_bars, nx_new_sl,  "Invalidation : " + nx_price(nx_new_sl),               color=nx_col_sl,   textcolor=color.white, style=label.style_label_left, size=size.small)
        nx_lb_tp1 := label.new(bar_index + nx_plan_bars, nx_new_tp1, "TP1 : " + nx_price(nx_new_tp1),                       color=nx_col_tp12, textcolor=color.white, style=label.style_label_left, size=size.small)
        nx_lb_tp2 := label.new(bar_index + nx_plan_bars, nx_new_tp2, "TP2 : " + nx_price(nx_new_tp2),                       color=nx_col_tp12, textcolor=color.white, style=label.style_label_left, size=size.small)
        nx_lb_tp3 := label.new(bar_index + nx_plan_bars, nx_new_tp3, "TP3 : " + nx_price(nx_new_tp3),                       color=nx_col_tp3,  textcolor=color.white, style=label.style_label_left, size=size.small)

        if nx_show_path
            float nx_path_mid = nx_new_ep
            float nx_path_tp  = nx_new_dir == 1 ? nx_long_tp1 : nx_short_tp1
            color nx_path_col = nx_new_dir == 1 ? color.new(color.green, 0) : color.new(color.red, 0)

            nx_path_1 := line.new(bar_index, close, bar_index + 8, nx_path_mid, color=nx_path_col, width=2, style=line.style_dotted)
            nx_path_2 := line.new(bar_index + 8, nx_path_mid, bar_index + 20, nx_path_tp, color=color.new(color.blue, 0), width=2, style=line.style_dashed)

    nx_plan_mode := nx_new_mode
    nx_plan_dir  := nx_new_dir
    nx_plan_ep   := nx_new_ep
    nx_plan_sl   := nx_new_sl
    nx_plan_tp1  := nx_new_tp1
    nx_plan_tp2  := nx_new_tp2
    nx_plan_tp3  := nx_new_tp3

//==================== SECTION 5 - SMART DASHBOARD ====================//
groupNX5 = "NX 5. Smart Dashboard"
nx_show_dash        = input.bool(true,  "Tampilkan smart dashboard",                group=groupNX5)
nx_dash_pos_input   = input.string("Bottom Left", "Dashboard Position",             options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=groupNX5)
nx_dash_style       = input.string("Mobile", "Dashboard Style",                     options=["Mobile", "Desktop"], group=groupNX5)

nx_buy_poi_ok  = not na(nx_bull_ob_low) or not na(nx_bull_fvg_low)
nx_sell_poi_ok = not na(nx_bear_ob_low) or not na(nx_bear_fvg_low)

nx_score = 0
nx_score += (nx_bull_setup_armed or nx_bear_setup_armed) ? 20 : 0
nx_score += nx_session_ok ? 10 : 0
nx_score += (nx_htf_bull_active or nx_htf_bear_active) ? 10 : 0
nx_score += (nx_bull_structure or nx_bear_structure) ? 10 : 0
nx_score += (nx_buy_pd_ok or nx_sell_pd_ok) ? 10 : 0
nx_score += (nx_buy_zone_source != "Projected Fib" or nx_sell_zone_source != "Projected Fib") ? 10 : 5
nx_score += (nx_in_buy_zone or nx_in_sell_zone) ? 10 : (nx_near_buy_zone or nx_near_sell_zone) ? 6 : 0
nx_score += (nx_ready_buy or nx_ready_sell) ? 15 : (nx_any_bull_trigger or nx_any_bear_trigger) ? 8 : 0
nx_score += (nx_judas_bull or nx_judas_bear) ? 5 : 0
nx_score := int(nx_clamp(nx_score, 0, 100))
nx_grade_text = nx_grade(nx_score)

nx_state_text =
     not nx_dr_valid ? "WAIT RANGE" :
     nx_ready_buy ? "TRIGGER READY BUY" :
     nx_ready_sell ? "TRIGGER READY SELL" :
     nx_bull_setup_armed and nx_in_buy_zone ? "IN BUY ZONE" :
     nx_bear_setup_armed and nx_in_sell_zone ? "IN SELL ZONE" :
     nx_bull_setup_armed and nx_near_buy_zone ? "NEAR BUY ZONE" :
     nx_bear_setup_armed and nx_near_sell_zone ? "NEAR SELL ZONE" :
     nx_bull_setup_armed ? "MAPPING BUY" :
     nx_bear_setup_armed ? "MAPPING SELL" :
     "WAIT"

nx_area_text =
     not nx_dr_valid ? "Range terlalu sempit. Hindari entry." :
     nx_pd_text == "Discount" ? "Harga berada di area Discount dari dealing range." :
     nx_pd_text == "Premium" ? "Harga berada di area Premium dari dealing range." :
     "Harga berada di Equilibrium."

nx_poi_text =
     nx_bull_setup_armed ? (nx_buy_zone_source == "OB + FVG" ? "Bull OB + FVG" : nx_buy_zone_source) :
     nx_bear_setup_armed ? (nx_sell_zone_source == "OB + FVG" ? "Bear OB + FVG" : nx_sell_zone_source) :
     "No Active POI"

nx_zone_line =
     nx_bull_setup_armed ? "BUY " + nx_price(nx_buy_exec_low) + " - " + nx_price(nx_buy_exec_high) :
     nx_bear_setup_armed ? "SELL " + nx_price(nx_sell_exec_low) + " - " + nx_price(nx_sell_exec_high) :
     "-"

nx_plan_text =
     nx_ready_buy ? "Ready BUY. Tunggu disiplin manajemen risiko." :
     nx_ready_sell ? "Ready SELL. Tunggu disiplin manajemen risiko." :
     nx_bull_setup_armed ? "Pantau retrace ke buy execution zone." :
     nx_bear_setup_armed ? "Pantau retrace ke sell execution zone." :
     "Belum ada rencana eksekusi."

nx_note_text =
     nx_ready_buy ? "Bias HTF bullish, zona valid, trigger confirmed." :
     nx_ready_sell ? "Bias HTF bearish, zona valid, trigger confirmed." :
     nx_bull_setup_armed ? "Bias bullish aktif, tunggu trigger di zone." :
     nx_bear_setup_armed ? "Bias bearish aktif, tunggu trigger di zone." :
     "Market masih mixed / belum siap."

var table nx_dash = table.new(nx_dash_pos(nx_dash_pos_input), nx_dash_style == "Mobile" ? 1 : 2, nx_dash_style == "Mobile" ? 8 : 8, border_width=1, border_color=color.rgb(90, 90, 90), frame_color=color.rgb(60, 60, 60), frame_width=1)

if nx_show_dash and barstate.islast
    color nx_header_bg = color.rgb(70, 95, 150)
    color nx_key_bg    = color.rgb(70, 70, 80)
    color nx_value_bg  = color.rgb(210, 210, 210)
    color nx_bias_bg   = nx_bull_bias ? color.rgb(80, 130, 80) : nx_bear_bias ? color.rgb(145, 75, 75) : color.rgb(110, 110, 110)
    color nx_state_bg  = nx_ready_buy or nx_ready_sell ? color.rgb(50, 150, 50) : not nx_dr_valid ? color.rgb(145, 75, 75) : color.rgb(170, 120, 50)

    if nx_dash_style == "Mobile"
        table.cell(nx_dash, 0, 0, "NX SMART CONTEXT | " + timeframe.period, text_color=color.white, bgcolor=nx_header_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 1, "Bias: " + nx_bias_text + " | " + nx_structure_text, text_color=color.white, bgcolor=nx_bias_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 2, "Session: " + (nx_in_asia ? "Asia" : nx_in_london ? "London" : nx_in_newyork ? "NY" : "Off") + " | HTF PD: " + nx_htf_pd + " | Entry PD: " + nx_pd_text, text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 3, "State: " + nx_state_text, text_color=color.white, bgcolor=nx_state_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 4, "Zone: " + nx_zone_line + " | POI: " + nx_poi_text, text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 5, "SL: " + (nx_bull_setup_armed ? nx_price(nx_long_invalid) : nx_bear_setup_armed ? nx_price(nx_short_invalid) : "-") + " | TP1/TP2/TP3: " + (nx_bull_setup_armed ? nx_price(nx_long_tp1) + " / " + nx_price(nx_long_tp2) + " / " + nx_price(nx_long_tp3) : nx_bear_setup_armed ? nx_price(nx_short_tp1) + " / " + nx_price(nx_short_tp2) + " / " + nx_price(nx_short_tp3) : "-"), text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 6, "Score: " + str.tostring(nx_score) + " | Grade: " + nx_grade_text + " | Trigger: " + (nx_trigger_name == "" ? "-" : nx_trigger_name), text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)
        table.cell(nx_dash, 0, 7, "Area: " + nx_area_text + "\nCatatan: " + nx_note_text + "\nRencana: " + nx_plan_text, text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)
    else
        table.cell(nx_dash, 0, 0, "NX SMART CONTEXT", text_color=color.white, bgcolor=nx_header_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 0, timeframe.period, text_color=color.white, bgcolor=nx_header_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 1, "Bias", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 1, nx_bias_text + " | " + nx_structure_text, text_color=color.white, bgcolor=nx_bias_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 2, "Session / PD", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 2, (nx_in_asia ? "Asia" : nx_in_london ? "London" : nx_in_newyork ? "NY" : "Off") + " | HTF " + nx_htf_pd + " | Entry " + nx_pd_text, text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 3, "State", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 3, nx_state_text, text_color=color.white, bgcolor=nx_state_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 4, "Zone / POI", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 4, nx_zone_line + " | " + nx_poi_text, text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 5, "SL / TP", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 5, (nx_bull_setup_armed ? "SL " + nx_price(nx_long_invalid) + " | TP " + nx_price(nx_long_tp1) + " / " + nx_price(nx_long_tp2) + " / " + nx_price(nx_long_tp3) : nx_bear_setup_armed ? "SL " + nx_price(nx_short_invalid) + " | TP " + nx_price(nx_short_tp1) + " / " + nx_price(nx_short_tp2) + " / " + nx_price(nx_short_tp3) : "-"), text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 6, "Score / Trigger", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 6, "Score " + str.tostring(nx_score) + " | " + nx_grade_text + " | " + (nx_trigger_name == "" ? "-" : nx_trigger_name), text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)

        table.cell(nx_dash, 0, 7, "Catatan", text_color=color.white, bgcolor=nx_key_bg, text_size=size.tiny)
        table.cell(nx_dash, 1, 7, nx_area_text + " | " + nx_note_text + " | " + nx_plan_text, text_color=color.black, bgcolor=nx_value_bg, text_size=size.tiny)
