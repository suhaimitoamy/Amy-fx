nx_buy_proj_high_plot = plot(nx_show_proj_zone and nx_show_zones and nx_bull_setup_armed ? nx_buy_zone_high : na, "NX Buy Proj High", color=color.new(color.green, 80), style=plot.style_linebr, linewidth=1)
fill(nx_buy_proj_low_plot, nx_buy_proj_high_plot, color=color.new(color.green, 92), title="NX Buy Proj Fill")

