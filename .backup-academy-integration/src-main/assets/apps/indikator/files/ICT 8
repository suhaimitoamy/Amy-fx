nx_overlap(_aLow, _aHigh, _bLow, _bHigh) =>
    not na(_aLow) and not na(_aHigh) and not na(_bLow) and not na(_bHigh) and math.max(_aLow, _bLow) <= math.min(_aHigh, _bHigh)

nx_inter_low(_aLow, _aHigh, _bLow, _bHigh) =>
    nx_overlap(_aLow, _aHigh, _bLow, _bHigh) ? math.max(_aLow, _bLow) : na

nx_inter_high(_aLow, _aHigh, _bLow, _bHigh) =>
    nx_overlap(_aLow, _aHigh, _bLow, _bHigh) ? math.min(_aHigh, _bHigh) : na

nx_clamp(_x, _lo, _hi) =>
