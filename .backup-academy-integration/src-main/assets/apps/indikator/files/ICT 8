plot(nx_show_levels and nx_dr_valid ? nx_active_sup : na, "NX Active Support", color=color.new(color.blue, 0), style=plot.style_linebr, linewidth=2)
plot(nx_show_levels and nx_dr_valid ? nx_active_res : na, "NX Active Resistance", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
plot(nx_show_asia_range and nx_asia_locked ? nx_asia_high : na, "NX Asia High", color=color.new(color.purple, 40), style=plot.style_linebr)
plot(nx_show_asia_range and nx_asia_locked ? nx_asia_low : na, "NX Asia Low", color=color.new(color.purple, 40), style=plot.style_linebr)

