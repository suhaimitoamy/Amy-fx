float nx_sell_exec_low = nx_sell_zone_low
float nx_sell_exec_high= nx_sell_zone_high

string nx_buy_zone_source  = "Projected Fib"
string nx_sell_zone_source = "Projected Fib"

if nx_refine_poi and nx_dr_valid
    bool nx_bull_ob_overlap  = nx_overlap(nx_bull_ob_low,  nx_bull_ob_high,  nx_buy_zone_low,  nx_buy_zone_high)
    bool nx_bull_fvg_overlap = nx_overlap(nx_bull_fvg_low, nx_bull_fvg_high, nx_buy_zone_low,  nx_buy_zone_high)

    if nx_bull_ob_overlap and nx_bull_fvg_overlap and nx_overlap(nx_bull_ob_low, nx_bull_ob_high, nx_bull_fvg_low, nx_bull_fvg_high)
        nx_buy_exec_low   := math.max(nx_buy_zone_low,  math.max(nx_bull_ob_low,  nx_bull_fvg_low))
        nx_buy_exec_high  := math.min(nx_buy_zone_high, math.min(nx_bull_ob_high, nx_bull_fvg_high))
        nx_buy_zone_source := "OB + FVG"
    else if nx_bull_ob_overlap
        nx_buy_exec_low   := nx_inter_low(nx_bull_ob_low, nx_bull_ob_high, nx_buy_zone_low, nx_buy_zone_high)
        nx_buy_exec_high  := nx_inter_high(nx_bull_ob_low, nx_bull_ob_high, nx_buy_zone_low, nx_buy_zone_high)
        nx_buy_zone_source := "Bull OB"
    else if nx_bull_fvg_overlap
        nx_buy_exec_low   := nx_inter_low(nx_bull_fvg_low, nx_bull_fvg_high, nx_buy_zone_low, nx_buy_zone_high)
        nx_buy_exec_high  := nx_inter_high(nx_bull_fvg_low, nx_bull_fvg_high, nx_buy_zone_low, nx_buy_zone_high)
        nx_buy_zone_source := "Bull FVG"

    bool nx_bear_ob_overlap  = nx_overlap(nx_bear_ob_low,  nx_bear_ob_high,  nx_sell_zone_low, nx_sell_zone_high)
    bool nx_bear_fvg_overlap = nx_overlap(nx_bear_fvg_low, nx_bear_fvg_high, nx_sell_zone_low, nx_sell_zone_high)

    if nx_bear_ob_overlap and nx_bear_fvg_overlap and nx_overlap(nx_bear_ob_low, nx_bear_ob_high, nx_bear_fvg_low, nx_bear_fvg_high)
        nx_sell_exec_low   := math.max(nx_sell_zone_low,  math.max(nx_bear_ob_low,  nx_bear_fvg_low))
        nx_sell_exec_high  := math.min(nx_sell_zone_high, math.min(nx_bear_ob_high, nx_bear_fvg_high))
        nx_sell_zone_source := "OB + FVG"
    else if nx_bear_ob_overlap
        nx_sell_exec_low   := nx_inter_low(nx_bear_ob_low, nx_bear_ob_high, nx_sell_zone_low, nx_sell_zone_high)
        nx_sell_exec_high  := nx_inter_high(nx_bear_ob_low, nx_bear_ob_high, nx_sell_zone_low, nx_sell_zone_high)
        nx_sell_zone_source := "Bear OB"
    else if nx_bear_fvg_overlap
        nx_sell_exec_low   := nx_inter_low(nx_bear_fvg_low, nx_bear_fvg_high, nx_sell_zone_low, nx_sell_zone_high)
        nx_sell_exec_high  := nx_inter_high(nx_bear_fvg_low, nx_bear_fvg_high, nx_sell_zone_low, nx_sell_zone_high)
        nx_sell_zone_source := "Bear FVG"

nx_buy_exec_mid  = not na(nx_buy_exec_low)  and not na(nx_buy_exec_high)  ? (nx_buy_exec_low  + nx_buy_exec_high)  * 0.5 : na
nx_sell_exec_mid = not na(nx_sell_exec_low) and not na(nx_sell_exec_high) ? (nx_sell_exec_low + nx_sell_exec_high) * 0.5 : na

nx_in_buy_zone   = nx_dr_valid and not na(nx_buy_exec_low)  and not na(nx_buy_exec_high)  and low <= nx_buy_exec_high  and high >= nx_buy_exec_low
nx_in_sell_zone  = nx_dr_valid and not na(nx_sell_exec_low) and not na(nx_sell_exec_high) and high >= nx_sell_exec_low and low  <= nx_sell_exec_high

nx_near_buy_zone  = nx_dr_valid and not nx_in_buy_zone  and not na(nx_buy_exec_high)  and close > nx_buy_exec_high  and close - nx_buy_exec_high  <= nx_atr * 0.35
nx_near_sell_zone = nx_dr_valid and not nx_in_sell_zone and not na(nx_sell_exec_low) and close < nx_sell_exec_low and nx_sell_exec_low - close <= nx_atr * 0.35

nx_long_invalid = nx_dr_valid ? nx_dr_low : na
nx_short_invalid = nx_dr_valid ? nx_dr_high : na

if not na(nx_bull_ob_low)
    nx_long_invalid := math.min(nx_long_invalid, nx_bull_ob_low)
if not na(nx_bull_fvg_low)
    nx_long_invalid := math.min(nx_long_invalid, nx_bull_fvg_low)

if not na(nx_bear_ob_high)
    nx_short_invalid := math.max(nx_short_invalid, nx_bear_ob_high)
if not na(nx_bear_fvg_high)
    nx_short_invalid := math.max(nx_short_invalid, nx_bear_fvg_high)

nx_long_tp1 = nx_dr_valid ? nx_dr_high : na
nx_long_tp2 = nx_dr_valid ? nx_dr_low + nx_dr_range * nx_tp2_ext : na
nx_long_tp3 = nx_dr_valid ? nx_dr_low + nx_dr_range * nx_tp3_ext : na

nx_short_tp1 = nx_dr_valid ? nx_dr_low : na
nx_short_tp2 = nx_dr_valid ? nx_dr_high - nx_dr_range * nx_tp2_ext : na
nx_short_tp3 = nx_dr_valid ? nx_dr_high - nx_dr_range * nx_tp3_ext : na

nx_buy_pd_ok  = nx_dr_valid and not na(nx_dr_mid) and nx_buy_exec_high  <= nx_dr_mid + nx_atr * 0.20
nx_sell_pd_ok = nx_dr_valid and not na(nx_dr_mid) and nx_sell_exec_low >= nx_dr_mid - nx_atr * 0.20

//==================== SECTION 3 - SEQUENTIAL TRIGGER ENGINE ====================//
groupNX3 = "NX 3. Sequential Trigger Engine"
nx_show_signals      = input.bool(true,  "Tampilkan trigger markers",               group=groupNX3)
nx_use_turtle_soup   = input.bool(true,  "Gunakan Turtle Soup",                     group=groupNX3)
nx_use_cisd          = input.bool(true,  "Gunakan CISD",                            group=groupNX3)
nx_use_local_fvg     = input.bool(true,  "Gunakan local FVG",                       group=groupNX3)
nx_use_local_mss     = input.bool(true,  "Gunakan local MSS",                       group=groupNX3)
nx_require_zone      = input.bool(true,  "Trigger harus terjadi di execution zone", group=groupNX3)

nx_body      = math.abs(close - open)
nx_bar_range = math.max(high - low, syminfo.mintick)
nx_body_ratio = nx_body / nx_bar_range
nx_bull_close_strength = (close - low) / nx_bar_range >= 0.65
nx_bear_close_strength = (close - low) / nx_bar_range <= 0.35
nx_disp_ok = nx_body >= nx_atr * 0.30 and nx_body_ratio >= 0.50

var float nx_last_red_high   = high
var float nx_last_green_low  = low

if close < open
    nx_last_red_high := high
if close > open
    nx_last_green_low := low

nx_t_fvg_bull = nx_use_local_fvg and barstate.isconfirmed and low > high[2] and close[1] > open[1]
nx_t_fvg_bear = nx_use_local_fvg and barstate.isconfirmed and high < low[2] and close[1] < open[1]

nx_t_ts_bull = nx_use_turtle_soup and not na(nx_active_sup) and low < nx_active_sup and close > nx_active_sup
nx_t_ts_bear = nx_use_turtle_soup and not na(nx_active_res) and high > nx_active_res and close < nx_active_res

nx_t_mss_bull = nx_use_local_mss and not na(nx_active_res) and ta.crossover(close, nx_active_res) and nx_disp_ok
nx_t_mss_bear = nx_use_local_mss and not na(nx_active_sup) and ta.crossunder(close, nx_active_sup) and nx_disp_ok

nx_t_cisd_bull = nx_use_cisd and ta.crossover(close, nx_last_red_high)
nx_t_cisd_bear = nx_use_cisd and ta.crossunder(close, nx_last_green_low)

nx_any_bull_trigger = nx_t_fvg_bull or nx_t_ts_bull or nx_t_mss_bull or nx_t_cisd_bull or nx_judas_bull
nx_any_bear_trigger = nx_t_fvg_bear or nx_t_ts_bear or nx_t_mss_bear or nx_t_cisd_bear or nx_judas_bear

nx_bull_setup_armed = nx_dr_valid and nx_bull_bias and nx_htf_bull_active and nx_session_ok and nx_buy_pd_ok
nx_bear_setup_armed = nx_dr_valid and nx_bear_bias and nx_htf_bear_active and nx_session_ok and nx_sell_pd_ok

nx_bull_zone_gate = nx_require_zone ? nx_in_buy_zone : (nx_in_buy_zone or nx_near_buy_zone)
nx_bear_zone_gate = nx_require_zone ? nx_in_sell_zone : (nx_in_sell_zone or nx_near_sell_zone)

nx_ready_buy  = barstate.isconfirmed and nx_bull_setup_armed and nx_bull_zone_gate and nx_any_bull_trigger and close > open and nx_bull_close_strength
nx_ready_sell = barstate.isconfirmed and nx_bear_setup_armed and nx_bear_zone_gate and nx_any_bear_trigger and close < open and nx_bear_close_strength

var string nx_trigger_name = ""
if nx_ready_buy
    string nx_tmp_buy = ""
    if nx_t_fvg_bull
        nx_tmp_buy += "FVG "
    if nx_t_ts_bull
        nx_tmp_buy += "TS "
    if nx_t_mss_bull
        nx_tmp_buy += "MSS "
    if nx_t_cisd_bull
        nx_tmp_buy += "CISD "
    if nx_judas_bull
        nx_tmp_buy += "JUDAS "
    nx_trigger_name := str.trim(nx_tmp_buy)

if nx_ready_sell
    string nx_tmp_sell = ""
    if nx_t_fvg_bear
        nx_tmp_sell += "FVG "
    if nx_t_ts_bear
        nx_tmp_sell += "TS "
    if nx_t_mss_bear
        nx_tmp_sell += "MSS "
    if nx_t_cisd_bear
        nx_tmp_sell += "CISD "
    if nx_judas_bear
        nx_tmp_sell += "JUDAS "
    nx_trigger_name := str.trim(nx_tmp_sell)

//==================== SECTION 4 - TRADE PLAN VISUALS ====================//
groupNX4 = "NX 4. Trade Plan Visuals"
nx_show_plan      = input.bool(true, "Tampilkan trade plan visuals", group=groupNX4)
nx_plan_bars      = input.int(25, "Jarak label/garis (bars)", minval=5, group=groupNX4)
nx_show_path      = input.bool(true, "Tampilkan projected path", group=groupNX4)
nx_show_proj_zone = input.bool(true, "Tampilkan projected zone", group=groupNX4)
nx_show_exec_zone = input.bool(true, "Tampilkan execution zone", group=groupNX4)

