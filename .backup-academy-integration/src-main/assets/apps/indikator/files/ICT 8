nx_zone_bounds(_dir, _mode, _origin, _extreme) =>
    float _range  = math.abs(_extreme - _origin)
    float _fib382 = na
    float _fib500 = na
    float _fib618 = na
    float _fib786 = na
    float _low    = na
    float _high   = na
    if _range > 0
        _fib382 := _dir == 1 ? _extreme - _range * 0.382 : _extreme + _range * 0.382
        _fib500 := _dir == 1 ? _extreme - _range * 0.500 : _extreme + _range * 0.500
        _fib618 := _dir == 1 ? _extreme - _range * 0.618 : _extreme + _range * 0.618
        _fib786 := _dir == 1 ? _extreme - _range * 0.786 : _extreme + _range * 0.786

        if _dir == 1
            if _mode == "Shallow"
                _low := _fib500
                _high := _fib382
            else if _mode == "Deep"
                _low := _fib786
                _high := _fib618
            else if _mode == "Normal"
                _low := _fib618
                _high := _fib500
            else
                _low := _fib786
                _high := _fib500
        else
            if _mode == "Shallow"
                _low := _fib382
                _high := _fib500
            else if _mode == "Deep"
                _low := _fib618
                _high := _fib786
            else if _mode == "Normal"
                _low := _fib500
                _high := _fib618
            else
                _low := _fib500
                _high := _fib786
    [_low, _high, _fib382, _fib500, _fib618, _fib786]

