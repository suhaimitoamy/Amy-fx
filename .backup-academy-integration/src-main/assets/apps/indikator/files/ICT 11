// Session / Killzone
//-----------------------------------------------------------------------------{
mi_londonOpen = not na(time(timeframe.period, "0700-1000", "Europe/London"))
mi_londonClose = not na(time(timeframe.period, "1500-1700", "Europe/London"))
mi_nyAM = not na(time(timeframe.period, "0700-1000", "America/New_York"))
mi_nyPM = not na(time(timeframe.period, "1300-1600", "America/New_York"))

mi_session =
     mi_inAsia ? "Asia | liquidity build" :
     mi_londonOpen ? "London Open | Killzone aktif" :
     mi_nyAM ? "New York AM | Killzone aktif" :
     mi_londonClose ? "London Close | retracement risk" :
     mi_nyPM ? "New York PM" :
     "Off Session"

mi_killzoneActive = mi_londonOpen or mi_nyAM or mi_londonClose

