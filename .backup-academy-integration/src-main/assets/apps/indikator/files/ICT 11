var label mi_pdhLbl = na
var label mi_pdlLbl = na

if showDayLvls and barstate.islast
    if na(mi_doLine)
        mi_doLine  := line.new(bar_index, mi_dailyOpen, bar_index + 1, mi_dailyOpen, extend=extend.right)
        mi_pdhLine := line.new(bar_index, mi_pdh,       bar_index + 1, mi_pdh,       extend=extend.right)
