// OB / FVG info
//-----------------------------------------------------------------------------{
mi_bullObTop = bullish_ob.size() > 0 ? bullish_ob.get(0).top : na
mi_bullObBtm = bullish_ob.size() > 0 ? bullish_ob.get(0).btm : na
mi_bearObTop = bearish_ob.size() > 0 ? bearish_ob.get(0).top : na
mi_bearObBtm = bearish_ob.size() > 0 ? bearish_ob.get(0).btm : na

mi_bullObMid = not na(mi_bullObTop) and not na(mi_bullObBtm) ? math.avg(mi_bullObTop, mi_bullObBtm) : na
mi_bearObMid = not na(mi_bearObTop) and not na(mi_bearObBtm) ? math.avg(mi_bearObTop, mi_bearObBtm) : na

mi_bullObDist = na(mi_bullObMid) ? na : math.abs(close - mi_bullObMid)
mi_bearObDist = na(mi_bearObMid) ? na : math.abs(close - mi_bearObMid)

mi_nearOB =
     na(mi_bullObDist) and na(mi_bearObDist) ? "n/a" :
     na(mi_bearObDist) or mi_bullObDist < mi_bearObDist ? "Bullish OB " + mi_fmt(mi_bullObBtm) + "-" + mi_fmt(mi_bullObTop) + " | " + mi_point(mi_bullObDist) :
     "Bearish OB " + mi_fmt(mi_bearObBtm) + "-" + mi_fmt(mi_bearObTop) + " | " + mi_point(mi_bearObDist)

mi_bullFvgTop = bFVG_UP.size() > 0 ? bFVG_UP.get(0).box.get_top() : na
mi_bullFvgBtm = bFVG_UP.size() > 0 ? bFVG_UP.get(0).box.get_bottom() : na
mi_bearFvgTop = bFVG_DN.size() > 0 ? bFVG_DN.get(0).box.get_top() : na
mi_bearFvgBtm = bFVG_DN.size() > 0 ? bFVG_DN.get(0).box.get_bottom() : na

mi_bullFvgMid = not na(mi_bullFvgTop) and not na(mi_bullFvgBtm) ? math.avg(mi_bullFvgTop, mi_bullFvgBtm) : na
mi_bearFvgMid = not na(mi_bearFvgTop) and not na(mi_bearFvgBtm) ? math.avg(mi_bearFvgTop, mi_bearFvgBtm) : na

mi_bullFvgDist = na(mi_bullFvgMid) ? na : math.abs(close - mi_bullFvgMid)
mi_bearFvgDist = na(mi_bearFvgMid) ? na : math.abs(close - mi_bearFvgMid)

mi_nearFVG =
     na(mi_bullFvgDist) and na(mi_bearFvgDist) ? "n/a" :
     na(mi_bearFvgDist) or mi_bullFvgDist < mi_bearFvgDist ? "Bullish FVG " + mi_fmt(mi_bullFvgBtm) + "-" + mi_fmt(mi_bullFvgTop) + " | " + mi_point(mi_bullFvgDist) :
     "Bearish FVG " + mi_fmt(mi_bearFvgBtm) + "-" + mi_fmt(mi_bearFvgTop) + " | " + mi_point(mi_bearFvgDist)

mi_nearContext =
     str.contains(mi_nearOB, "n/a") and str.contains(mi_nearFVG, "n/a") ? "level break / protected level" :
     str.contains(mi_nearOB, "n/a") ? mi_nearFVG :
     str.contains(mi_nearFVG, "n/a") ? mi_nearOB :
     mi_nearOB + " / " + mi_nearFVG

//-----------------------------------------------------------------------------}
// Candle Pattern
//-----------------------------------------------------------------------------{
mi_body = math.abs(close - open)
mi_range = high - low
mi_upperWick = high - math.max(open, close)
mi_lowerWick = math.min(open, close) - low
mi_avgBody5 = ta.sma(mi_body, 5)

mi_bullEngulf = close > open and close[1] < open[1] and close > open[1] and open < close[1]
mi_bearEngulf = close < open and close[1] > open[1] and close < open[1] and open > close[1]
mi_bullPin = mi_lowerWick > mi_body * 2 and mi_upperWick < mi_body
mi_bearPin = mi_upperWick > mi_body * 2 and mi_lowerWick < mi_body
mi_doji = mi_range > 0 and mi_body <= mi_range * 0.2
mi_bullDisp = close > open and mi_body >= mi_avgBody5 * 1.5
mi_bearDisp = close < open and mi_body >= mi_avgBody5 * 1.5

mi_pattern =
     mi_bullDisp ? "Bullish Displacement" :
     mi_bearDisp ? "Bearish Displacement" :
     mi_bullEngulf ? "Bullish Engulfing" :
     mi_bearEngulf ? "Bearish Engulfing" :
     mi_bullPin ? "Bullish Pin Bar" :
     mi_bearPin ? "Bearish Pin Bar" :
     mi_doji ? "Doji" :
     "None"

mi_patternReason =
     mi_bullDisp ? "candle kuat naik / continuation clue" :
     mi_bearDisp ? "candle kuat turun / continuation clue" :
     mi_bullEngulf ? "engulfing bullish / pressure naik" :
     mi_bearEngulf ? "engulfing bearish / pressure turun" :
     mi_bullPin ? "rejection wick bawah" :
     mi_bearPin ? "rejection wick atas" :
     mi_doji ? "indecision / belum jelas" :
     "belum ada candle konfirmasi"

//-----------------------------------------------------------------------------}
// Market State / Bias
//-----------------------------------------------------------------------------{
mi_atr = ta.atr(14)
mi_range5 = ta.highest(high, 5) - ta.lowest(low, 5)

mi_marketState =
     mi_range5 <= mi_atr * 0.75 ? "Ranging" :
     mi_body >= mi_avgBody5 * 1.5 ? "Ekspansi" :
     "Kompresi"

mi_marketInfo = mi_marketState + " | Range " + mi_point(mi_range5) + " | ATR " + mi_point(mi_atr)

mi_doBull = close > mi_dailyOpen
mi_asiaBull = not na(mi_asiaEQ) and close > mi_asiaEQ
mi_doBear = close < mi_dailyOpen
mi_asiaBear = not na(mi_asiaEQ) and close < mi_asiaEQ

mi_biasRaw =
     mi_doBull and mi_asiaBull ? 1 :
     mi_doBear and mi_asiaBear ? -1 :
     0

mi_bias =
     mi_biasRaw == 1 ? "Bullish | DO bullish, Asia EQ bullish" :
     mi_biasRaw == -1 ? "Bearish | DO bearish, Asia EQ bearish" :
     mi_doBull and mi_asiaBear ? "Netral | DO bullish, Asia EQ bearish" :
     mi_doBear and mi_asiaBull ? "Netral | DO bearish, Asia EQ bullish" :
     "Netral | belum jelas"

mi_conflict = mi_biasRaw == 0

//-----------------------------------------------------------------------------}
// Key Levels / Protected
//-----------------------------------------------------------------------------{
mi_pivotHigh = ta.pivothigh(high, 3, 1)
mi_pivotLow  = ta.pivotlow(low, 3, 1)

var float mi_protectedHigh = na
var float mi_protectedLow  = na

if not na(mi_pivotHigh)
    mi_protectedHigh := mi_pivotHigh

if not na(mi_pivotLow)
    mi_protectedLow := mi_pivotLow

mi_upperKey = not na(mi_protectedHigh) ? mi_protectedHigh : mi_asiaHigh
mi_lowerKey = not na(mi_protectedLow) ? mi_protectedLow : mi_asiaLow

mi_breakUp = not na(mi_upperKey) and close > mi_upperKey
mi_breakDn = not na(mi_lowerKey) and close < mi_lowerKey

mi_rejectTop = not na(mi_upperKey) and high > mi_upperKey and close < mi_upperKey
mi_rejectBtm = not na(mi_lowerKey) and low < mi_lowerKey and close > mi_lowerKey

mi_breakLine = ">" + mi_fmt(mi_upperKey) + " lanjut naik | <" + mi_fmt(mi_lowerKey) + " lanjut turun"
mi_protectedLine = "PH " + mi_fmt(mi_protectedHigh) + " | PL " + mi_fmt(mi_protectedLow)

mi_rejectionLine =
     mi_rejectTop ? "Test " + mi_fmt(mi_upperKey) + " gagal = reject atas forming" :
     mi_rejectBtm ? "Test " + mi_fmt(mi_lowerKey) + " gagal = reject bawah forming" :
     "Belum ada rejection jelas"

//-----------------------------------------------------------------------------}
// Event Engine
//-----------------------------------------------------------------------------{
mi_judasBear = (mi_londonOpen or mi_nyAM) and mi_asiaHighSwept and (mi_bearPin or mi_bearEngulf or mi_doji)
mi_judasBull = (mi_londonOpen or mi_nyAM) and mi_asiaLowSwept and (mi_bullPin or mi_bullEngulf or mi_doji)

mi_event =
     mi_judasBear ? "Judas Swing Risk" :
     mi_judasBull ? "Judas Swing Risk" :
     not na(mi_protectedHigh) and close > mi_protectedHigh ? "Protected High Broken" :
     not na(mi_protectedLow) and close < mi_protectedLow ? "Protected Low Broken" :
     mi_pdhSwept ? "PDH Taken" :
     mi_pdlSwept ? "PDL Taken" :
     mi_asiaHighSwept ? "Asia High Swept" :
     mi_asiaLowSwept ? "Asia Low Swept" :
     mi_breakUp ? "Break Level Valid" :
     mi_breakDn ? "Break Level Valid" :
     mi_rejectTop or mi_rejectBtm ? "Rejection Forming" :
     mi_marketState == "Ekspansi" ? "Expansion Running" :
     mi_marketState == "Kompresi" ? "Liquidity Build" :
     "No Major Event"

mi_focus =
     mi_event == "Protected Low Broken" or mi_event == "Break Level Valid" and mi_breakDn or mi_bearDisp or mi_biasRaw == -1 ? "Fokus SELL" :
     mi_event == "Protected High Broken" or mi_event == "Break Level Valid" and mi_breakUp or mi_bullDisp or mi_biasRaw == 1 ? "Fokus BUY" :
     "WAIT"

mi_focusReason =
     mi_focus == "Fokus SELL" ? "struktur/bias cenderung turun, jangan kejar harga" :
     mi_focus == "Fokus BUY" ? "struktur/bias cenderung naik, jangan kejar harga" :
     "arah belum bersih, tunggu reaksi level"

mi_info =
     mi_event == "Judas Swing Risk" and mi_judasBear ? "Sweep Asia High saat Killzone, close balik range" :
     mi_event == "Judas Swing Risk" and mi_judasBull ? "Sweep Asia Low saat Killzone, close balik range" :
     mi_event == "Protected High Broken" ? "Body close tembus Protected High, bearish structure gugur" :
     mi_event == "Protected Low Broken" ? "Body close tembus Protected Low, bullish structure gugur" :
     mi_event == "PDH Taken" ? "Harga sudah mengambil liquidity di atas PDH" :
     mi_event == "PDL Taken" ? "Harga sudah mengambil liquidity di bawah PDL" :
     mi_event == "Asia High Swept" ? "Harga sweep Asia High lalu close balik range" :
     mi_event == "Asia Low Swept" ? "Harga sweep Asia Low lalu close balik range" :
     mi_event == "Break Level Valid" and mi_breakUp ? "Body close tembus level atas" :
     mi_event == "Break Level Valid" and mi_breakDn ? "Body close tembus level bawah" :
     mi_event == "Rejection Forming" ? "Harga test level kunci tapi gagal close tembus" :
     mi_event == "Expansion Running" ? "Candle besar sedang dorong harga keluar range" :
     mi_event == "Liquidity Build" ? "Harga masih kompresi, liquidity sedang build" :
     "Belum ada event besar, tunggu reaksi di level kunci"

mi_scenario =
     mi_event == "Judas Swing Risk" ? "Tunggu MSS / displacement setelah sweep" :
     mi_event == "Protected High Broken" ? "Jika follow-through kuat, potensi lanjut naik" :
     mi_event == "Protected Low Broken" ? "Jika follow-through kuat, potensi lanjut turun" :
     mi_event == "PDH Taken" ? "Jika close bertahan di atas PDH, potensi lanjut naik" :
     mi_event == "PDL Taken" ? "Jika close bertahan di bawah PDL, potensi lanjut turun" :
     mi_event == "Asia High Swept" ? "Jika close balik bawah Asia High, rejection risk naik" :
     mi_event == "Asia Low Swept" ? "Jika close balik atas Asia Low, rejection risk naik" :
     mi_event == "Break Level Valid" and mi_breakUp ? "Jika follow-through kuat, potensi lanjut naik" :
     mi_event == "Break Level Valid" and mi_breakDn ? "Jika follow-through kuat, potensi lanjut turun" :
     mi_event == "Rejection Forming" ? "Tunggu candle lanjutan untuk validasi rejection" :
     mi_event == "Expansion Running" ? "Pantau follow-through dan pullback sehat" :
     mi_event == "Liquidity Build" ? "Tunggu close body keluar level kunci" :
     "Tunggu close body di luar level penting"

mi_areaFocus =
     mi_focus == "Fokus SELL" ? "Pullback/retest ke " + mi_fmt(mi_lowerKey) + " / " + mi_nearContext :
     mi_focus == "Fokus BUY" ? "Pullback/retest ke " + mi_fmt(mi_upperKey) + " / " + mi_nearContext :
     "Tunggu harga mendekati level kunci"

mi_trigger =
     mi_focus == "Fokus SELL" ? "rejection di area fokus + close turun" :
     mi_focus == "Fokus BUY" ? "rejection di area fokus + close naik" :
     "body close jelas / displacement"

mi_invalid =
     mi_focus == "Fokus SELL" ? "close body balik di atas " + mi_fmt(mi_lowerKey) :
     mi_focus == "Fokus BUY" ? "close body balik di bawah " + mi_fmt(mi_upperKey) :
     "belum ada invalidasi jelas"

mi_warning =
     mi_event == "Judas Swing Risk" ? "Awas manipulasi awal sesi" :
     mi_event == "PDH Taken" or mi_event == "PDL Taken" ? "Awas rejection jika close balik level" :
     mi_event == "Asia High Swept" or mi_event == "Asia Low Swept" ? "Awas false break Asia Range" :
     mi_event == "Rejection Forming" ? "Awas rejection belum valid tanpa candle lanjutan" :
     mi_conflict ? "Bias konflik, market belum bersih" :
     "Tidak ada warning besar"

mi_evidence =
     mi_pattern != "None" ? "Pattern: " + mi_pattern + " | " + mi_patternReason :
     mi_event == "PDH Taken" or mi_event == "PDL Taken" ? "Liquidity sudah diambil, confirmation belum lengkap" :
     mi_event == "Break Level Valid" ? "Body close tembus level, tunggu follow-through" :
     "Confirmation belum lengkap"

//-----------------------------------------------------------------------------}
// Quality / Confidence
//-----------------------------------------------------------------------------{
mi_score = 0
mi_score += mi_killzoneActive ? 15 : 0
mi_score += mi_event != "No Major Event" ? 20 : 0
mi_score += mi_bullDisp or mi_bearDisp ? 20 : 0
mi_score += mi_asiaHighSwept or mi_asiaLowSwept or mi_pdhTaken or mi_pdlTaken ? 15 : 0
mi_score += mi_breakUp or mi_breakDn ? 15 : 0
mi_score -= mi_conflict ? 15 : 0
mi_score -= mi_marketState == "Ranging" ? 10 : 0

mi_confidence = math.max(0, math.min(100, mi_score))
mi_quality =
     mi_confidence >= 70 ? "Kuat" :
     mi_confidence >= 40 ? "Sedang" :
     "Lemah"

mi_qualityLine = mi_quality + " | Confidence " + str.tostring(mi_confidence) + "%"

//-----------------------------------------------------------------------------}
