mi_pdh       = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
mi_pdl       = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_on)

mi_pdhTaken = not na(mi_pdh) and high >= mi_pdh
mi_pdlTaken = not na(mi_pdl) and low  <= mi_pdl

mi_pdhSwept = not na(mi_pdh) and high > mi_pdh and close < mi_pdh
mi_pdlSwept = not na(mi_pdl) and low  < mi_pdl and close > mi_pdl

var line mi_doLine  = na
var line mi_pdhLine = na
var line mi_pdlLine = na

