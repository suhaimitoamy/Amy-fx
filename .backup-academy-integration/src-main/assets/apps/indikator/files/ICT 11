    mi_pdhLbl := label.new(bar_index, mi_pdh,       "PDH",        style=label.style_label_left, textcolor=color.white, color=color.new(color.gray, 75))
    mi_pdlLbl := label.new(bar_index, mi_pdl,       "PDL",        style=label.style_label_left, textcolor=color.white, color=color.new(color.gray, 75))

