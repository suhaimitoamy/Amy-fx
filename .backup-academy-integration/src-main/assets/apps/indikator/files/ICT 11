    else
        line.set_xy1(mi_asiaHighLine, bar_index, mi_asiaHigh)
        line.set_xy2(mi_asiaHighLine, bar_index + 1, mi_asiaHigh)
        line.set_xy1(mi_asiaLowLine, bar_index, mi_asiaLow)
        line.set_xy2(mi_asiaLowLine, bar_index + 1, mi_asiaLow)
        line.set_xy1(mi_asiaEQLine, bar_index, mi_asiaEQ)
        line.set_xy2(mi_asiaEQLine, bar_index + 1, mi_asiaEQ)

    label.delete(mi_asiaHighLbl)
    label.delete(mi_asiaLowLbl)
    label.delete(mi_asiaEQLbl)

    mi_asiaHighLbl := label.new(bar_index, mi_asiaHigh, "Asia High", style=label.style_label_left, textcolor=color.white, color=color.new(color.gray, 70))
    mi_asiaLowLbl  := label.new(bar_index, mi_asiaLow,  "Asia Low",  style=label.style_label_left, textcolor=color.white, color=color.new(color.gray, 70))
    mi_asiaEQLbl   := label.new(bar_index, mi_asiaEQ,   "Asia EQ",   style=label.style_label_left, textcolor=color.white, color=color.new(color.gray, 80))

