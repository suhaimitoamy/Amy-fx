// Asia Range
//-----------------------------------------------------------------------------{
mi_inAsia  = not na(time(timeframe.period, mi_asiaSess, mi_tz))
mi_newAsia = mi_inAsia and not mi_inAsia[1]

var float mi_asiaHigh = na
var float mi_asiaLow  = na
var float mi_asiaEQ   = na

if mi_newAsia
    mi_asiaHigh := high
    mi_asiaLow  := low

if mi_inAsia
    mi_asiaHigh := na(mi_asiaHigh) ? high : math.max(mi_asiaHigh, high)
    mi_asiaLow  := na(mi_asiaLow)  ? low  : math.min(mi_asiaLow, low)

mi_asiaEQ := not na(mi_asiaHigh) and not na(mi_asiaLow) ? math.avg(mi_asiaHigh, mi_asiaLow) : na

mi_asiaHighSwept = not na(mi_asiaHigh) and high > mi_asiaHigh and close < mi_asiaHigh
mi_asiaLowSwept  = not na(mi_asiaLow)  and low  < mi_asiaLow  and close > mi_asiaLow

mi_asiaBreakUp = not na(mi_asiaHigh) and close > mi_asiaHigh
mi_asiaBreakDn = not na(mi_asiaLow)  and close < mi_asiaLow

mi_asiaStatus =
     na(mi_asiaHigh) or na(mi_asiaLow) ? "Belum Ada" :
     mi_asiaHighSwept ? "Buyside Swept | close balik range" :
     mi_asiaLowSwept ? "Sellside Swept | close balik range" :
     mi_asiaBreakUp ? "Break Above Asia" :
     mi_asiaBreakDn ? "Break Below Asia" :
     close > mi_asiaEQ ? "Active | harga di atas EQ" :
     close < mi_asiaEQ ? "Active | harga di bawah EQ" :
     "Active"

var line mi_asiaHighLine = na
var line mi_asiaLowLine  = na
var line mi_asiaEQLine   = na

var label mi_asiaHighLbl = na
var label mi_asiaLowLbl  = na
var label mi_asiaEQLbl   = na

if showAsiaLn and barstate.islast and not na(mi_asiaHigh) and not na(mi_asiaLow)
